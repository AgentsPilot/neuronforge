/**
 * IR Requirements Validator
 *
 * Validates that Hard Requirements from Phase 0 are preserved in the Formalized IR.
 * This runs AFTER IR formalization and BEFORE compilation.
 *
 * Purpose: Ensure no requirements are lost between Semantic Plan → IR
 */

import type { HardRequirements } from './HardRequirementsExtractor'
import type { DeclarativeLogicalIR } from '../logical-ir/schemas/declarative-ir-types'

export interface IRValidationResult {
  valid: boolean
  score: number  // 0-100, percentage of requirements preserved
  preserved_requirements: string[]  // Requirement IDs that are preserved
  missing_requirements: string[]    // Requirement IDs that are missing
  details: Array<{
    requirementId: string
    type: string
    constraint: string
    preserved: boolean
    irMapping: string | null
    evidence: string
  }>
}

export class IRRequirementsValidator {
  /**
   * Validate that all Hard Requirements are preserved in IR
   */
  validate(
    hardRequirements: HardRequirements,
    ir: DeclarativeLogicalIR
  ): IRValidationResult {
    const details: IRValidationResult['details'] = []
    const preserved: string[] = []
    const missing: string[] = []

    // Check each requirement
    hardRequirements.requirements.forEach(req => {
      const result = this.checkRequirement(req, ir, hardRequirements)

      details.push({
        requirementId: req.id,
        type: req.type,
        constraint: req.constraint,
        preserved: result.preserved,
        irMapping: result.mapping,
        evidence: result.evidence
      })

      if (result.preserved) {
        preserved.push(req.id)
      } else {
        missing.push(req.id)
      }
    })

    const totalReqs = hardRequirements.requirements.length
    const preservedCount = preserved.length
    const score = totalReqs > 0 ? Math.round((preservedCount / totalReqs) * 100) : 100

    return {
      valid: score >= 80, // Require 80% preservation to pass
      score,
      preserved_requirements: preserved,
      missing_requirements: missing,
      details
    }
  }

  /**
   * Check if a single requirement is preserved in the IR
   */
  private checkRequirement(
    req: { id: string; type: string; constraint: string },
    ir: DeclarativeLogicalIR,
    hardReqs: HardRequirements
  ): { preserved: boolean; mapping: string | null; evidence: string } {
    const irJson = JSON.stringify(ir).toLowerCase()

    switch (req.type) {
      case 'unit_of_work': {
        // Check if unit of work is referenced in data sources
        if (hardReqs.unit_of_work === 'attachment') {
          // Check data sources for attachment/PDF references
          const hasAttachment = ir.data_sources?.some(ds =>
            ds.config?.attachment_types ||
            ds.config?.has_attachment ||
            JSON.stringify(ds.config || {}).toLowerCase().includes('attachment') ||
            JSON.stringify(ds.config || {}).toLowerCase().includes('pdf')
          )
          if (hasAttachment) {
            return {
              preserved: true,
              mapping: 'data_sources[].config',
              evidence: 'Unit of work (attachment) found in data source config'
            }
          }
        } else if (hardReqs.unit_of_work === 'email') {
          // Check data sources for email references
          const hasEmail = ir.data_sources?.some(ds =>
            ds.plugin_key?.includes('mail') ||
            ds.source?.includes('mail') ||
            ds.operation_type === 'search'
          )
          if (hasEmail) {
            return {
              preserved: true,
              mapping: 'data_sources[]',
              evidence: 'Unit of work (email) found in data sources'
            }
          }
        } else if (hardReqs.unit_of_work === 'row') {
          // Check data sources for tabular data
          const hasRows = ir.data_sources?.some(ds =>
            ds.type === 'tabular' ||
            ds.plugin_key?.includes('sheets') ||
            ds.plugin_key?.includes('excel')
          )
          if (hasRows) {
            return {
              preserved: true,
              mapping: 'data_sources[]',
              evidence: 'Unit of work (row) found in tabular data sources'
            }
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: `Unit of work ${hardReqs.unit_of_work} not found in IR`
        }
      }

      case 'threshold': {
        // Check if threshold is captured in post_ai_filters or conditionals
        const thresholds = hardReqs.thresholds
        if (thresholds.length === 0) {
          return { preserved: true, mapping: null, evidence: 'No thresholds to validate' }
        }

        const threshold = thresholds[0]

        // Check post_ai_filters
        const hasPostFilter = ir.post_ai_filters?.conditions?.some(cond =>
          cond.field.toLowerCase() === threshold.field.toLowerCase() &&
          (cond.operator === 'greater_than' || cond.operator === 'less_than')
        )

        // Check conditionals
        const hasConditional = ir.conditionals?.some(cond => {
          const condJson = JSON.stringify(cond).toLowerCase()
          return condJson.includes(threshold.field.toLowerCase()) &&
                 (condJson.includes('greater') || condJson.includes(String(threshold.value)))
        })

        if (hasPostFilter || hasConditional) {
          return {
            preserved: true,
            mapping: hasPostFilter ? 'post_ai_filters.conditions[]' : 'conditionals[]',
            evidence: `Threshold ${threshold.field}>${threshold.value} found in ${hasPostFilter ? 'post_ai_filters' : 'conditionals'}`
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: `Threshold ${threshold.field}>${threshold.value} not found in IR`
        }
      }

      case 'invariant': {
        // Check if invariants are preserved
        if (req.constraint.includes('sequential')) {
          // Check for sequential markers in delivery_rules.multiple_destinations
          if (ir.delivery_rules.multiple_destinations) {
            // Sequential execution is indicated by {{step_result.*}} references in config
            const hasStepRefs = ir.delivery_rules.multiple_destinations.some(dest => {
              const configJson = JSON.stringify(dest.config || {})
              return configJson.includes('{{step_result.') || configJson.includes('step_result')
            })
            if (hasStepRefs) {
              return {
                preserved: true,
                mapping: 'delivery_rules.multiple_destinations[].config',
                evidence: 'Sequential dependency markers ({{step_result.*}}) found in delivery config'
              }
            }
          }

          // Also check file_operations for sequential operations
          if (ir.file_operations) {
            const hasFileOps = ir.file_operations.length >= 2
            if (hasFileOps) {
              return {
                preserved: true,
                mapping: 'file_operations[]',
                evidence: 'Sequential file operations detected (create, upload, share)'
              }
            }
          }

          return {
            preserved: false,
            mapping: null,
            evidence: 'Sequential dependency markers not found in IR'
          }
        } else if (req.constraint.includes('data availability')) {
          // Data availability is implicit in IR structure
          // If delivery_rules exist and data_sources exist, this is satisfied
          if (ir.delivery_rules && ir.data_sources && ir.data_sources.length > 0) {
            return {
              preserved: true,
              mapping: 'delivery_rules + data_sources',
              evidence: 'Data availability preserved (delivery after data sources)'
            }
          }
          return {
            preserved: false,
            mapping: null,
            evidence: 'Data availability not clear in IR structure'
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: 'Invariant type not recognized'
        }
      }

      case 'required_output': {
        // Check if required output field is in rendering or AI output schema
        const match = req.constraint.match(/output\.includes\('([^']+)'\)/)
        if (!match) {
          return { preserved: false, mapping: null, evidence: 'Could not parse output field' }
        }

        const outputField = match[1]

        // Check rendering.columns_in_order
        const hasInRendering = ir.rendering?.columns_in_order?.some(col =>
          col.toLowerCase().includes(outputField.toLowerCase())
        )

        // Check AI operation output schema
        const hasInAISchema = ir.ai_operations?.some(op =>
          op.output_schema.fields?.some(field =>
            field.name.toLowerCase().includes(outputField.toLowerCase())
          )
        )

        if (hasInRendering || hasInAISchema) {
          return {
            preserved: true,
            mapping: hasInRendering ? 'rendering.columns_in_order' : 'ai_operations[].output_schema.fields[]',
            evidence: `Output field ${outputField} found in ${hasInRendering ? 'rendering columns' : 'AI output schema'}`
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: `Output field ${outputField} not found in IR`
        }
      }

      case 'side_effect_constraint': {
        // Check if conditional logic is captured in conditionals or post_ai_filters
        const hasConditionals = ir.conditionals && ir.conditionals.length > 0
        const hasPostFilters = ir.post_ai_filters && ir.post_ai_filters.conditions && ir.post_ai_filters.conditions.length > 0

        if (hasConditionals || hasPostFilters) {
          return {
            preserved: true,
            mapping: hasConditionals ? 'conditionals[]' : 'post_ai_filters',
            evidence: 'Conditional logic found in IR'
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: 'Conditional logic not found in IR'
        }
      }

      case 'routing_rule': {
        // Check if routing rules are in partitions or delivery rules
        const rules = hardReqs.routing_rules
        if (rules.length === 0) {
          return { preserved: true, mapping: null, evidence: 'No routing rules to validate' }
        }

        const hasPartitions = ir.partitions && ir.partitions.length > 0
        const hasGrouping = ir.grouping !== undefined

        if (hasPartitions || hasGrouping) {
          return {
            preserved: true,
            mapping: hasPartitions ? 'partitions[]' : 'grouping',
            evidence: 'Routing logic found in IR'
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: 'Routing logic not found in IR'
        }
      }

      case 'empty_behavior': {
        // Check if empty state handling is captured
        const hasEdgeCase = ir.edge_cases?.some(ec =>
          ec.condition === 'no_rows_after_filter' ||
          ec.condition === 'empty_data_source'
        )
        const hasEmptyMessage = ir.rendering?.empty_message !== undefined
        const hasSendWhenEmpty = ir.delivery_rules.send_when_no_results !== undefined

        if (hasEdgeCase || hasEmptyMessage || hasSendWhenEmpty) {
          return {
            preserved: true,
            mapping: hasEdgeCase ? 'edge_cases[]' : hasEmptyMessage ? 'rendering.empty_message' : 'delivery_rules.send_when_no_results',
            evidence: 'Empty state handling found in IR'
          }
        }
        return {
          preserved: false,
          mapping: null,
          evidence: 'Empty state handling not found in IR'
        }
      }

      default:
        return {
          preserved: false,
          mapping: null,
          evidence: `Unknown requirement type: ${req.type}`
        }
    }
  }
}
