      "idempotent": false,
      "domain": "messaging",
      "capability": "upload",
      "input_entity": "file",
      "output_entity": "file",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": [
        "id",
        "name",
        "url_private"
      ],
      "required_params": [
