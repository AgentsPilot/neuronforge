      ],
      "parameters": {
        "type": "object",
        "required": [
          "filename",
          "file_content"
        ],
        "properties": {
          "filename": {
            "type": "string",
            "description": "The name of the file to upload",
            "x-variable-mapping": {
              "from_type": "file_attachment",
              "field_path": "filename",
              "description": "Extract filename from attachment or file object"
            }
          },
          "file_content": {
            "type": "string",
            "description": "The file content (base64 encoded for binary files, or plain text)",
            "x-variable-mapping": {
              "from_type": "file_attachment",
              "field_path": "content",
              "description": "Extract content from attachment or file object"
            }
          },
          "channel_ids": {
            "type": "array",
            "description": "Array of channel IDs where the file should be shared",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string",
            "description": "Optional: title for the file"
          },
          "initial_comment": {
            "type": "string",
            "description": "Optional: message to include with the file"
          }
        }
      },
      "rules": [
        {
          "rule_type": "confirmation",
          "field": "file_content",
          "message": "You are about to upload a file named '{filename}' to Slack. Proceed?"
        }
      ],
      "output_schema": {
        "type": "object",
        "description": "Details of the uploaded file",
        "properties": {
          "file_id": {
            "type": "string",
            "description": "ID of the uploaded file",
            "x-guaranteed": true
          },
          "filename": {
            "type": "string",
            "description": "Name of the file"
          },
          "title": {
            "type": "string",
            "description": "Title of the file",
