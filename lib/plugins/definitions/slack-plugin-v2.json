          },
          "url": {
            "type": "string",
            "description": "Permalink URL to access the file"
          },
          "channels": {
            "type": "array",
            "description": "Channel IDs where file was shared",
            "items": {
              "type": "string"
            }
          },
          "success": {
            "type": "boolean",
            "description": "Whether upload was successful"
          },
          "uploaded_at": {
            "type": "string",
            "description": "ISO 8601 timestamp of upload",
            "x-guaranteed": true
          }
        },
        "required": [
          "id",
          "name",
          "url_private"
        ]
      },
      "output_guidance": {
