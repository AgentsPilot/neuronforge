      },
      "output_schema": {
        "type": "object",
        "x-semantic-type": "folder",
        "properties": {
          "folder_id": { "type": "string", "x-guaranteed": true },
          "folder_name": { "type": "string", "x-guaranteed": true },
          "web_url": { "type": "string" },
          "created_at": { "type": "string", "x-guaranteed": true }
