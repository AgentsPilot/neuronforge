{
  "plugin": {
    "name": "onedrive",
    "version": "1.0.0",
    "description": "Access, search, upload, and manage files and folders in Microsoft OneDrive",
    "context": "Use for accessing OneDrive files, searching documents, uploading files, creating folders, managing folder structures, and sharing files. Part of Microsoft 365 with same credentials as Outlook.",
    "icon": "<Cloud className='w-5 h-5 text-blue-600'/>",
    "category": "productivity",
    "isPopular": true,
    "auth_config": {
      "auth_type": "oauth2_microsoft",
      "client_id": "${MICROSOFT_CLIENT_ID}",
      "client_secret": "${MICROSOFT_CLIENT_SECRET}",
      "redirect_uri": "${NEXT_PUBLIC_APP_URL}/oauth/callback/onedrive",
      "auth_url": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
      "token_url": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "refresh_url": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
      "profile_url": "https://graph.microsoft.com/v1.0/me",
      "required_scopes": [
        "openid",
        "profile",
        "email",
        "offline_access",
        "https://graph.microsoft.com/Files.ReadWrite.All"
      ],
      "token_expiry_seconds": 3600
    },
    "provider_family": "microsoft"
  },
  "actions": {
    "list_files": {
      "description": "List files and folders in OneDrive with optional filtering and sorting",
      "usage_context": "When user wants to browse OneDrive contents, see files in a folder, or list files matching criteria",
      "idempotent": true,
      "domain": "storage",
      "capability": "list",
      "input_entity": "folder",
      "output_entity": "file",
      "input_cardinality": "single",
      "output_cardinality": "collection",
      "output_fields": ["id", "name", "size", "createdDateTime", "lastModifiedDateTime", "webUrl", "mimeType"],
      "required_params": [],
      "optional_params": ["folder_id", "max_results", "order_by", "file_types"],
      "must_support": ["folder_browsing", "mime_type_filter", "date_filter"],
      "parameters": {
        "type": "object",
        "properties": {
          "folder_id": {
            "type": "string",
            "description": "ID of the folder to list files from. If not provided, lists from root",
            "x-dynamic-options": {
              "source": "list_folders",
              "description": "Fetches available folders dynamically"
            },
            "x-variable-mapping": {
              "from_type": "folder",
              "field_path": "folder_id",
              "description": "Extract folder ID from folder object"
            }
          },
          "max_results": {
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "default": 20,
            "description": "Maximum number of files to return"
          },
          "order_by": {
            "type": "string",
            "enum": ["lastModifiedDateTime", "name", "createdDateTime", "size"],
            "default": "lastModifiedDateTime",
            "description": "How to order the file results"
          },
          "file_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["document", "spreadsheet", "presentation", "pdf", "image", "video", "folder", "all"]
            },
            "description": "Filter by file types"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "x-semantic-type": "file_attachment",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "size": { "type": "integer" },
                "mimeType": { "type": "string" },
                "createdDateTime": { "type": "string" },
                "lastModifiedDateTime": { "type": "string" },
                "webUrl": { "type": "string" },
                "isFolder": { "type": "boolean" }
              }
            }
          },
          "file_count": { "type": "integer", "x-guaranteed": true },
          "retrieved_at": { "type": "string", "x-guaranteed": true }
        }
      },
      "output_guidance": {
        "success_description": "Retrieved files from OneDrive",
        "sample_output": {
          "files": [
            {
              "id": "01BYE5RZ6QN3ZWBTUFOFD3GSPGOHDJD36K",
              "name": "invoice.pdf",
              "size": 245760,
              "mimeType": "application/pdf",
              "createdDateTime": "2026-03-13T10:00:00Z",
              "lastModifiedDateTime": "2026-03-13T15:00:00Z",
              "webUrl": "https://onedrive.live.com/...",
              "isFolder": false
            }
          ],
          "file_count": 1,
          "retrieved_at": "2026-03-13T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your OneDrive connection has expired. Please reconnect in Settings → Connected Apps.",
          "folder_not_found": "The specified folder was not found.",
          "insufficient_permissions": "Files.Read permission is required to list files."
        }
      }
    },
    "search_files": {
      "description": "Search for files and folders in OneDrive using query text",
      "usage_context": "When user wants to find specific files by name, content, or metadata",
      "idempotent": true,
      "domain": "storage",
      "capability": "search",
      "input_entity": null,
      "output_entity": "file",
      "input_cardinality": null,
      "output_cardinality": "collection",
      "output_fields": ["id", "name", "size", "mimeType", "lastModifiedDateTime", "webUrl"],
      "required_params": ["query"],
      "optional_params": ["folder_id", "max_results"],
      "must_support": ["full_text_search", "scoped_search"],
      "parameters": {
        "type": "object",
        "required": ["query"],
        "properties": {
          "query": {
            "type": "string",
            "description": "Search query text (searches file names and content)"
          },
          "folder_id": {
            "type": "string",
            "description": "Limit search to specific folder",
            "x-variable-mapping": {
              "from_type": "folder",
              "field_path": "folder_id",
              "description": "Extract folder ID from folder object"
            }
          },
          "max_results": {
            "type": "number",
            "minimum": 1,
            "maximum": 100,
            "default": 20,
            "description": "Maximum number of results"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "x-semantic-type": "file_attachment",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "size": { "type": "integer" },
                "mimeType": { "type": "string" },
                "lastModifiedDateTime": { "type": "string" },
                "webUrl": { "type": "string" }
              }
            }
          },
          "file_count": { "type": "integer", "x-guaranteed": true },
          "searched_at": { "type": "string", "x-guaranteed": true }
        }
      },
      "output_guidance": {
        "success_description": "Search results from OneDrive",
        "sample_output": {
          "files": [
            {
              "id": "01BYE5RZ6QN3ZWBTUFOFD3GSPGOHDJD36K",
              "name": "invoice-march.pdf",
              "size": 245760,
              "mimeType": "application/pdf",
              "lastModifiedDateTime": "2026-03-13T15:00:00Z",
              "webUrl": "https://onedrive.live.com/..."
            }
          ],
          "file_count": 1,
          "searched_at": "2026-03-13T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your OneDrive connection has expired. Please reconnect."
        }
      }
    },
    "get_file_metadata": {
      "description": "Get detailed information about a specific file or folder",
      "usage_context": "When user wants file details, permissions, or metadata",
      "idempotent": true,
      "domain": "storage",
      "capability": "get",
      "input_entity": "file",
      "output_entity": "file",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["id", "name", "size", "mimeType", "createdDateTime", "lastModifiedDateTime", "createdBy", "lastModifiedBy"],
      "required_params": ["file_id"],
      "optional_params": ["include_permissions"],
      "must_support": ["metadata_retrieval", "permission_info"],
      "parameters": {
        "type": "object",
        "required": ["file_id"],
        "properties": {
          "file_id": {
            "type": "string",
            "description": "ID of the file or folder",
            "x-variable-mapping": {
              "from_type": "file",
              "field_path": "id",
              "description": "Extract file ID from file object"
            }
          },
          "include_permissions": {
            "type": "boolean",
            "default": false,
            "description": "Include sharing permissions"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "x-guaranteed": true },
          "name": { "type": "string", "x-guaranteed": true },
          "size": { "type": "integer" },
          "mimeType": { "type": "string" },
          "createdDateTime": { "type": "string" },
          "lastModifiedDateTime": { "type": "string" },
          "webUrl": { "type": "string" },
          "createdBy": { "type": "object" },
          "lastModifiedBy": { "type": "object" }
        }
      },
      "output_guidance": {
        "success_description": "Retrieved file metadata",
        "sample_output": {
          "id": "01BYE5RZ6QN3ZWBTUFOFD3GSPGOHDJD36K",
          "name": "invoice.pdf",
          "size": 245760,
          "mimeType": "application/pdf",
          "createdDateTime": "2026-03-13T10:00:00Z",
          "lastModifiedDateTime": "2026-03-13T15:00:00Z",
          "webUrl": "https://onedrive.live.com/..."
        },
        "common_errors": {
          "auth_failed": "Your OneDrive connection has expired.",
          "file_not_found": "The specified file was not found."
        }
      }
    },
    "download_file": {
      "description": "Download file content from OneDrive",
      "usage_context": "When user needs to download or access file content",
      "idempotent": true,
      "domain": "storage",
      "capability": "fetch_content",
      "input_entity": "file",
      "output_entity": "file",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["file_id", "file_name", "content", "mime_type", "size"],
      "required_params": ["file_id"],
      "optional_params": ["return_url_only"],
      "must_support": ["binary_download", "url_generation"],
      "parameters": {
        "type": "object",
        "required": ["file_id"],
        "properties": {
          "file_id": {
            "type": "string",
            "description": "ID of the file to download",
            "x-variable-mapping": {
              "from_type": "file",
              "field_path": "id",
              "description": "Extract file ID from file object"
            }
          },
          "return_url_only": {
            "type": "boolean",
            "default": false,
            "description": "Return download URL instead of file content"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "x-semantic-type": "file_attachment",
        "properties": {
          "file_id": { "type": "string", "x-guaranteed": true },
          "file_name": { "type": "string", "x-guaranteed": true },
          "mime_type": { "type": "string" },
          "size": { "type": "integer" },
          "content": { "type": "string", "description": "Base64 encoded content or download URL" },
          "download_url": { "type": "string" },
          "downloaded_at": { "type": "string", "x-guaranteed": true }
        }
      },
      "output_guidance": {
        "success_description": "File downloaded successfully",
        "sample_output": {
          "file_id": "01BYE5RZ6QN3ZWBTUFOFD3GSPGOHDJD36K",
          "file_name": "invoice.pdf",
          "mime_type": "application/pdf",
          "size": 245760,
          "download_url": "https://graph.microsoft.com/...",
          "downloaded_at": "2026-03-13T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your OneDrive connection has expired.",
          "file_not_found": "The specified file was not found.",
          "file_too_large": "File exceeds download size limit."
        }
      },
      "output_dependencies": [
        {
          "when_param": { "return_url_only": true },
          "unpopulated_fields": ["content", "size"],
          "message": "content and size are not populated when return_url_only=true — only download_url is returned"
        }
      ]
    },
    "upload_file": {
      "description": "Upload a file to OneDrive",
      "usage_context": "When user wants to save files to OneDrive",
      "idempotent": false,
      "domain": "storage",
      "capability": "create",
      "input_entity": "file",
      "output_entity": "file",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["file_id", "file_name", "web_url", "size"],
      "required_params": ["file_content", "file_name"],
      "optional_params": ["folder_id", "mime_type", "conflict_behavior"],
      "must_support": ["binary_upload", "conflict_resolution"],
      "parameters": {
        "type": "object",
        "required": ["file_content", "file_name"],
        "properties": {
          "file_content": {
            "type": "string",
            "description": "File content (base64 encoded for binary files, or plain text)",
            "x-variable-mapping": {
              "from_type": "file_attachment",
              "field_path": "content",
              "description": "Extract content from attachment object"
            }
          },
          "file_name": {
            "type": "string",
            "description": "Name for the uploaded file",
            "x-variable-mapping": {
              "from_type": "file_attachment",
              "field_path": "filename",
              "description": "Extract filename from attachment object"
            }
          },
          "folder_id": {
            "type": "string",
            "description": "ID of parent folder (default: root)",
            "x-dynamic-options": {
              "source": "list_folders",
              "description": "Fetches available folders dynamically"
            },
            "x-variable-mapping": {
              "from_type": "folder",
              "field_path": "folder_id",
              "description": "Extract folder ID from folder object"
            }
          },
          "mime_type": {
            "type": "string",
            "description": "MIME type of the file"
          },
          "conflict_behavior": {
            "type": "string",
            "enum": ["rename", "replace", "fail"],
            "default": "rename",
            "description": "What to do if file already exists"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "file_id": { "type": "string", "x-guaranteed": true },
          "file_name": { "type": "string", "x-guaranteed": true },
          "web_url": { "type": "string" },
          "size": { "type": "integer" },
          "uploaded_at": { "type": "string", "x-guaranteed": true }
        }
      },
      "output_guidance": {
        "success_description": "File uploaded successfully",
        "sample_output": {
          "file_id": "01BYE5RZ6QN3ZWBTUFOFD3GSPGOHDJD36K",
          "file_name": "invoice.pdf",
          "web_url": "https://onedrive.live.com/...",
          "size": 245760,
          "uploaded_at": "2026-03-13T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your OneDrive connection has expired.",
          "file_name_invalid": "The file name contains invalid characters.",
          "quota_exceeded": "OneDrive storage quota exceeded."
        }
      }
    },
