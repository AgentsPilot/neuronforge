          "permission_denied": "You don't have permission to update this page. Please request access from the workspace owner.",
          "invalid_data": "The provided properties are invalid. Please check property types and values.",
          "rate_limit": "Too many requests to Notion API. Please wait a moment and try again.",
          "api_error": "Notion API error occurred. Please try again or contact support if the issue persists."
        }
      }
    },
    "query_database": {
      "description": "Query a database with filtering, sorting, and pagination",
      "usage_context": "Use this action to retrieve pages from a database. Supports filtering by property values, sorting, and pagination. Perfect for querying structured data.",
      "idempotent": true,
      "domain": "knowledge",
      "capability": "list",
      "input_entity": "database",
      "output_entity": "page",
      "input_cardinality": "single",
      "output_cardinality": "collection",
      "output_fields": [
        "id",
        "properties",
        "created_time",
        "last_edited_time"
      ],
      "required_params": [
        "database_id"
      ],
      "optional_params": [
        "filter",
        "sorts",
        "page_size"
      ],
      "must_support": [
        "property_filter",
        "multi_sort"
      ],
      "parameters": {
        "type": "object",
        "required": [
          "database_id"
        ],
        "properties": {
          "database_id": {
            "type": "string",
            "description": "The ID of the database to query",
            "x-dynamic-options": {
              "source": "search",
              "description": "Fetches available databases dynamically"
            },
            "x-variable-mapping": {
              "from_type": "database",
              "field_path": "id",
              "description": "Extract database ID from database object"
            }
          },
          "filter": {
            "type": "object",
            "description": "Filter object to query specific pages (e.g., {property: 'Status', select: {equals: 'Active'}})"
