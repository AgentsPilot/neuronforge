          },
          "page_size": {
            "type": "integer",
            "description": "Number of pages to return (max: 100)",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          }
        }
      },
      "rules": {
        "limits": {
          "rate_limit": "3 requests per second",
          "timeout_seconds": 30
        }
      },
      "output_schema": {
        "type": "object",
        "description": "Database query results",
        "properties": {
          "results": {
            "type": "array",
            "description": "Array of pages matching the query",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Page ID"
                },
                "properties": {
                  "type": "object",
                  "description": "Page properties"
                },
                "created_time": {
                  "type": "string",
                  "description": "ISO 8601 timestamp of creation"
                },
                "last_edited_time": {
                  "type": "string",
                  "description": "ISO 8601 timestamp of last edit"
                }
              }
            }
          },
          "has_more": {
            "type": "boolean",
            "description": "Whether more results are available"
          },
          "next_cursor": {
            "type": "string",
            "description": "Cursor for pagination"
          },
          "result_count": {
            "type": "integer",
            "description": "Number of results returned"
          }
        },
        "required": [
          "id",
          "properties"
        ]
      },
      "output_guidance": {
        "success_description": "Retrieved database pages",
        "sample_output": {
          "results": [
            {
              "id": "page123",
              "properties": {
                "Name": {
                  "type": "title",
                  "title": [
                    {
                      "text": {
                        "content": "Task 1"
                      }
                    }
                  ]
                },
                "Status": {
                  "type": "select",
                  "select": {
                    "name": "Active"
                  }
                }
              },
              "created_time": "2024-01-01T00:00:00.000Z",
              "last_edited_time": "2024-01-15T10:00:00.000Z"
            }
          ],
          "has_more": false,
          "result_count": 1
        },
        "common_errors": {
          "auth_failed": "Your Notion connection has expired. Please go to Settings → Connected Apps to reconnect Notion.",
          "not_found": "The specified database was not found. Please check the database ID and try again.",
          "permission_denied": "You don't have permission to access this database. Please request access from the workspace owner.",
          "invalid_filter": "The provided filter is invalid. Please check the filter syntax.",
          "rate_limit": "Too many requests to Notion API. Please wait a moment and try again.",
          "api_error": "Notion API error occurred. Please try again or contact support if the issue persists."
        }
      }
    },
    "get_database": {
      "description": "Get database schema and properties",
      "usage_context": "Use this action to retrieve a database's structure, including all property definitions, types, and options. Essential for understanding database schema before querying or creating pages.",
      "idempotent": true,
      "domain": "knowledge",
      "capability": "get",
      "input_entity": "database",
      "output_entity": "database",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": [
        "id",
        "title",
        "properties",
        "created_time"
      ],
      "required_params": [
        "database_id"
