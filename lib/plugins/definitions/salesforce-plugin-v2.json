{
  "plugin": {
    "name": "salesforce",
    "version": "1.0.0",
    "description": "Manage leads, accounts, contacts, opportunities, and cases in Salesforce CRM",
    "context": "Use for CRM operations: creating leads, managing accounts, tracking opportunities, and organizing sales pipeline. Salesforce is the leading CRM platform for sales and customer relationship management.",
    "icon": "<Cloud className='w-5 h-5 text-blue-600'/>",
    "category": "crm",
    "isPopular": true,
    "auth_config": {
      "auth_type": "oauth2_salesforce",
      "client_id": "${SALESFORCE_CLIENT_ID}",
      "client_secret": "${SALESFORCE_CLIENT_SECRET}",
      "redirect_uri": "${NEXT_PUBLIC_APP_URL}/oauth/callback/salesforce",
      "auth_url": "https://login.salesforce.com/services/oauth2/authorize",
      "token_url": "https://login.salesforce.com/services/oauth2/token",
      "refresh_url": "https://login.salesforce.com/services/oauth2/token",
      "profile_url": "https://login.salesforce.com/services/oauth2/userinfo",
      "required_scopes": [
        "api",
        "refresh_token",
        "full"
      ],
      "token_expiry_seconds": 7200,
      "requires_pkce": true
    }
  },
  "actions": {
    "create_lead": {
      "description": "Create a new lead in Salesforce CRM",
      "usage_context": "When user wants to add new sales leads, capture prospects, or record potential customers",
      "idempotent": false,
      "domain": "crm",
      "capability": "create",
      "input_entity": "lead",
      "output_entity": "lead",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["id", "first_name", "last_name", "email", "company", "status"],
      "required_params": ["last_name", "company"],
      "optional_params": ["first_name", "email", "phone", "status", "lead_source"],
      "must_support": ["custom_fields", "status_tracking"],
      "parameters": {
        "type": "object",
        "required": ["last_name", "company"],
        "properties": {
          "first_name": {
            "type": "string",
            "description": "Lead's first name"
          },
          "last_name": {
            "type": "string",
            "description": "Lead's last name"
          },
          "email": {
            "type": "string",
            "description": "Lead's email address"
          },
          "company": {
            "type": "string",
            "description": "Lead's company name"
          },
          "phone": {
            "type": "string",
            "description": "Lead's phone number"
          },
          "status": {
            "type": "string",
            "enum": ["Open - Not Contacted", "Working - Contacted", "Closed - Converted", "Closed - Not Converted"],
            "default": "Open - Not Contacted",
            "description": "Lead status"
          },
          "lead_source": {
            "type": "string",
            "enum": ["Web", "Phone Inquiry", "Partner Referral", "Purchased List", "Other"],
            "description": "Source of the lead"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique Salesforce Lead ID",
            "x-guaranteed": true
          },
          "first_name": { "type": "string" },
          "last_name": { "type": "string", "x-guaranteed": true },
          "email": { "type": "string" },
          "company": { "type": "string", "x-guaranteed": true },
          "status": { "type": "string", "x-guaranteed": true },
          "created_at": {
            "type": "string",
            "description": "Timestamp when lead was created (ISO 8601)",
            "x-guaranteed": true
          }
        }
      },
      "output_guidance": {
        "success_description": "Lead created successfully",
        "sample_output": {
          "id": "00Q5e00000HgYzBEAV",
          "first_name": "John",
          "last_name": "Doe",
          "email": "john.doe@company.com",
          "company": "Acme Corp",
          "status": "Open - Not Contacted",
          "created_at": "2026-03-17T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your Salesforce connection has expired. Please reconnect in Settings → Connected Apps.",
          "required_field_missing": "Last name and company are required to create a lead.",
          "duplicate_lead": "A lead with this email already exists.",
          "insufficient_permissions": "You don't have permission to create leads in Salesforce."
        }
      }
    },
    "query_leads": {
      "description": "Search and retrieve leads from Salesforce using filters",
      "usage_context": "When user wants to find leads, filter by criteria, or list prospects",
      "idempotent": true,
      "domain": "crm",
      "capability": "search",
      "input_entity": null,
      "output_entity": "lead",
      "input_cardinality": null,
      "output_cardinality": "collection",
      "output_fields": ["id", "first_name", "last_name", "email", "company", "phone", "status"],
      "required_params": [],
      "optional_params": ["email", "company", "status", "created_date", "limit"],
      "must_support": ["full_text_search", "date_filtering", "status_filtering"],
      "parameters": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Filter by email address"
          },
          "company": {
            "type": "string",
            "description": "Filter by company name (partial match supported)"
          },
          "status": {
            "type": "string",
            "enum": ["Open - Not Contacted", "Working - Contacted", "Closed - Converted", "Closed - Not Converted"],
            "description": "Filter by lead status"
          },
          "created_date": {
            "type": "string",
            "description": "Filter by creation date (ISO 8601, e.g., '2026-03-01')"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 200,
            "default": 100,
            "description": "Maximum number of results to return"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "leads": {
            "type": "array",
            "description": "List of matching leads",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "Salesforce Lead ID" },
                "first_name": { "type": "string" },
                "last_name": { "type": "string" },
                "email": { "type": "string" },
                "company": { "type": "string" },
                "phone": { "type": "string" },
                "status": { "type": "string" },
                "created_date": { "type": "string" }
              }
            }
          },
          "lead_count": {
            "type": "integer",
            "description": "Number of leads returned",
            "x-guaranteed": true
          },
          "searched_at": {
            "type": "string",
            "description": "Timestamp when search was performed (ISO 8601)",
            "x-guaranteed": true
          }
        }
      },
      "output_guidance": {
        "success_description": "Retrieved leads from Salesforce",
        "sample_output": {
          "leads": [
            {
              "id": "00Q5e00000HgYzBEAV",
              "first_name": "John",
              "last_name": "Doe",
              "email": "john.doe@company.com",
              "company": "Acme Corp",
              "phone": "+1234567890",
              "status": "Working - Contacted",
              "created_date": "2026-03-15"
            }
          ],
          "lead_count": 1,
          "searched_at": "2026-03-17T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your Salesforce connection has expired. Please reconnect.",
          "insufficient_permissions": "You don't have permission to query leads."
        }
      }
    },
    "update_lead": {
      "description": "Update an existing lead's information",
      "usage_context": "When user wants to modify lead details, update status, or change contact information",
      "idempotent": true,
      "domain": "crm",
      "capability": "update",
      "input_entity": "lead",
      "output_entity": "lead",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["id", "updated_fields", "updated_at"],
      "required_params": ["lead_id"],
      "optional_params": ["first_name", "last_name", "email", "phone", "status", "company"],
      "must_support": ["partial_updates", "status_changes"],
      "parameters": {
        "type": "object",
        "required": ["lead_id"],
        "properties": {
          "lead_id": {
            "type": "string",
            "description": "The ID of the lead to update",
            "x-variable-mapping": {
              "from_type": "lead",
              "field_path": "id",
              "description": "Extract lead ID from lead object"
            }
          },
          "first_name": {
            "type": "string",
            "description": "Updated first name"
          },
          "last_name": {
            "type": "string",
            "description": "Updated last name"
          },
          "email": {
            "type": "string",
            "description": "Updated email address"
          },
          "phone": {
            "type": "string",
            "description": "Updated phone number"
          },
          "status": {
            "type": "string",
            "enum": ["Open - Not Contacted", "Working - Contacted", "Closed - Converted", "Closed - Not Converted"],
            "description": "Updated lead status"
          },
          "company": {
            "type": "string",
            "description": "Updated company name"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Lead ID",
            "x-guaranteed": true
          },
          "success": {
            "type": "boolean",
            "x-guaranteed": true
          },
          "updated_at": {
            "type": "string",
            "description": "Timestamp when lead was updated (ISO 8601)",
            "x-guaranteed": true
          }
        }
      },
      "output_guidance": {
        "success_description": "Lead updated successfully",
        "sample_output": {
          "id": "00Q5e00000HgYzBEAV",
          "success": true,
          "updated_at": "2026-03-17T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your Salesforce connection has expired.",
          "lead_not_found": "The specified lead was not found.",
          "insufficient_permissions": "You don't have permission to update leads."
        }
      }
    },
