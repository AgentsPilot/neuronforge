    "create_opportunity": {
      "description": "Create a new sales opportunity in Salesforce",
      "usage_context": "When user wants to track deals, record potential sales, or manage pipeline",
      "idempotent": false,
      "domain": "crm",
      "capability": "create",
      "input_entity": "opportunity",
      "output_entity": "opportunity",
      "input_cardinality": "single",
      "output_cardinality": "single",
      "output_fields": ["id", "name", "amount", "stage", "close_date", "account_id"],
      "required_params": ["name", "stage", "close_date"],
      "optional_params": ["account_id", "amount", "probability", "description"],
      "must_support": ["stage_tracking", "amount_tracking", "account_association"],
      "parameters": {
        "type": "object",
        "required": ["name", "stage", "close_date"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Opportunity name/title"
          },
          "account_id": {
            "type": "string",
            "description": "Associated Salesforce Account ID",
            "x-variable-mapping": {
              "from_type": "account",
              "field_path": "id",
              "description": "Extract account ID from account object"
            }
          },
          "amount": {
            "type": "number",
            "description": "Opportunity amount (in USD or account currency)"
          },
          "close_date": {
            "type": "string",
            "description": "Expected close date (ISO 8601 date format, e.g., '2026-04-01')"
          },
          "stage": {
            "type": "string",
            "enum": ["Prospecting", "Qualification", "Needs Analysis", "Value Proposition", "Proposal/Price Quote", "Negotiation/Review", "Closed Won", "Closed Lost"],
            "description": "Sales stage of the opportunity"
          },
          "probability": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Probability of closing (0-100%)"
          },
          "description": {
            "type": "string",
            "description": "Opportunity description or notes"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Salesforce Opportunity ID",
            "x-guaranteed": true
          },
          "name": {
            "type": "string",
            "x-guaranteed": true
          },
          "amount": { "type": "number" },
          "stage": {
            "type": "string",
            "x-guaranteed": true
          },
          "close_date": {
            "type": "string",
            "x-guaranteed": true
          },
          "account_id": { "type": "string" },
          "created_at": {
            "type": "string",
            "x-guaranteed": true
          }
        }
      },
      "output_guidance": {
        "success_description": "Opportunity created successfully",
        "sample_output": {
          "id": "0065e00000AbCdEFGH",
          "name": "Q2 Enterprise Deal",
          "amount": 50000,
          "stage": "Qualification",
          "close_date": "2026-06-30",
          "account_id": "0015e00000XyZaBCDE",
          "created_at": "2026-03-17T16:00:00Z"
        },
        "common_errors": {
          "auth_failed": "Your Salesforce connection has expired.",
          "invalid_stage": "The specified stage is not valid.",
          "account_not_found": "The specified account was not found.",
          "insufficient_permissions": "You don't have permission to create opportunities."
        }
