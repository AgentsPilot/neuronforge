{
  "slots": {
    "raw_gantt_rows": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "properties": {
          "range": {
            "type": "string",
            "source": "plugin",
            "description": "The actual range that was read (may differ from requested)",
            "required": true
          },
          "values": {
            "type": "array",
            "source": "plugin",
            "description": "2D array of cell values (rows of cells)",
            "items": {
              "type": "array",
              "source": "plugin",
              "items": {
                "type": "string",
                "source": "plugin"
              }
            },
            "required": true
          },
          "row_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of rows returned",
            "required": true
          },
          "column_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of columns returned"
          },
          "major_dimension": {
            "type": "string",
            "source": "plugin",
            "description": "How data is organized (ROWS or COLUMNS)"
          },
          "retrieved_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when data was retrieved (ISO 8601)"
          }
        }
      },
      "scope": "global",
      "produced_by": "read_gantt_data",
      "consumed_by": [
        "convert_rows_to_objects"
      ]
    },
    "task_objects": {
      "schema": {
        "type": "array",
        "source": "ai_declared",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "task_name": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "finish_date": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "priority": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            }
          }
        }
      },
      "scope": "global",
      "produced_by": "convert_rows_to_objects",
      "consumed_by": [
        "filter_valid_tasks"
      ]
    },
    "valid_tasks": {
