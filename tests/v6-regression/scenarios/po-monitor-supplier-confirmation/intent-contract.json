{
  "version": "intent.v1",
  "goal": "Search Gmail for order emails (subject contains 'Orders', last 7 days), extract purchase order details from all attachments (PDF, images, DOCX, XLSX), build an HTML summary table, send it to configured recipients, and reply in-thread with confirmation to supplier emails extracted from PO attachments.",
  "unit_of_work": {
    "entity": "attachment",
    "parent_entity": "email"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find order emails with subject containing Orders from the last 7 days",
      "default": "subject:Orders newer_than:7d"
    },
    {
      "key": "primary_recipient",
      "type": "string",
      "description": "Primary recipient for the HTML summary email",
      "default": "meiribarak@gmail.com"
    },
    {
      "key": "additional_summary_recipients",
      "type": "string",
      "description": "Semicolon-separated additional recipients for the summary email",
      "default": "eomer3@gmail.com; offir.omer@gmail.com"
    },
    {
      "key": "confirmation_template",
      "type": "string",
      "description": "Template for supplier confirmation message",
      "default": "Confirmed. We received PO {order_ID}. Thank you."
    },
    {
      "key": "missing_field_status",
      "type": "string",
      "description": "Status value to use when required fields are missing or unclear",
      "default": "Needs review"
    }
  ],
  "invariants": [
    "All attachments of supported types (PDF, JPG, PNG, DOCX, XLSX) on each matched email must be processed",
    "Missing or unclear fields must be left blank with status flagged as 'Needs review'",
    "Supplier confirmation must only be sent when a supplier email is successfully extracted from the PO attachment",
    "Summary table columns must be exactly: order date and time, order_ID, Vendor, QTY, cost, amount, status"
  ],
  "required_outcomes": [
    "HTML summary table email sent to all configured recipients",
    "In-thread confirmation replies sent to supplier emails extracted from PO attachments",
    "Rows with missing fields flagged as 'Needs review' in the summary table"
  ],
  "steps": [
    {
      "id": "search_order_emails",
      "kind": "data_source",
      "summary": "Search Gmail for emails with subject containing 'Orders' from the last 7 days, including attachment metadata",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "order_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full",
        "include_attachments": true
      }
    },
    {
      "id": "filter_emails_with_attachments",
      "kind": "transform",
      "summary": "Keep only emails that have at least one attachment",
      "inputs": [
        "order_emails"
      ],
      "output": "emails_with_attachments",
      "transform": {
        "op": "filter",
        "input": "order_emails",
        "description": "Keep only emails that have attachments",
        "where": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "order_emails",
            "field": "attachments"
          },
          "comparator": "exists"
        }
      }
    },
    {
      "id": "flatten_attachments",
      "kind": "transform",
      "summary": "Extract all attachments from emails into a flat list, preserving parent email context (message_id, thread_id, from, subject)",
      "inputs": [
        "emails_with_attachments"
      ],
      "output": "all_attachments",
      "transform": {
        "op": "flatten",
        "input": "emails_with_attachments",
        "description": "Flatten attachments array from each email, carrying parent email fields (id, thread_id, from, subject) into each attachment record",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "filename": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              },
              "attachment_id": {
                "type": "string"
              },
              "message_id": {
                "type": "string"
              },
              "thread_id": {
                "type": "string"
              },
              "from": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              }
            },
            "required": [
              "filename",
              "mimeType",
              "attachment_id",
              "message_id",
              "thread_id",
              "from",
              "subject"
            ]
          }
        }
      }
    },
    {
      "id": "filter_supported_attachments",
      "kind": "transform",
      "summary": "Keep only attachments of supported types: PDF, JPG, PNG, DOCX, XLSX",
      "inputs": [
        "all_attachments"
      ],
      "output": "supported_attachments",
      "transform": {
        "op": "filter",
        "input": "all_attachments",
        "description": "Filter to only PDF, JPG, PNG, DOCX, XLSX attachments by MIME type",
        "where": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "all_attachments",
            "field": "mimeType"
          },
          "comparator": "in",
          "right": {
            "kind": "literal",
            "value": [
              "application/pdf",
              "image/jpeg",
              "image/png",
              "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
            ]
          }
        }
      }
    },
    {
      "id": "process_each_attachment",
      "kind": "loop",
      "summary": "For each supported attachment: download content, extract PO fields and supplier email, build normalized row, and send supplier confirmation if possible",
      "inputs": [
        "supported_attachments"
      ],
      "output": "processed_po_rows",
      "loop": {
        "over": "supported_attachments",
        "item_ref": "attachment_item",
        "unit_of_work": {
          "entity": "attachment"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_po_rows",
          "from_step_output": "final_po_row"
        },
        "do": [
          {
            "id": "download_attachment",
            "kind": "data_source",
            "summary": "Download the attachment content (binary data) from Gmail",
            "uses": [
              {
                "capability": "download",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "attachment_item"
            ],
            "output": "attachment_content",
            "source": {
              "domain": "email",
              "intent": "download"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "message_id"
              },
              "attachment_id": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "attachment_id"
              },
              "filename": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "filename"
              }
            }
          },
          {
            "id": "extract_po_fields",
            "kind": "extract",
            "summary": "Extract purchase order fields (order date/time, order_ID, Vendor, QTY, cost, amount, status) and supplier email from the attachment content",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "inputs": [
              "attachment_content"
            ],
            "output": "extracted_po_data",
            "extract": {
              "input": "attachment_content",
              "fields": [
                {
                  "name": "order_date_and_time",
                  "type": "string",
                  "required": false,
                  "description": "Order date and time from the purchase order"
                },
                {
                  "name": "order_ID",
                  "type": "string",
                  "required": false,
                  "description": "Purchase order ID/number"
                },
                {
                  "name": "Vendor",
                  "type": "string",
                  "required": false,
                  "description": "Vendor or supplier name"
                },
                {
                  "name": "QTY",
                  "type": "number",
                  "required": false,
                  "description": "Quantity ordered"
                },
                {
                  "name": "cost",
                  "type": "currency",
                  "required": false,
                  "description": "Unit cost"
                },
                {
                  "name": "amount",
                  "type": "currency",
                  "required": false,
                  "description": "Total amount"
                },
                {
                  "name": "status",
                  "type": "string",
                  "required": false,
                  "description": "Order status"
                },
                {
                  "name": "supplier_email",
                  "type": "string",
                  "required": false,
                  "description": "Supplier email address extracted from the PO attachment content (not from the email sender)"
                }
              ],
              "content_hints": {
                "file_types": [
                  "pdf",
                  "jpg",
                  "png",
                  "docx",
                  "xlsx"
                ],
                "language": "en"
              }
            }
          },
          {
            "id": "build_po_row",
            "kind": "transform",
            "summary": "Build a normalized PO row combining extracted fields with parent email context (thread_id, message_id), flagging rows with missing fields as 'Needs review'",
            "inputs": [
              "extracted_po_data",
              "attachment_item"
            ],
            "output": "po_row_with_status",
            "transform": {
              "op": "with_fields",
              "input": "extracted_po_data",
              "fields": [
                {
                  "name": "thread_id",
                  "expression": {
                    "kind": "ref",
                    "ref": "attachment_item",
                    "field": "thread_id"
                  }
                },
                {
                  "name": "source_message_id",
                  "expression": {
                    "kind": "ref",
                    "ref": "attachment_item",
                    "field": "message_id"
                  }
                },
                {
                  "name": "has_all_required_fields",
                  "expression": {
                    "kind": "all_not_null",
                    "refs": [
                      "order_date_and_time",
                      "order_ID",
                      "Vendor",
                      "QTY",
                      "cost",
                      "amount",
                      "status"
                    ]
                  }
                },
                {
                  "name": "has_supplier_email",
                  "expression": {
                    "kind": "null_check",
                    "invert": true,
                    "value": {
                      "kind": "ref",
                      "ref": "extracted_po_data",
                      "field": "supplier_email"
                    }
                  }
                },
                {
                  "name": "display_status",
                  "expression": {
                    "kind": "if",
                    "condition": {
                      "op": "test",
                      "left": {
                        "kind": "computed",
                        "op": "all_not_null",
                        "args": []
                      },
                      "comparator": "eq",
                      "right": {
                        "kind": "literal",
                        "value": true
                      }
                    },
                    "then": {
                      "kind": "ref",
                      "ref": "extracted_po_data",
                      "field": "status"
                    },
                    "else": {
                      "kind": "literal",
                      "value": "Needs review"
                    }
                  }
                }
              ],
              "output_schema": {
                "type": "object",
                "properties": {
                  "order_date_and_time": {
                    "type": "string"
                  },
                  "order_ID": {
                    "type": "string"
                  },
                  "Vendor": {
                    "type": "string"
                  },
                  "QTY": {
                    "type": "number"
                  },
                  "cost": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "supplier_email": {
                    "type": "string"
                  },
                  "thread_id": {
                    "type": "string"
                  },
                  "source_message_id": {
                    "type": "string"
                  },
                  "has_all_required_fields": {
                    "type": "boolean"
                  },
                  "has_supplier_email": {
                    "type": "boolean"
                  },
                  "display_status": {
                    "type": "string"
                  }
                }
              }
            }
          },
          {
            "id": "map_final_row",
            "kind": "transform",
            "summary": "Map PO row to final output shape preserving all needed fields",
            "inputs": [
              "po_row_with_status"
            ],
            "output": "final_po_row",
            "transform": {
              "op": "map",
              "input": "po_row_with_status",
              "mapping": [
                {
                  "to": "order_date_and_time",
                  "from": "order_date_and_time"
                },
                {
                  "to": "order_ID",
                  "from": "order_ID"
                },
                {
                  "to": "Vendor",
                  "from": "Vendor"
                },
                {
                  "to": "QTY",
                  "from": "QTY"
                },
                {
                  "to": "cost",
                  "from": "cost"
                },
                {
                  "to": "amount",
                  "from": "amount"
                },
                {
                  "to": "status",
                  "from": "display_status"
                },
                {
                  "to": "supplier_email",
                  "from": "supplier_email"
                },
                {
                  "to": "thread_id",
                  "from": "thread_id"
                },
                {
                  "to": "source_message_id",
                  "from": "source_message_id"
                },
                {
                  "to": "has_supplier_email",
                  "from": "has_supplier_email"
                }
              ],
              "output_schema": {
                "type": "object",
                "properties": {
                  "order_date_and_time": {
                    "type": "string"
                  },
                  "order_ID": {
                    "type": "string"
                  },
                  "Vendor": {
                    "type": "string"
                  },
                  "QTY": {
                    "type": "number"
                  },
                  "cost": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "supplier_email": {
                    "type": "string"
                  },
                  "thread_id": {
                    "type": "string"
                  },
                  "source_message_id": {
                    "type": "string"
                  },
                  "has_supplier_email": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          {
            "id": "check_supplier_email_available",
            "kind": "decide",
            "summary": "If supplier email was extracted from the PO attachment, send an in-thread confirmation reply",
            "inputs": [
              "final_po_row"
            ],
            "decide": {
              "condition": {
                "op": "test",
                "left": {
                  "kind": "ref",
                  "ref": "final_po_row",
                  "field": "has_supplier_email"
                },
                "comparator": "eq",
                "right": {
                  "kind": "literal",
                  "value": true
                }
              },
              "then": [
                {
                  "id": "send_supplier_confirmation",
                  "kind": "notify",
                  "summary": "Reply in the same email thread with a short acknowledgement confirmation to the supplier email extracted from the PO",
                  "inputs": [
                    "final_po_row"
                  ],
                  "uses": [
                    {
                      "capability": "send_message",
                      "domain": "email",
                      "preferences": {
                        "provider_family": "google"
                      }
                    }
                  ],
                  "notify": {
                    "channel": "email",
                    "recipients": {
                      "to": [
                        {
                          "kind": "ref",
                          "ref": "final_po_row",
                          "field": "supplier_email"
                        }
                      ]
                    },
                    "content": {
                      "subject": {
                        "kind": "computed",
                        "op": "concat",
                        "args": [
                          {
                            "kind": "literal",
                            "value": "Re: PO "
                          },
                          {
                            "kind": "ref",
                            "ref": "final_po_row",
                            "field": "order_ID"
                          },
                          {
                            "kind": "literal",
                            "value": " - Confirmation"
                          }
                        ]
                      },
                      "body": {
                        "kind": "computed",
                        "op": "concat",
                        "args": [
                          {
                            "kind": "literal",
                            "value": "Confirmed. We received PO "
                          },
                          {
                            "kind": "ref",
                            "ref": "final_po_row",
                            "field": "order_ID"
                          },
                          {
                            "kind": "literal",
                            "value": ". Thank you."
                          }
                        ]
                      },
                      "format": "text"
                    },
                    "options": {
                      "reply_to_thread": true,
                      "thread_id": {
                        "kind": "ref",
                        "ref": "final_po_row",
                        "field": "thread_id"
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "generate_html_summary",
      "kind": "generate",
      "summary": "Generate a professional HTML summary table with all PO rows, columns: order date and time, order_ID, Vendor, QTY, cost, amount, status",
      "inputs": [
        "processed_po_rows"
      ],
      "output": "html_summary_email",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "processed_po_rows",
        "format": "html",
        "instruction": "Create a professional HTML email body containing a summary table of all purchase order rows. The table must have exactly these columns: 'Order Date & Time', 'Order ID', 'Vendor', 'QTY', 'Cost', 'Amount', 'Status'. Use an HTML <table> with proper <thead> and <tbody>. Style with borders, header row with a dark background and white text, alternating row colors, and padding for readability. Rows where status is 'Needs review' should be highlighted with a light yellow/orange background. Include a title 'Purchase Order Summary' above the table and a footer with the date the report was generated. Each row corresponds to one processed PO attachment from the input array. Use the fields: order_date_and_time, order_ID, Vendor, QTY, cost, amount, status.",
        "reason": "Free-form HTML email body composition with styled table, conditional row highlighting, and professional formatting — requires semantic content generation, not a deterministic template",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line for the summary email"
          },
          {
            "name": "body",
            "type": "string",
            "description": "Full HTML email body containing the styled summary table"
          }
        ]
      }
    },
    {
      "id": "send_summary_to_primary",
      "kind": "notify",
      "summary": "Send the HTML summary table as a new email to the primary recipient",
      "inputs": [
        "html_summary_email"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "primary_recipient"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "body"
          },
          "format": "html"
        }
      }
    },
    {
      "id": "send_summary_to_additional_recipient_1",
      "kind": "notify",
      "summary": "Send the HTML summary table as a new email to eomer3@gmail.com",
      "inputs": [
        "html_summary_email"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "literal",
              "value": "eomer3@gmail.com"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "body"
          },
          "format": "html"
        }
      }
    },
    {
      "id": "send_summary_to_additional_recipient_2",
      "kind": "notify",
      "summary": "Send the HTML summary table as a new email to offir.omer@gmail.com",
      "inputs": [
        "html_summary_email"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "literal",
              "value": "offir.omer@gmail.com"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "html_summary_email",
            "field": "body"
          },
          "format": "html"
        }
      }
    }
  ],
  "confidence": 0.88,
  "meta": {
    "notes": [
      "Supplier email is extracted from PO attachment content, not from the email sender field",
      "Confirmation replies are only sent when supplier_email is successfully extracted",
      "All supported attachment types (PDF, JPG, PNG, DOCX, XLSX) are processed per email",
      "Missing fields result in blank values with status set to 'Needs review'",
      "The document-extractor plugin is used for structured field extraction from file attachments"
    ]
  }
}