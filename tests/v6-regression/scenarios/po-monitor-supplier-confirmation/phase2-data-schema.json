{
  "slots": {
    "order_emails": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "description": "Search results with email details",
        "properties": {
          "emails": {
            "type": "array",
            "source": "plugin",
            "description": "Array of matching emails",
            "items": {
              "type": "object",
              "source": "plugin",
              "semantic_type": "email_message",
              "properties": {
                "id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Gmail message ID"
                },
                "thread_id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Gmail thread ID"
                },
                "subject": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Email subject"
                },
                "from": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Sender address"
                },
                "to": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Recipient addresses"
                },
                "date": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Email date"
                },
                "snippet": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Email preview snippet (first ~200 chars of email body - USE THIS for content matching/filtering)"
                },
                "labels": {
                  "type": "array",
                  "source": "plugin",
                  "description": "Gmail labels",
                  "items": {
                    "type": "string",
                    "source": "plugin"
                  }
                },
                "body": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Email body text (NOTE: Usually empty in search results - use 'snippet' field instead for email content)"
                },
                "attachments": {
                  "type": "array",
                  "source": "plugin",
                  "description": "Attachment metadata (if include_attachments=true). Each item contains: filename, mimeType, size, attachment_id (use with get_email_attachment), message_id (email ID)",
                  "items": {
                    "type": "object",
                    "source": "plugin",
                    "semantic_type": "file_attachment",
                    "properties": {
                      "filename": {
                        "type": "string",
                        "source": "plugin",
                        "description": "Attachment filename"
                      },
                      "mimeType": {
                        "type": "string",
                        "source": "plugin",
                        "description": "MIME type (application/pdf, image/png, etc.)"
                      },
                      "size": {
                        "type": "number",
                        "source": "plugin",
                        "description": "File size in bytes"
                      },
                      "attachment_id": {
                        "type": "string",
                        "source": "plugin",
                        "description": "Attachment ID (required for get_email_attachment action)"
                      },
                      "message_id": {
                        "type": "string",
                        "source": "plugin",
                        "description": "Email message ID (required for get_email_attachment action)"
                      }
                    }
                  }
                }
              }
            }
          },
          "total_found": {
            "type": "number",
            "source": "plugin",
            "description": "Number of emails returned"
          },
          "total_available": {
            "type": "number",
            "source": "plugin",
            "description": "Estimated total matching emails"
          },
          "search_query": {
            "type": "string",
            "source": "plugin",
            "description": "The search query that was executed"
          },
          "searched_at": {
            "type": "string",
            "source": "plugin",
            "description": "ISO 8601 timestamp of search"
          }
        }
      },
      "scope": "global",
      "produced_by": "search_order_emails",
      "consumed_by": [
        "filter_emails_with_attachments"
      ]
    },
