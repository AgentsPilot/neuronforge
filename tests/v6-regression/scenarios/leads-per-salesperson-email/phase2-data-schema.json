{
  "slots": {
    "raw_sheet_data": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "properties": {
          "range": {
            "type": "string",
            "source": "plugin",
            "description": "The actual range that was read (may differ from requested)",
            "required": true
          },
          "values": {
            "type": "array",
            "source": "plugin",
            "description": "2D array of cell values (rows of cells)",
            "items": {
              "type": "array",
              "source": "plugin",
              "items": {
                "type": "string",
                "source": "plugin"
              }
            },
            "required": true
          },
          "row_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of rows returned",
            "required": true
          },
          "column_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of columns returned"
          },
          "major_dimension": {
            "type": "string",
            "source": "plugin",
            "description": "How data is organized (ROWS or COLUMNS)"
          },
          "retrieved_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when data was retrieved (ISO 8601)"
          }
        }
      },
      "scope": "global",
      "produced_by": "read_leads_sheet",
      "consumed_by": [
        "parse_rows_with_headers"
      ]
    },
    "all_leads": {
      "schema": {
        "type": "array",
        "source": "ai_declared",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "date": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "lead_name": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "company": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "email": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "phone": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "stage": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "notes": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "sales_person": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            }
          }
        }
      },
      "scope": "global",
      "produced_by": "parse_rows_with_headers",
      "consumed_by": [
        "filter_high_qualified"
      ]
    },
    "qualified_leads": {
      "schema": {
        "type": "array",
        "source": "inferred",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "date": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "lead_name": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "company": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "email": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "phone": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "stage": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "notes": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "sales_person": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            }
          }
        }
