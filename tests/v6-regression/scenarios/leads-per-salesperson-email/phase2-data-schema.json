            "required": true
          },
          "recipient_count": {
            "type": "number",
            "source": "plugin",
            "description": "Total number of recipients (to + cc + bcc)"
          },
          "recipients": {
            "type": "object",
            "source": "plugin",
            "description": "Recipient addresses",
            "properties": {
              "to": {
                "type": "array",
                "source": "plugin",
                "items": {
                  "type": "string",
