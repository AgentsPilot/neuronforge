    "qualified_count": {
      "schema": {
        "type": "number",
        "description": "Count of qualified_count",
        "source": "inferred"
      },
      "scope": "global",
      "produced_by": "count_qualified",
      "consumed_by": [
        "decide_has_leads"
      ]
    },
    "qualified_metrics": {
      "schema": {
        "type": "number",
        "description": "Count of qualified_count",
        "source": "inferred"
      },
      "scope": "global",
      "produced_by": "count_qualified"
    },
    "user_email_body": {
      "schema": {
        "type": "object",
        "properties": {
          "html_body": {
            "type": "string",
            "source": "ai_declared",
            "description": "Complete HTML email body with styled leads table"
          }
        },
        "source": "ai_declared"
      },
      "scope": "loop",
      "produced_by": "generate_user_summary_email",
      "consumed_by": [
        "send_user_summary_email"
      ]
    },
    "salesperson_groups": {
      "schema": {
        "type": "array",
        "source": "ai_declared",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "key": {
              "type": "string",
              "source": "ai_declared",
              "description": "The sales_person value (name or email) that identifies this group",
              "required": true
            },
            "items": {
              "type": "array",
              "source": "ai_declared",
              "description": "Array of leads assigned to this salesperson",
              "items": {
                "type": "object",
                "source": "ai_declared",
                "properties": {
                  "date": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "lead_name": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "company": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "email": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "phone": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "stage": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "notes": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "sales_person": {
                    "type": "string",
                    "source": "ai_declared"
                  }
                }
              },
              "required": true
            }
          }
        }
      },
      "scope": "loop",
      "produced_by": "group_by_salesperson",
      "consumed_by": [
        "send_per_salesperson_emails"
      ]
    },
    "sp_group": {
      "schema": {
        "type": "object",
        "source": "inferred",
        "properties": {
          "key": {
            "type": "string",
            "source": "ai_declared",
            "description": "The sales_person value (name or email) that identifies this group",
            "required": true
          },
          "items": {
            "type": "array",
            "source": "ai_declared",
            "description": "Array of leads assigned to this salesperson",
            "items": {
              "type": "object",
              "source": "ai_declared",
              "properties": {
                "date": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "lead_name": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "company": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "email": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "phone": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "stage": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "notes": {
                  "type": "string",
                  "source": "ai_declared"
                },
                "sales_person": {
                  "type": "string",
                  "source": "ai_declared"
                }
              }
            },
            "required": true
          }
        }
      },
      "scope": "loop",
      "produced_by": "send_per_salesperson_emails",
      "consumed_by": [
        "generate_sp_email_body",
        "send_sp_email"
      ]
    },
    "salesperson_email_results": {
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "source": "plugin",
          "description": "Confirmation of sent email with identifiers",
          "properties": {
            "message_id": {
              "type": "string",
              "source": "plugin",
              "description": "Gmail message ID",
              "required": true
            },
            "thread_id": {
              "type": "string",
              "source": "plugin",
              "description": "Gmail thread ID",
              "required": true
            },
            "sent_at": {
              "type": "string",
              "source": "plugin",
              "description": "ISO 8601 timestamp when email was sent",
              "required": true
            },
            "recipient_count": {
              "type": "number",
              "source": "plugin",
              "description": "Total number of recipients (to + cc + bcc)"
            },
            "recipients": {
              "type": "object",
              "source": "plugin",
              "description": "Recipient addresses",
              "properties": {
                "to": {
                  "type": "array",
                  "source": "plugin",
                  "items": {
                    "type": "string",
                    "source": "plugin"
                  }
                },
                "cc": {
                  "type": "array",
                  "source": "plugin",
                  "items": {
                    "type": "string",
                    "source": "plugin"
                  }
                },
                "bcc": {
                  "type": "array",
                  "source": "plugin",
                  "items": {
                    "type": "string",
                    "source": "plugin"
                  }
                }
              }
            },
            "subject": {
              "type": "string",
              "source": "plugin",
              "description": "Email subject line"
            }
          }
        },
        "source": "inferred"
      },
      "scope": "global",
      "produced_by": "send_per_salesperson_emails"
    },
    "sp_email_body": {
      "schema": {
        "type": "object",
        "properties": {
          "html_body": {
            "type": "string",
            "source": "ai_declared",
            "description": "Complete HTML email body with styled leads table for this salesperson"
          },
          "recipient_identifier": {
            "type": "string",
            "source": "ai_declared",
            "description": "The salesperson identifier (name or email) extracted from the group key"
          }
        },
        "source": "ai_declared"
      },
      "scope": "loop",
      "produced_by": "generate_sp_email_body",
      "consumed_by": [
        "send_sp_email"
      ]
    },
    "sp_email_sent": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "description": "Confirmation of sent email with identifiers",
        "properties": {
          "message_id": {
            "type": "string",
            "source": "plugin",
            "description": "Gmail message ID",
            "required": true
          },
          "thread_id": {
            "type": "string",
            "source": "plugin",
