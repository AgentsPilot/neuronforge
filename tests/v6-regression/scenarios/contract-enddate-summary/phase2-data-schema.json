    "contracts_folder_results": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "properties": {
          "files": {
            "type": "array",
            "source": "plugin",
            "description": "List of matching files and folders",
            "items": {
              "type": "object",
              "source": "plugin",
              "semantic_type": "file_attachment",
              "properties": {
                "id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Unique file ID"
                },
                "name": {
                  "type": "string",
                  "source": "plugin",
                  "description": "File or folder name"
                },
                "mimeType": {
                  "type": "string",
                  "source": "plugin",
                  "description": "MIME type of the file"
                },
                "size": {
                  "type": "string",
                  "source": "plugin",
                  "description": "File size in bytes"
                },
                "createdTime": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Creation timestamp (ISO 8601)"
                },
                "modifiedTime": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Last modification timestamp (ISO 8601)"
                },
                "webViewLink": {
                  "type": "string",
                  "source": "plugin",
                  "description": "URL to view the file"
                },
                "shared": {
                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is shared"
                },
                "starred": {
                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is starred"
                }
              }
            }
          },
          "file_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of files found"
          },
          "search_query": {
            "type": "string",
            "source": "plugin",
            "description": "The search query that was executed"
          },
          "next_page_token": {
            "type": "string",
            "source": "plugin",
            "description": "Token for fetching next page of results"
          },
          "has_more": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether more results are available"
          },
          "searched_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when search was performed (ISO 8601)"
          },
          "message": {
            "type": "string",
            "source": "plugin",
            "description": "Status message if no results found"
          }
        }
      },
      "scope": "global",
      "produced_by": "find_contracts_folder",
      "consumed_by": [
        "list_docs_in_folder"
      ]
    },
