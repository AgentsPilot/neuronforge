    "params": {
      "folder_id": "{{contracts_folder_results.files[0].id}}",
      "max_results": 200,
      "file_types": [
        "application/vnd.google-apps.document"
      ]
    },
    "name": "List all Google Docs within the Contracts folder",
    "action": "list_files"
  },
  {
    "step_id": "step3",
    "type": "transform",
    "operation": "filter",
    "input": "{{all_folder_docs.files}}",
    "description": "Filter documents whose title contains at least one of the contract keywords (Contract, Agreement, MSA, SOW, Order Form, Statement of Work)",
    "config": {
      "type": "filter",
      "input": "all_folder_docs.files",
      "custom_code": "Keep only documents whose name contains at least one contract keyword",
      "condition": {
        "operator": "contains_any",
        "value": [
          "Contract",
          "Agreement",
          "MSA",
          "SOW",
          "Order Form",
          "Statement of Work"
        ],
        "field": "item.name",
        "conditionType": "simple"
      }
    },
    "output_variable": "candidate_docs",
    "output_schema": {
      "type": "array",
      "source": "inferred",
      "description": "List of files and folders",
      "items": {
        "type": "object",
        "source": "plugin",
        "semantic_type": "file_attachment",
        "properties": {
          "id": {
            "type": "string",
            "source": "plugin",
            "description": "Unique file ID"
          },
          "name": {
            "type": "string",
            "source": "plugin",
            "description": "File or folder name"
          },
          "mimeType": {
            "type": "string",
            "source": "plugin",
            "description": "MIME type of the file"
          },
          "size": {
            "type": "string",
            "source": "plugin",
            "description": "File size in bytes"
          },
          "createdTime": {
            "type": "string",
            "source": "plugin",
            "description": "Creation timestamp (ISO 8601)"
          },
          "modifiedTime": {
            "type": "string",
            "source": "plugin",
            "description": "Last modification timestamp (ISO 8601)"
          },
          "webViewLink": {
            "type": "string",
            "source": "plugin",
            "description": "URL to view the file"
          },
          "shared": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is shared"
          },
          "starred": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is starred"
          }
        }
      }
    },
    "id": "step3",
    "_on_empty": "throw",
    "name": "Filter documents whose title contains at least one of the contract keywords (Contract, Agreement, MSA, SOW, Order Form, Statement of Work)"
  },
  {
    "step_id": "step4",
    "type": "scatter_gather",
    "description": "Loop over candidate_docs",
    "scatter": {
      "input": "{{candidate_docs}}",
      "steps": [
        {
          "step_id": "step5",
          "type": "action",
          "description": "Read the full text content of the Google Doc",
          "plugin": "google-drive",
          "output_variable": "doc_content",
          "output_schema": {
            "type": "object",
            "source": "plugin",
            "properties": {
              "file_id": {
                "type": "string",
                "source": "plugin",
                "description": "ID of the file that was read"
              },
              "file_name": {
                "type": "string",
                "source": "plugin",
                "description": "Name of the file"
              },
              "file_size": {
                "type": "string",
                "source": "plugin",
                "description": "Human-readable file size (e.g., '1.5 MB')"
              },
              "mime_type": {
                "type": "string",
                "source": "plugin",
                "description": "MIME type of the file"
              },
              "content": {
                "type": "string",
                "source": "plugin",
                "description": "Text content extracted from the file"
              },
              "content_length": {
                "type": "number",
                "source": "plugin",
