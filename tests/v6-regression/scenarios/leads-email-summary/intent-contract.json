{
  "version": "intent.v1",
  "goal": "Read leads from Google Sheets, filter for Stage = 4, generate HTML summary table, and email to recipients",
  "unit_of_work": {
    "entity": "lead",
    "parent_entity": "spreadsheet"
  },
  "config": [
    {
      "key": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID",
      "default": "1RHLbBXzrKv24gNgp7a4Lr7RlMIrP9fjacfGWjhPAbOE"
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Name of the sheet tab containing leads",
      "default": "Leads Tab"
    },
    {
      "key": "stage_threshold",
      "type": "number",
      "description": "Stage value to filter for (qualification rule)",
      "default": 4
    },
    {
      "key": "email_recipients",
      "type": "json",
      "description": "List of email recipients",
      "default": [
        "meiribarak@gmail.com",
        "eomer3@gmail.com",
        "offir.omer@gmail.com"
      ]
    },
    {
      "key": "email_subject",
      "type": "string",
      "description": "Email subject line",
      "default": "High-qualified leads (Stage = 4)"
    }
  ],
  "required_outcomes": [
    "Leads with Stage = 4 are identified",
    "HTML table is generated with correct columns",
    "Email is sent to all recipients"
  ],
  "steps": [
    {
      "id": "read_leads_data",
      "kind": "data_source",
      "summary": "Read all lead rows from Google Sheets tab",
      "uses": [
        {
          "capability": "get",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "raw_leads",
      "source": {
        "domain": "table",
        "intent": "read_range"
      },
      "payload": {
        "spreadsheet_id": {
          "kind": "config",
          "key": "spreadsheet_id"
        },
        "range": {
          "kind": "computed",
          "op": "concat",
          "args": [
            {
              "kind": "config",
              "key": "sheet_tab_name"
            },
            {
              "kind": "literal",
              "value": "!A:H"
            }
          ]
        }
      }
    },
    {
      "id": "filter_qualified_leads",
      "kind": "transform",
      "summary": "Filter leads where Stage = 4",
      "inputs": [
        "raw_leads"
      ],
      "output": "qualified_leads",
      "transform": {
        "op": "filter",
        "input": "raw_leads",
        "description": "Keep only leads where Stage column equals 4",
        "where": {
          "op": "and",
          "conditions": [
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "raw_leads",
                "field": "Stage"
              },
              "comparator": "eq",
              "right": {
                "kind": "config",
                "key": "stage_threshold"
              }
            },
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "raw_leads",
                "field": "Stage"
              },
              "comparator": "exists"
            }
          ]
        },
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Date": {
                "type": "string"
              },
              "Lead Name": {
                "type": "string"
              },
              "Company": {
                "type": "string"
              },
              "Email": {
                "type": "string"
              },
              "Phone": {
                "type": "string"
              },
              "Stage": {
                "type": "number"
              },
              "Notes": {
                "type": "string"
              },
              "Sales Person": {
                "type": "string"
              }
            },
            "required": [
              "Date",
              "Lead Name",
              "Company",
              "Email",
              "Phone",
              "Stage",
              "Notes",
              "Sales Person"
            ]
          }
        }
      }
    },
    {
      "id": "calculate_lead_count",
      "kind": "aggregate",
      "summary": "Count qualified leads to determine if any exist",
      "inputs": [
        "qualified_leads"
      ],
      "output": "lead_metrics",
      "aggregate": {
        "input": "qualified_leads",
        "outputs": [
          {
            "name": "total_qualified_count",
            "type": "count"
          }
        ]
      }
    },
    {
      "id": "check_if_leads_exist",
      "kind": "decide",
      "summary": "Branch based on whether qualified leads exist",
      "inputs": [
        "total_qualified_count"
      ],
      "decide": {
        "condition": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "total_qualified_count"
          },
          "comparator": "gt",
          "right": {
            "kind": "literal",
            "value": 0
          }
        },
        "then": [
          {
            "id": "generate_html_table",
            "kind": "generate",
            "summary": "Generate HTML table with qualified leads",
            "inputs": [
              "qualified_leads",
              "total_qualified_count"
            ],
            "output": "email_content",
            "uses": [
              {
                "capability": "generate",
                "domain": "internal"
              }
            ],
            "generate": {
              "input": "qualified_leads",
              "format": "html",
              "instruction": "Create a professional HTML email body with an HTML table displaying all qualified leads. Include a header row with columns: Date, Lead Name, Company, Email, Phone, Stage, Notes, Sales Person. Style the table with borders, header background color, and proper padding. Include a brief introduction stating the number of high-qualified (Stage = 4) leads found.",
              "outputs": [
                {
                  "name": "html_body",
                  "type": "string",
                  "description": "Complete HTML email body with styled table"
                }
              ]
            }
          },
          {
            "id": "send_leads_email",
            "kind": "notify",
            "summary": "Send email with qualified leads table",
            "inputs": [
              "email_content"
            ],
            "uses": [
              {
                "capability": "send_message",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "notify": {
              "channel": "email",
              "recipients": {
                "to": [
                  {
                    "kind": "config",
                    "key": "email_recipients"
                  }
                ]
              },
              "content": {
                "subject": {
                  "kind": "config",
                  "key": "email_subject"
                },
                "body": {
                  "kind": "ref",
                  "ref": "email_content",
                  "field": "html_body"
                },
                "format": "html"
              }
            }
          }
        ],
        "else": [
          {
            "id": "generate_no_results_message",
            "kind": "generate",
            "summary": "Generate email body stating no qualified leads found",
            "output": "no_results_content",
            "uses": [
              {
                "capability": "generate",
                "domain": "internal"
              }
            ],
            "generate": {
              "format": "html",
              "instruction": "Create a professional HTML email body stating that no high-qualified (Stage = 4) leads were found in the current data. Keep the message brief and professional.",
              "outputs": [
                {
                  "name": "html_body",
                  "type": "string",
                  "description": "HTML email body for no results case"
                }
              ]
            }
          },
          {
            "id": "send_no_results_email",
            "kind": "notify",
            "summary": "Send email stating no qualified leads found",
            "inputs": [
              "no_results_content"
            ],
            "uses": [
              {
                "capability": "send_message",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "notify": {
              "channel": "email",
              "recipients": {
                "to": [
                  {
                    "kind": "config",
                    "key": "email_recipients"
                  }
                ]
              },
              "content": {
                "subject": {
                  "kind": "config",
                  "key": "email_subject"
                },
                "body": {
                  "kind": "ref",
                  "ref": "no_results_content",
                  "field": "html_body"
                },
                "format": "html"
              }
            }
          }
        ]
      }
    }
  ],
  "confidence": 0.95
}