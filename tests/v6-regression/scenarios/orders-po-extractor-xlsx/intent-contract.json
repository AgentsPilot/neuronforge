{
  "version": "intent.v1",
  "goal": "Search Gmail for emails with 'Orders' in subject from last 30 days, extract purchase order line items from attachments, group by Vendor, generate one XLSX per Vendor, email each XLSX to user, then send a final confirmation email.",
  "unit_of_work": {
    "entity": "attachment",
    "parent_entity": "email"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find order emails",
      "default": "subject:Orders newer_than:30d"
    },
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send XLSX summaries to",
      "default": "meiribarak@gmail.com"
    },
    {
      "key": "required_fields",
      "type": "json",
      "description": "Fields required for Complete status",
      "default": [
        "Order Date/Time",
        "Order_ID",
        "Vendor",
        "QTY",
        "Cost",
        "Amount"
      ]
    }
  ],
  "invariants": [
    {
      "description": "Each output row represents exactly one purchase order line item"
    },
    {
      "description": "Status is 'Complete' only when all required fields are present; otherwise 'Needs review' with missing-field note"
    },
    {
      "description": "Only purchase-order attachments are processed; non-PO attachments are ignored"
    },
    {
      "description": "One XLSX and one email per unique Vendor"
    }
  ],
  "required_outcomes": [
    "One email per Vendor sent to recipient with XLSX attachment containing that Vendor's line items",
    "Final confirmation email sent with total Vendor count and total line-item row count"
  ],
  "steps": [
    {
      "id": "search_order_emails",
      "kind": "data_source",
      "summary": "Search Gmail for emails with 'Orders' in subject from last 30 days, including attachment metadata",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "order_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full",
        "include_attachments": true
      }
    },
    {
      "id": "flatten_attachments",
      "kind": "transform",
      "summary": "Extract all attachments from all emails into a flat list, preserving parent email metadata (message_id, subject, from, date)",
      "inputs": [
        "order_emails"
      ],
      "output": "all_attachments",
      "transform": {
        "op": "flatten",
        "input": "order_emails",
        "description": "Flatten attachments array from each email, carrying forward parent email fields (id, subject, from, date) onto each attachment record",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "message_id": {
                "type": "string"
              },
              "email_subject": {
                "type": "string"
              },
              "email_from": {
                "type": "string"
              },
              "email_date": {
                "type": "string"
              },
              "filename": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              },
              "attachment_id": {
                "type": "string"
              }
            },
            "required": [
              "message_id",
              "filename",
              "attachment_id"
            ]
          }
        }
      }
    },
    {
      "id": "process_each_attachment",
      "kind": "loop",
      "summary": "For each attachment: download content, classify if it is a purchase order, and if so extract line items with required fields and status",
      "inputs": [
        "all_attachments"
      ],
      "output": "all_extracted_line_items",
      "loop": {
        "over": "all_attachments",
        "item_ref": "attachment_item",
        "unit_of_work": {
          "entity": "attachment"
        },
        "collect": {
          "enabled": true,
          "collect_as": "all_extracted_line_items",
          "from_step_output": "attachment_line_items"
        },
        "do": [
          {
            "id": "download_attachment",
            "kind": "data_source",
            "summary": "Download the attachment content (binary data) from Gmail",
            "uses": [
              {
                "capability": "download",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "attachment_item"
            ],
            "output": "attachment_content",
            "source": {
              "domain": "email",
              "intent": "download"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "message_id"
              },
              "attachment_id": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "attachment_id"
              },
              "filename": {
                "kind": "ref",
                "ref": "attachment_item",
                "field": "filename"
              }
            }
          },
          {
            "id": "classify_purchase_order",
            "kind": "classify",
            "summary": "Determine whether this attachment is a purchase order document. Classify based on content analysis of the downloaded file.",
            "inputs": [
              "attachment_content"
            ],
            "output": "po_classification",
            "classify": {
              "input": "attachment_content",
              "labels": [
                "purchase_order",
                "not_purchase_order"
              ],
              "multi_label": false,
              "output_field": "document_type"
            }
          },
          {
            "id": "check_is_purchase_order",
            "kind": "decide",
            "summary": "Only proceed with extraction if the attachment is classified as a purchase order",
            "inputs": [
              "po_classification"
            ],
            "decide": {
              "condition": {
                "op": "test",
                "left": {
                  "kind": "ref",
                  "ref": "po_classification",
                  "field": "document_type"
                },
                "comparator": "eq",
                "right": {
                  "kind": "literal",
                  "value": "purchase_order"
                }
              },
              "then": [
                {
                  "id": "extract_po_line_items",
                  "kind": "extract",
                  "summary": "Extract purchase order line items from the attachment. One row per line item with fields: Order Date/Time, Order_ID, Vendor, QTY, Cost, Amount. Leave fields blank if not confidently extractable.",
                  "inputs": [
                    "attachment_content"
                  ],
                  "output": "raw_line_items",
                  "uses": [
                    {
                      "capability": "extract_structured_data",
                      "domain": "document"
                    }
                  ],
                  "extract": {
                    "input": "attachment_content",
                    "fields": [
                      {
                        "name": "line_items",
                        "type": "array",
                        "required": true,
                        "description": "Array of purchase order line items extracted from the document. One entry per line item.",
                        "items": {
                          "type": "object",
                          "properties": {
                            "Order Date/Time": {
                              "type": "string",
                              "description": "Date and/or time of the order, normalized to consistent format"
                            },
                            "Order_ID": {
                              "type": "string",
                              "description": "Purchase order identifier or number"
                            },
                            "Vendor": {
                              "type": "string",
                              "description": "Vendor or supplier name"
                            },
                            "QTY": {
                              "type": "number",
                              "description": "Quantity ordered"
                            },
                            "Cost": {
                              "type": "number",
                              "description": "Unit cost or price per item"
                            },
                            "Amount": {
                              "type": "number",
                              "description": "Total amount for this line item (QTY * Cost or as stated)"
                            }
                          }
                        }
                      }
                    ],
                    "deterministic": false,
                    "content_hints": {
                      "file_types": [
                        "pdf",
                        "image",
                        "spreadsheet"
                      ],
                      "language": "en"
                    }
                  }
                },
                {
                  "id": "flatten_line_items",
                  "kind": "transform",
                  "summary": "Flatten the extracted line_items array into individual row records",
                  "inputs": [
                    "raw_line_items"
                  ],
                  "output": "flat_line_items",
                  "transform": {
                    "op": "flatten",
                    "input": "raw_line_items",
                    "description": "Extract the line_items array from the extraction result into a flat list of line item objects",
                    "output_schema": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Order Date/Time": {
                            "type": "string"
                          },
                          "Order_ID": {
                            "type": "string"
                          },
                          "Vendor": {
                            "type": "string"
                          },
                          "QTY": {
                            "type": "number"
                          },
                          "Cost": {
                            "type": "number"
                          },
                          "Amount": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                },
                {
                  "id": "add_status_field",
                  "kind": "transform",
                  "summary": "Add Status field: 'Complete' if all required fields present, otherwise 'Needs review: missing <field1>, <field2>'",
                  "inputs": [
                    "flat_line_items"
                  ],
                  "output": "attachment_line_items",
                  "transform": {
                    "op": "with_fields",
                    "input": "flat_line_items",
                    "fields": [
                      {
                        "name": "Status",
                        "expression": {
                          "kind": "if",
                          "condition": {
                            "op": "test",
                            "left": {
                              "kind": "computed",
                              "op": "all_not_null",
                              "args": [
                                "Order Date/Time",
                                "Order_ID",
                                "Vendor",
                                "QTY",
                                "Cost",
                                "Amount"
                              ]
                            },
                            "comparator": "eq",
                            "right": {
                              "kind": "literal",
                              "value": true
                            }
                          },
                          "then": {
                            "kind": "literal",
                            "value": "Complete"
                          },
                          "else": {
                            "kind": "literal",
                            "value": "Needs review"
                          }
                        }
                      }
                    ],
                    "output_schema": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "Order Date/Time": {
                            "type": "string"
                          },
                          "Order_ID": {
                            "type": "string"
                          },
                          "Vendor": {
                            "type": "string"
                          },
                          "QTY": {
                            "type": "number"
                          },
                          "Cost": {
                            "type": "number"
                          },
                          "Amount": {
                            "type": "number"
                          },
                          "Status": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "Status"
                        ]
                      }
                    }
                  }
                }
              ],
              "else": [
                {
                  "id": "skip_non_po",
                  "kind": "transform",
                  "summary": "Return empty array for non-purchase-order attachments so the loop collect produces no rows",
                  "output": "attachment_line_items",
                  "transform": {
                    "op": "filter",
                    "input": "attachment_item",
                    "description": "Return empty result for non-PO attachment",
                    "where": {
                      "op": "test",
                      "left": {
                        "kind": "literal",
                        "value": false
                      },
                      "comparator": "eq",
                      "right": {
                        "kind": "literal",
                        "value": true
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "flatten_collected_line_items",
      "kind": "transform",
      "summary": "Flatten the collected arrays of line items from all attachments into a single flat list of all line-item rows",
      "inputs": [
        "all_extracted_line_items"
      ],
      "output": "all_line_items_flat",
      "transform": {
        "op": "flatten",
        "input": "all_extracted_line_items",
        "description": "Flatten nested arrays from loop collection into a single flat array of line-item rows",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Order Date/Time": {
                "type": "string"
              },
              "Order_ID": {
                "type": "string"
              },
              "Vendor": {
                "type": "string"
              },
              "QTY": {
                "type": "number"
              },
              "Cost": {
                "type": "number"
              },
              "Amount": {
                "type": "number"
              },
              "Status": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "id": "enhance_status_with_missing_notes",
      "kind": "generate",
      "summary": "For rows with Status='Needs review', append a note listing which specific fields are missing or blank (e.g., 'Needs review: missing Vendor, Cost'). Rows with Status='Complete' remain unchanged.",
      "inputs": [
        "all_line_items_flat"
      ],
      "output": "line_items_with_status_notes",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "all_line_items_flat",
        "instruction": "For each row in the input array: if Status is 'Complete', keep it as-is. If Status is 'Needs review', check which of the following fields are null, empty, or blank: 'Order Date/Time', 'Order_ID', 'Vendor', 'QTY', 'Cost', 'Amount'. Update the Status value to 'Needs review: missing <comma-separated list of missing field names>'. Return the full array with all fields preserved and only Status values updated where needed.",
        "reason": "Conditional string composition that inspects multiple fields for null/empty and builds a dynamic comma-separated list of missing field names — this requires per-field null inspection and dynamic string assembly that exceeds with_fields expression vocabulary",
        "outputs": [
          {
            "name": "rows",
            "type": "array",
            "description": "All line-item rows with enhanced Status notes",
            "items": {
              "type": "object",
              "properties": {
                "Order Date/Time": {
                  "type": "string"
                },
                "Order_ID": {
                  "type": "string"
                },
                "Vendor": {
                  "type": "string"
                },
                "QTY": {
                  "type": "number"
                },
                "Cost": {
                  "type": "number"
                },
                "Amount": {
                  "type": "number"
                },
                "Status": {
                  "type": "string"
                }
              }
            }
          }
        ]
      }
    },
    {
      "id": "group_by_vendor",
      "kind": "transform",
      "summary": "Group all line-item rows by Vendor field to create per-vendor groups",
      "inputs": [
        "line_items_with_status_notes"
      ],
      "output": "vendor_groups",
      "transform": {
        "op": "group",
        "input": "line_items_with_status_notes",
        "description": "Group rows by the Vendor field",
        "rules": {
          "group_by": "Vendor"
        },
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "group_key": {
                "type": "string",
                "description": "The Vendor name for this group"
              },
              "items": {
                "type": "array",
                "description": "Line-item rows belonging to this Vendor",
                "items": {
                  "type": "object",
                  "properties": {
                    "Order Date/Time": {
                      "type": "string"
                    },
                    "Order_ID": {
                      "type": "string"
                    },
                    "Vendor": {
                      "type": "string"
                    },
                    "QTY": {
                      "type": "number"
                    },
                    "Cost": {
                      "type": "number"
                    },
                    "Amount": {
                      "type": "number"
                    },
                    "Status": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "required": [
              "group_key",
              "items"
            ]
          }
        }
      }
    },
    {
      "id": "compute_totals",
      "kind": "aggregate",
      "summary": "Calculate total number of vendors and total line-item rows for the final confirmation email",
      "inputs": [
        "vendor_groups",
        "line_items_with_status_notes"
      ],
      "output": "totals_meta",
      "aggregate": {
        "input": "vendor_groups",
        "outputs": [
          {
            "name": "vendor_count",
            "type": "count"
          },
          {
            "name": "total_row_count",
            "type": "count",
            "of": "line_items_with_status_notes"
          }
        ]
      }
    },
    {
      "id": "send_vendor_emails",
      "kind": "loop",
      "summary": "For each Vendor group: generate an XLSX file with that Vendor's line items and send it as an email attachment",
      "inputs": [
        "vendor_groups"
      ],
      "output": "sent_vendor_emails",
      "loop": {
        "over": "vendor_groups",
        "item_ref": "vendor_group",
        "unit_of_work": {
          "entity": "vendor_group"
        },
        "collect": {
          "enabled": true,
          "collect_as": "sent_vendor_emails",
          "from_step_output": "vendor_email_sent"
        },
        "do": [
          {
            "id": "generate_vendor_xlsx",
            "kind": "generate",
            "summary": "Generate an XLSX file for this Vendor containing a header row (Order Date/Time, Order_ID, Vendor, QTY, Cost, Amount, Status) followed by the Vendor's line-item rows",
            "inputs": [
              "vendor_group"
            ],
            "output": "vendor_xlsx",
            "uses": [
              {
                "capability": "generate",
                "domain": "internal"
              }
            ],
            "generate": {
              "input": "vendor_group",
              "instruction": "Create an XLSX file (base64-encoded) for the vendor group. The spreadsheet must have columns in this exact order: Order Date/Time, Order_ID, Vendor, QTY, Cost, Amount, Status. Include a header row with these column names, then one data row per line item from the vendor_group.items array. Normalize date/time values to a consistent format (YYYY-MM-DD HH:MM). Format QTY as integer, Cost and Amount as decimal numbers with 2 decimal places. Return the file as base64-encoded XLSX content and a suggested filename using the vendor name.",
              "reason": "XLSX binary file generation with formatting rules requires AI-driven content assembly — no structured primitive can produce binary spreadsheet files",
              "outputs": [
                {
                  "name": "xlsx_content",
                  "type": "string",
                  "description": "Base64-encoded XLSX file content"
                },
                {
                  "name": "xlsx_filename",
                  "type": "string",
                  "description": "Suggested filename like 'Orders_Summary_VendorName.xlsx'"
                },
                {
                  "name": "vendor_name",
                  "type": "string",
                  "description": "The vendor name for use in email subject"
                }
              ]
            }
          },
          {
            "id": "send_vendor_email",
            "kind": "notify",
            "summary": "Send email to recipient with the Vendor's XLSX attached, subject includes vendor name",
            "inputs": [
              "vendor_xlsx"
            ],
            "output": "vendor_email_sent",
            "uses": [
              {
                "capability": "send_message",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "notify": {
              "channel": "email",
              "recipients": {
                "to": [
                  {
                    "kind": "config",
                    "key": "recipient_email"
                  }
                ]
              },
              "content": {
                "subject": {
                  "kind": "computed",
                  "op": "concat",
                  "args": [
                    {
                      "kind": "literal",
                      "value": "Orders summary – "
                    },
                    {
                      "kind": "ref",
                      "ref": "vendor_xlsx",
                      "field": "vendor_name"
                    }
                  ]
                },
                "body": {
                  "kind": "computed",
                  "op": "concat",
                  "args": [
                    {
                      "kind": "literal",
                      "value": "Please find attached the purchase order line-item summary for "
                    },
                    {
                      "kind": "ref",
                      "ref": "vendor_xlsx",
                      "field": "vendor_name"
                    },
                    {
                      "kind": "literal",
                      "value": "."
                    }
                  ]
                },
                "format": "text"
              },
              "options": {
                "attachment_content": {
                  "kind": "ref",
                  "ref": "vendor_xlsx",
                  "field": "xlsx_content"
                },
                "attachment_filename": {
                  "kind": "ref",
                  "ref": "vendor_xlsx",
                  "field": "xlsx_filename"
                },
                "attachment_mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
              }
            }
          }
        ]
      }
    },
    {
      "id": "generate_confirmation_body",
      "kind": "generate",
      "summary": "Compose the confirmation email body stating how many vendors were processed and how many total line-item rows were extracted",
      "inputs": [
        "vendor_count",
        "total_row_count"
      ],
      "output": "confirmation_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "instruction": "Compose a short, professional confirmation email body. State: 'All purchase order summaries have been sent. Total vendors processed: <vendor_count>. Total line-item rows extracted: <total_row_count>.' Use the actual numeric values from the inputs.",
        "reason": "Natural language email body composition with dynamic value insertion — semantic text generation",
        "outputs": [
          {
            "name": "body",
            "type": "string",
            "description": "Confirmation email body text"
          }
        ]
      }
    },
    {
      "id": "send_confirmation_email",
      "kind": "notify",
      "summary": "Send final confirmation email to recipient summarizing total vendors and rows processed",
      "inputs": [
        "confirmation_content",
        "sent_vendor_emails"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "literal",
            "value": "Orders PO Extraction – Processing Complete"
          },
          "body": {
            "kind": "ref",
            "ref": "confirmation_content",
            "field": "body"
          },
          "format": "text"
        }
      }
    }
  ],
  "confidence": 0.82,
  "meta": {
    "notes": [
      "XLSX generation is handled via AI generate step since no native XLSX plugin is available; the AI produces base64-encoded XLSX content",
      "Purchase order classification uses AI classify step since determining whether an attachment is a PO requires semantic content analysis",
      "Status enhancement with dynamic missing-field notes uses AI generate because it requires inspecting multiple fields for null/empty and building a dynamic comma-separated string — exceeds with_fields expression vocabulary",
      "Attachments are downloaded individually via the email download capability before processing"
    ]
  }
}