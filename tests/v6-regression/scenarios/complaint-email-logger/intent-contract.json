{
  "version": "intent.v1",
  "goal": "Scan Gmail inbox for complaint emails from the last 7 days, deduplicate against existing rows in Google Sheets, and append new complaint emails to the UrgentEmails tab",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "inbox"
  },
  "config": [
    {
      "key": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID for the destination",
      "default": "1RHLbBXzrKv24gNgp7a4Lr7RlMIrP9fjacfGWjhPAbOE"
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Name of the worksheet tab to append complaint emails to",
      "default": "UrgentEmails"
    },
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find candidate complaint emails from the last 7 days",
      "default": "in:inbox newer_than:7d (complaint OR refund OR angry OR \"not working\")"
    },
    {
      "key": "complaint_keywords",
      "type": "json",
      "description": "List of keywords to match against email content (case-insensitive)",
      "default": [
        "complaint",
        "refund",
        "angry",
        "not working"
      ]
    },
    {
      "key": "user_email",
      "type": "string",
      "description": "User's email address",
      "default": "meiribarak@gmail.com"
    }
  ],
  "invariants": [
    {
      "description": "Each complaint email is logged at most once, deduplicated by Gmail message ID"
    },
    {
      "description": "Every matching message is logged independently, even if part of the same thread"
    },
    {
      "description": "Rows are appended in order: sender email, subject, date, full email text, Gmail message link/id"
    }
  ],
  "required_outcomes": [
    "All complaint emails from the last 7 days that are not already in the sheet are appended to the UrgentEmails tab",
    "No duplicate rows are created for emails already present in the sheet",
    "Each appended row contains: sender email, subject, date, full email text, Gmail message link/id"
  ],
  "steps": [
    {
      "id": "search_complaint_emails",
      "kind": "data_source",
      "summary": "Search Gmail inbox for emails from the last 7 days matching complaint keywords",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "candidate_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 100,
        "include_content": "full",
        "include_attachments": false
      }
    },
    {
      "id": "ensure_sheet_tab",
      "kind": "artifact",
      "summary": "Ensure the UrgentEmails tab exists in the destination spreadsheet",
      "uses": [
        {
          "capability": "upsert",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "sheet_tab",
      "artifact": {
        "domain": "table",
        "type": "sheet_tab",
        "strategy": "get_or_create",
        "name_hint": "UrgentEmails",
        "options": {
          "spreadsheet_id": {
            "kind": "config",
            "key": "spreadsheet_id"
          },
          "tab_name": {
            "kind": "config",
            "key": "sheet_tab_name"
          }
        }
      }
    },
    {
      "id": "read_existing_rows",
      "kind": "data_source",
      "summary": "Read existing rows from the UrgentEmails tab to get already-logged Gmail message IDs",
      "uses": [
        {
          "capability": "get",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "inputs": [
        "sheet_tab"
      ],
      "output": "existing_sheet_data",
      "source": {
        "domain": "table",
        "intent": "read"
      },
      "payload": {
        "spreadsheet_id": {
          "kind": "config",
          "key": "spreadsheet_id"
        },
        "range": {
          "kind": "computed",
          "op": "concat",
          "args": [
            {
              "kind": "config",
              "key": "sheet_tab_name"
            },
            {
              "kind": "literal",
              "value": "!A:E"
            }
          ]
        }
      }
    },
    {
      "id": "extract_existing_message_ids",
      "kind": "transform",
      "summary": "Extract the Gmail message link/id column (column E, index 4) from existing sheet rows to build a dedup set",
      "inputs": [
        "existing_sheet_data"
      ],
      "output": "existing_message_ids",
      "transform": {
        "op": "project_column",
        "input": "existing_sheet_data",
        "column": {
          "kind": "by_index",
          "index": 4
        }
      }
    },
    {
      "id": "filter_by_complaint_keywords",
      "kind": "transform",
      "summary": "Filter candidate emails to only those whose body or subject contains complaint keywords (case-insensitive)",
      "inputs": [
        "candidate_emails"
      ],
      "output": "complaint_emails",
      "transform": {
        "op": "filter",
        "input": "candidate_emails",
        "description": "Keep emails where body or subject contains any complaint keyword",
        "where": {
          "op": "or",
          "conditions": [
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "candidate_emails",
                "field": "body"
              },
              "comparator": "contains_any",
              "right": {
                "kind": "config",
                "key": "complaint_keywords"
              }
            },
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "candidate_emails",
                "field": "subject"
              },
              "comparator": "contains_any",
              "right": {
                "kind": "config",
                "key": "complaint_keywords"
              }
            }
          ]
        }
      }
    },
    {
      "id": "prepare_complaint_rows",
      "kind": "transform",
      "summary": "Map complaint emails to row format: sender email, subject, date, full email text, Gmail message id",
      "inputs": [
        "complaint_emails"
      ],
      "output": "complaint_rows",
      "transform": {
        "op": "map",
        "input": "complaint_emails",
        "mapping": [
          {
            "to": "sender_email",
            "from": "from"
          },
          {
            "to": "subject",
            "from": "subject"
          },
          {
            "to": "date",
            "from": "date"
          },
          {
            "to": "full_email_text",
            "from": "body"
          },
          {
            "to": "gmail_message_link_id",
            "from": "id"
          }
        ],
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender_email": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "full_email_text": {
                "type": "string"
              },
              "gmail_message_link_id": {
                "type": "string"
              }
            },
            "required": [
              "sender_email",
              "subject",
              "date",
              "full_email_text",
              "gmail_message_link_id"
            ]
          }
        }
      }
    },
    {
      "id": "deduplicate_against_existing",
      "kind": "transform",
      "summary": "Remove complaint rows whose Gmail message ID already exists in the sheet",
      "inputs": [
        "complaint_rows",
        "existing_message_ids"
      ],
      "output": "new_complaint_rows",
      "transform": {
        "op": "set_difference",
        "input": "complaint_rows",
        "reference": "existing_message_ids",
        "key_field": "gmail_message_link_id"
      }
    },
    {
      "id": "check_new_complaints_exist",
      "kind": "decide",
      "summary": "Only append rows if there are new complaint emails to log",
      "inputs": [
        "new_complaint_rows"
      ],
      "decide": {
        "condition": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "new_complaint_rows",
            "field": "length"
          },
          "comparator": "gt",
          "right": {
            "kind": "literal",
            "value": 0
          }
        },
        "then": [
          {
            "id": "format_rows_for_sheets",
            "kind": "transform",
            "summary": "Convert complaint row objects into 2D array format for Google Sheets append (each row: [sender_email, subject, date, full_email_text, gmail_message_link_id])",
            "inputs": [
              "new_complaint_rows"
            ],
            "output": "formatted_rows",
            "transform": {
              "op": "map",
              "input": "new_complaint_rows",
              "description": "Transform each complaint row object into an ordered array: [sender_email, subject, date, full_email_text, gmail_message_link_id]",
              "mapping": [
                {
                  "to": "0",
                  "from": "sender_email"
                },
                {
                  "to": "1",
                  "from": "subject"
                },
                {
                  "to": "2",
                  "from": "date"
                },
                {
                  "to": "3",
                  "from": "full_email_text"
                },
                {
                  "to": "4",
                  "from": "gmail_message_link_id"
                }
              ],
              "output_schema": {
                "type": "array",
                "items": {
                  "type": "array"
                }
              }
            }
          },
          {
            "id": "append_to_sheet",
            "kind": "deliver",
            "summary": "Append new complaint email rows to the UrgentEmails tab in Google Sheets",
            "inputs": [
              "formatted_rows",
              "sheet_tab"
            ],
            "output": "append_result",
            "uses": [
              {
                "capability": "append",
                "domain": "table",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "table",
              "intent": "append_rows",
              "input": "formatted_rows",
              "destination": "sheet_tab",
              "mapping": [
                {
                  "from": {
                    "kind": "config",
                    "key": "spreadsheet_id"
                  },
                  "to": "spreadsheet_id"
                },
                {
                  "from": {
                    "kind": "computed",
                    "op": "concat",
                    "args": [
                      {
                        "kind": "config",
                        "key": "sheet_tab_name"
                      },
                      {
                        "kind": "literal",
                        "value": "!A:E"
                      }
                    ]
                  },
                  "to": "range"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "formatted_rows"
                  },
                  "to": "values"
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "confidence": 0.93,
  "meta": {
    "estimated_steps": 8,
    "services_used": [
      "google-mail",
      "google-sheets"
    ],
    "dedup_strategy": "set_difference on gmail_message_link_id against existing sheet column E",
    "thread_handling": "each matching message logged independently"
  }
}