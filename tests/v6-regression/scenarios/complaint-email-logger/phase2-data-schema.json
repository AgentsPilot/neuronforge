          }
        }
      },
      "scope": "global",
      "produced_by": "deduplicate_against_existing",
      "consumed_by": [
        "append_new_complaints"
      ]
    },
    "append_result": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "properties": {
          "updated_range": {
            "type": "string",
            "source": "plugin",
            "description": "The range where data was appended",
            "required": true
          },
          "appended_rows": {
            "type": "number",
            "source": "plugin",
            "description": "Number of rows appended",
            "required": true
          },
          "appended_columns": {
            "type": "number",
            "source": "plugin",
            "description": "Number of columns in appended data"
          },
          "appended_cells": {
            "type": "number",
            "source": "plugin",
            "description": "Total number of cells appended"
          },
          "table_range": {
            "type": "string",
            "source": "plugin",
            "description": "Full range of the table including appended data"
          },
          "sheet_name": {
            "type": "string",
            "source": "plugin",
            "description": "Name of the sheet where data was appended"
          },
          "values": {
            "type": "array",
            "source": "plugin",
            "description": "The values that were appended"
          },
          "appended_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when data was appended (ISO 8601)"
          }
        }
      },
      "scope": "global",
      "produced_by": "append_new_complaints"
    }
  }
}