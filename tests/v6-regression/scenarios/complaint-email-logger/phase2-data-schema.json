    "complaint_rows": {
      "schema": {
        "type": "array",
        "source": "ai_declared",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "sender_email": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "subject": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "date": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "full_email_text": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "gmail_message_link_id": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            }
          }
        }
      },
      "scope": "global",
      "produced_by": "prepare_complaint_rows",
      "consumed_by": [
        "deduplicate_against_existing"
      ]
    },
    "new_complaint_rows": {
      "schema": {
        "type": "array",
        "source": "inferred",
        "items": {
          "type": "object",
          "source": "ai_declared",
          "properties": {
            "sender_email": {
              "type": "string",
              "source": "ai_declared",
              "required": true
            },
            "subject": {
              "type": "string",
