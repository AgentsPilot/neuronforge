                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is shared"
                },
                "starred": {
                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is starred"
                }
              }
            }
          },
          "file_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of files returned"
          },
          "next_page_token": {
            "type": "string",
            "source": "plugin",
