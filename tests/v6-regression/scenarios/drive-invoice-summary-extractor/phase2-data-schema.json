{
  "slots": {
    "folder_files": {
      "schema": {
        "type": "object",
        "source": "plugin",
        "properties": {
          "files": {
            "type": "array",
            "source": "plugin",
            "description": "List of files and folders",
            "items": {
              "type": "object",
              "source": "plugin",
              "semantic_type": "file_attachment",
              "properties": {
                "id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Unique file ID"
                },
                "name": {
                  "type": "string",
                  "source": "plugin",
                  "description": "File or folder name"
                },
                "mimeType": {
                  "type": "string",
                  "source": "plugin",
                  "description": "MIME type of the file"
                },
                "size": {
                  "type": "string",
                  "source": "plugin",
                  "description": "File size in bytes"
                },
                "createdTime": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Creation timestamp (ISO 8601)"
                },
                "modifiedTime": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Last modification timestamp (ISO 8601)"
                },
                "webViewLink": {
                  "type": "string",
                  "source": "plugin",
                  "description": "URL to view the file"
                },
                "shared": {
                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is shared"
                },
                "starred": {
                  "type": "boolean",
                  "source": "plugin",
                  "description": "Whether file is starred"
                }
              }
            }
          },
          "file_count": {
            "type": "number",
            "source": "plugin",
            "description": "Number of files returned"
          },
          "next_page_token": {
            "type": "string",
            "source": "plugin",
            "description": "Token for fetching next page of results"
          },
          "has_more": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether more files are available"
          },
          "query_used": {
            "type": "string",
            "source": "plugin",
            "description": "The query used to filter results"
          },
          "retrieved_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when data was retrieved (ISO 8601)"
          }
        }
      },
      "scope": "global",
      "produced_by": "list_folder_files",
      "consumed_by": [
        "filter_invoice_files"
      ]
    },
