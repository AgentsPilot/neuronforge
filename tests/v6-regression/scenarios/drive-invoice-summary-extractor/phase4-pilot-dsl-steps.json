[
  {
    "step_id": "step1",
    "type": "action",
    "description": "List all files in the specified Google Drive invoice folder",
    "plugin": "google-drive",
    "output_variable": "folder_files",
    "output_schema": {
      "type": "object",
      "source": "plugin",
      "properties": {
        "files": {
          "type": "array",
          "source": "plugin",
          "description": "List of files and folders",
          "items": {
            "type": "object",
            "source": "plugin",
            "semantic_type": "file_attachment",
            "properties": {
              "id": {
                "type": "string",
                "source": "plugin",
                "description": "Unique file ID"
              },
              "name": {
                "type": "string",
                "source": "plugin",
                "description": "File or folder name"
              },
              "mimeType": {
                "type": "string",
                "source": "plugin",
                "description": "MIME type of the file"
              },
              "size": {
                "type": "string",
                "source": "plugin",
                "description": "File size in bytes"
              },
              "createdTime": {
                "type": "string",
                "source": "plugin",
                "description": "Creation timestamp (ISO 8601)"
              },
              "modifiedTime": {
                "type": "string",
                "source": "plugin",
                "description": "Last modification timestamp (ISO 8601)"
              },
              "webViewLink": {
                "type": "string",
                "source": "plugin",
                "description": "URL to view the file"
              },
              "shared": {
                "type": "boolean",
                "source": "plugin",
                "description": "Whether file is shared"
              },
              "starred": {
                "type": "boolean",
                "source": "plugin",
                "description": "Whether file is starred"
              }
            }
          }
        },
        "file_count": {
          "type": "number",
          "source": "plugin",
          "description": "Number of files returned"
        },
        "next_page_token": {
          "type": "string",
          "source": "plugin",
          "description": "Token for fetching next page of results"
        },
        "has_more": {
          "type": "boolean",
          "source": "plugin",
          "description": "Whether more files are available"
        },
        "query_used": {
          "type": "string",
          "source": "plugin",
          "description": "The query used to filter results"
        },
        "retrieved_at": {
          "type": "string",
          "source": "plugin",
          "description": "Timestamp when data was retrieved (ISO 8601)"
        }
      }
    },
    "id": "step1",
    "params": {
      "folder_id": "{{input.folder_id}}",
      "max_results": 100
    },
    "name": "List all files in the specified Google Drive invoice folder",
    "action": "list_files"
  },
  {
    "step_id": "step2",
    "type": "transform",
    "operation": "filter",
    "input": "{{folder_files.files}}",
    "description": "Filter to only PDF and image files (JPG, PNG) that are likely invoices",
    "config": {
      "type": "filter",
      "input": "folder_files.files",
      "custom_code": "Keep only files with PDF or image MIME types as candidate invoices",
      "condition": {
        "operator": "in",
        "value": [
          "application/pdf",
          "image/jpeg",
          "image/png",
          "image/jpg"
        ],
        "field": "item.mimeType",
        "conditionType": "simple"
      }
    },
    "output_variable": "invoice_files",
    "output_schema": {
      "type": "array",
      "source": "inferred",
      "description": "List of files and folders",
      "items": {
        "type": "object",
        "source": "plugin",
        "semantic_type": "file_attachment",
        "properties": {
          "id": {
            "type": "string",
            "source": "plugin",
            "description": "Unique file ID"
          },
          "name": {
            "type": "string",
            "source": "plugin",
            "description": "File or folder name"
          },
          "mimeType": {
            "type": "string",
            "source": "plugin",
            "description": "MIME type of the file"
          },
          "size": {
            "type": "string",
            "source": "plugin",
            "description": "File size in bytes"
          },
          "createdTime": {
            "type": "string",
            "source": "plugin",
            "description": "Creation timestamp (ISO 8601)"
          },
          "modifiedTime": {
            "type": "string",
            "source": "plugin",
            "description": "Last modification timestamp (ISO 8601)"
          },
          "webViewLink": {
            "type": "string",
            "source": "plugin",
            "description": "URL to view the file"
          },
          "shared": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is shared"
          },
          "starred": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is starred"
          }
        }
      }
    },
    "id": "step2",
    "_on_empty": "throw",
    "name": "Filter to only PDF and image files (JPG, PNG) that are likely invoices"
  },
  {
    "step_id": "step3",
    "type": "scatter_gather",
    "description": "Loop over invoice_files",
    "scatter": {
      "input": "{{invoice_files}}",
      "steps": [
        {
          "step_id": "step4",
          "type": "action",
          "description": "Read the file content from Google Drive for extraction",
          "plugin": "google-drive",
          "output_variable": "file_content",
          "output_schema": {
            "type": "object",
            "source": "plugin",
            "properties": {
              "file_id": {
                "type": "string",
                "source": "plugin",
                "description": "ID of the file that was read"
              },
              "file_name": {
                "type": "string",
                "source": "plugin",
                "description": "Name of the file"
              },
              "file_size": {
                "type": "string",
                "source": "plugin",
                "description": "Human-readable file size (e.g., '1.5 MB')"
              },
              "mime_type": {
                "type": "string",
                "source": "plugin",
                "description": "MIME type of the file"
              },
              "content": {
                "type": "string",
                "source": "plugin",
                "description": "Text content extracted from the file"
              },
              "content_length": {
                "type": "number",
                "source": "plugin",
                "description": "Length of the extracted content in characters"
              },
              "export_format": {
                "type": "string",
                "source": "plugin",
                "description": "Format the file was exported as (text/plain, text/html, or 'original')"
              },
              "read_at": {
                "type": "string",
                "source": "plugin",
                "description": "Timestamp when file was read (ISO 8601)"
              }
            }
          },
          "id": "step4",
          "params": {
            "file_id": "{{invoice_file.id}}",
            "export_format": "application/pdf"
          },
          "name": "Read the file content from Google Drive for extraction",
          "action": "read_file_content"
        },
        {
          "step_id": "step5",
          "type": "ai_processing",
          "input": "{{file_content}}",
          "prompt": "Extract the following structured fields from the input text. For each email/message, read the subject, snippet, and body, then extract: vendor_name (string — Vendor or supplier name on the invoice); invoice_number (string — Invoice number or reference ID); invoice_date (date — Date the invoice was issued); due_date (date — Payment due date); total_amount (number — Total invoice amount); currency (string — Currency code (e.g., USD, EUR, ILS)); tax_amount (number — Tax or VAT amount). Return a JSON object with these fields. If a field cannot be found in the text, set its value to null.",
          "description": "Extract structured invoice fields from the file content (vendor, invoice number, dates, totals, currency, tax)",
          "config": {
            "ai_type": "llm_extract",
            "output_schema": {
              "fields": [
                {
                  "name": "vendor_name",
                  "type": "string",
                  "description": "Vendor or supplier name on the invoice",
                  "required": false
                },
                {
                  "name": "invoice_number",
                  "type": "string",
                  "description": "Invoice number or reference ID",
                  "required": false
                },
                {
                  "name": "invoice_date",
                  "type": "date",
                  "description": "Date the invoice was issued",
                  "required": false
                },
                {
                  "name": "due_date",
                  "type": "date",
                  "description": "Payment due date",
                  "required": false
                },
                {
                  "name": "total_amount",
                  "type": "number",
                  "description": "Total invoice amount",
                  "required": false
                },
                {
                  "name": "currency",
                  "type": "string",
                  "description": "Currency code (e.g., USD, EUR, ILS)",
                  "required": false
                },
                {
                  "name": "tax_amount",
                  "type": "number",
                  "description": "Tax or VAT amount",
                  "required": false
                }
              ]
            },
            "type": "llm_extract",
            "instruction": "Extract the following structured fields from the input text. For each email/message, read the subject, snippet, and body, then extract: vendor_name (string — Vendor or supplier name on the invoice); invoice_number (string — Invoice number or reference ID); invoice_date (date — Date the invoice was issued); due_date (date — Payment due date); total_amount (number — Total invoice amount); currency (string — Currency code (e.g., USD, EUR, ILS)); tax_amount (number — Tax or VAT amount). Return a JSON object with these fields. If a field cannot be found in the text, set its value to null.",
            "input": "{{file_content}}"
          },
          "output_variable": "raw_extracted_fields",
          "output_schema": {
            "type": "object",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared",
                "description": "Vendor or supplier name on the invoice",
                "required": false
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared",
                "description": "Invoice number or reference ID",
                "required": false
              },
              "invoice_date": {
                "type": "string",
                "source": "ai_declared",
                "description": "Date the invoice was issued",
                "required": false
              },
              "due_date": {
                "type": "string",
                "source": "ai_declared",
                "description": "Payment due date",
                "required": false
              },
              "total_amount": {
                "type": "number",
                "source": "ai_declared",
                "description": "Total invoice amount",
                "required": false
              },
              "currency": {
                "type": "string",
                "source": "ai_declared",
                "description": "Currency code (e.g., USD, EUR, ILS)",
                "required": false
              },
              "tax_amount": {
                "type": "number",
                "source": "ai_declared",
                "description": "Tax or VAT amount",
                "required": false
              }
            },
            "source": "ai_declared"
          },
          "id": "step5",
          "name": "Extract structured invoice fields from the file content (vendor, invoice number, dates, totals, currency, tax)"
        },
        {
          "step_id": "step6",
          "type": "transform",
          "operation": "with_fields",
          "input": "{{raw_extracted_fields}}",
          "description": "Augment extracted fields with file name and modification date from the Drive file metadata",
          "config": {
            "type": "with_fields",
            "input": "raw_extracted_fields",
            "output_schema": {
              "type": "object",
              "properties": {
                "vendor_name": {
                  "type": "string"
                },
                "invoice_number": {
                  "type": "string"
                },
                "invoice_date": {
                  "type": "string"
                },
                "due_date": {
                  "type": "string"
                },
                "total_amount": {
                  "type": "number"
                },
                "currency": {
                  "type": "string"
                },
                "tax_amount": {
                  "type": "number"
                },
                "file_name": {
                  "type": "string"
                },
                "file_modified": {
                  "type": "string"
                }
              }
            },
            "fields": [
              {
                "name": "file_name",
                "expression": "{{invoice_file.name}}"
              },
              {
                "name": "file_modified",
                "expression": "{{invoice_file.modifiedTime}}"
              }
            ]
          },
          "output_variable": "extraction_result",
          "output_schema": {
            "type": "object",
            "source": "ai_declared",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "due_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "total_amount": {
                "type": "number",
                "source": "ai_declared"
              },
              "currency": {
                "type": "string",
                "source": "ai_declared"
              },
              "tax_amount": {
                "type": "number",
                "source": "ai_declared"
              },
              "file_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "file_modified": {
                "type": "string",
                "source": "ai_declared"
              }
            }
          },
          "id": "step6",
          "name": "Augment extracted fields with file name and modification date from the Drive file metadata"
        }
      ],
      "itemVariable": "invoice_file"
    },
    "gather": {
      "operation": "collect"
    },
    "output_variable": "extracted_invoices",
    "id": "step3",
    "name": "Loop over invoice_files"
  },
  {
    "step_id": "step7",
    "type": "transform",
    "operation": "reduce",
    "input": "{{extracted_invoices}}",
    "description": "Count items for invoice_count",
    "config": {
      "type": "reduce",
      "input": "extracted_invoices",
      "reduce_operation": "count",
      "reducer": "count"
    },
    "output_variable": "invoice_count",
    "output_schema": {
      "type": "number",
      "description": "Count of invoice_count",
      "source": "inferred"
    },
    "id": "step7",
    "name": "Count items for invoice_count"
  },
  {
    "step_id": "step8",
    "type": "transform",
    "operation": "reduce",
    "input": "{{extracted_invoices}}",
    "description": "Aggregate sum for total_sum",
    "config": {
      "type": "reduce",
      "input": "extracted_invoices",
      "reduce_operation": "sum",
      "reducer": "sum",
      "field": "total_amount"
    },
    "output_variable": "total_sum",
    "output_schema": {
      "type": "number",
      "description": "sum of total_amount",
      "source": "inferred"
    },
    "id": "step8",
    "name": "Aggregate sum for total_sum"
  },
  {
    "step_id": "step9",
    "type": "transform",
    "operation": "filter",
    "input": "{{extracted_invoices}}",
    "description": "Filter subset for invoices_missing_total",
    "config": {
      "type": "filter",
      "input": "extracted_invoices",
      "condition": {
        "conditionType": "complex_not",
        "condition": {
          "operator": "exists",
          "field": "item.total_amount",
          "conditionType": "simple"
        }
      }
    },
    "output_variable": "invoices_missing_total",
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "source": "ai_declared",
        "properties": {
          "vendor_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_number": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "due_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "total_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "currency": {
            "type": "string",
            "source": "ai_declared"
          },
          "tax_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "file_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "file_modified": {
            "type": "string",
            "source": "ai_declared"
          }
        }
      },
      "source": "inferred"
    },
    "id": "step9",
    "_on_empty": "warn",
    "name": "Filter subset for invoices_missing_total"
  },
  {
    "step_id": "step10",
    "type": "transform",
    "operation": "filter",
    "input": "{{extracted_invoices}}",
    "description": "Filter subset for invoices_missing_invoice_number",
    "config": {
      "type": "filter",
      "input": "extracted_invoices",
      "condition": {
        "conditionType": "complex_not",
        "condition": {
          "operator": "exists",
          "field": "item.invoice_number",
          "conditionType": "simple"
        }
      }
    },
    "output_variable": "invoices_missing_invoice_number",
    "output_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "source": "ai_declared",
        "properties": {
          "vendor_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_number": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "due_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "total_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "currency": {
            "type": "string",
            "source": "ai_declared"
          },
          "tax_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "file_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "file_modified": {
            "type": "string",
            "source": "ai_declared"
          }
        }
      },
      "source": "inferred"
    },
    "id": "step10",
    "_on_empty": "warn",
    "name": "Filter subset for invoices_missing_invoice_number"
  },
  {
    "step_id": "step11",
    "type": "ai_processing",
    "input": "{{extracted_invoices}}",
    "prompt": "Generate a professional HTML email body for an invoice summary. Structure it as follows:\n\n1. HEADER: Include a short greeting, the Google Drive folder link (from config folder_link), and the total number of invoices found (from invoice_count).\n\n2. If no invoices were found (invoice_count is 0), state that no invoices were found in the folder and include the folder link. Skip the table and totals.\n\n3. INVOICE TABLE: Create an HTML <table> with styled borders, header row with background color, and padding. Columns: File Name, Vendor, Invoice #, Invoice Date, Due Date, Total, Currency, Notes. One row per invoice from extracted_invoices. For any missing/null field, show a dash and add a note like 'Missing vendor name' in the Notes column. Multiple missing fields should be comma-separated in Notes.\n\n4. TOTALS SECTION: Below the table, show:\n   - Total invoices processed: (invoice_count)\n   - Sum of invoice totals: (total_sum, formatted with 2 decimal places; note if some invoices had no total)\n   - Exceptions: list file names from invoices_missing_total and invoices_missing_invoice_number if any exist.\n\n5. Use professional styling: table borders (#ddd), header background (#4472C4 with white text), alternating row colors, padding 8px.",
    "description": "Generate an HTML email body with a header, per-invoice table, and roll-up totals/exceptions section",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "description": "Email subject line"
          },
          "html_body": {
            "type": "string",
            "description": "Complete HTML email body with styled table and totals"
          }
        },
        "required": [
          "subject",
          "html_body"
        ]
      },
      "type": "generate",
      "instruction": "Generate a professional HTML email body for an invoice summary. Structure it as follows:\n\n1. HEADER: Include a short greeting, the Google Drive folder link (from config folder_link), and the total number of invoices found (from invoice_count).\n\n2. If no invoices were found (invoice_count is 0), state that no invoices were found in the folder and include the folder link. Skip the table and totals.\n\n3. INVOICE TABLE: Create an HTML <table> with styled borders, header row with background color, and padding. Columns: File Name, Vendor, Invoice #, Invoice Date, Due Date, Total, Currency, Notes. One row per invoice from extracted_invoices. For any missing/null field, show a dash and add a note like 'Missing vendor name' in the Notes column. Multiple missing fields should be comma-separated in Notes.\n\n4. TOTALS SECTION: Below the table, show:\n   - Total invoices processed: (invoice_count)\n   - Sum of invoice totals: (total_sum, formatted with 2 decimal places; note if some invoices had no total)\n   - Exceptions: list file names from invoices_missing_total and invoices_missing_invoice_number if any exist.\n\n5. Use professional styling: table borders (#ddd), header background (#4472C4 with white text), alternating row colors, padding 8px.",
      "input": "{{extracted_invoices}}"
    },
    "output_variable": "email_content",
    "output_schema": {
      "type": "object",
      "properties": {
        "subject": {
          "type": "string",
          "source": "ai_declared",
          "description": "Email subject line"
        },
        "html_body": {
          "type": "string",
          "source": "ai_declared",
          "description": "Complete HTML email body with styled table and totals"
        }
      },
      "source": "ai_declared"
    },
    "input_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "source": "ai_declared",
        "properties": {
          "vendor_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_number": {
            "type": "string",
            "source": "ai_declared"
          },
          "invoice_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "due_date": {
            "type": "string",
            "source": "ai_declared"
          },
          "total_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "currency": {
            "type": "string",
            "source": "ai_declared"
          },
          "tax_amount": {
            "type": "number",
            "source": "ai_declared"
          },
          "file_name": {
            "type": "string",
            "source": "ai_declared"
          },
          "file_modified": {
            "type": "string",
            "source": "ai_declared"
          }
        }
      },
      "source": "inferred"
    },
    "id": "step11",
    "name": "Generate an HTML email body with a header, per-invoice table, and roll-up totals/exceptions section"
  },
  {
    "step_id": "step12",
    "type": "action",
    "description": "Send the invoice summary email via Gmail to the user",
    "plugin": "google-mail",
    "id": "step12",
    "params": {
      "recipients": {
        "to": [
          "{{input.recipient_email}}"
        ]
      },
      "content": {
        "subject": "{{email_content.subject}}",
        "html_body": "{{email_content.html_body}}"
      }
    },
    "name": "Send the invoice summary email via Gmail to the user",
    "action": "send_email"
  }
]