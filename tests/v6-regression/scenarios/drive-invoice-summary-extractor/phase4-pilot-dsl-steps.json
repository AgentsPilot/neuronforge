      },
      {
        "step_id": "step12",
        "type": "ai_processing",
        "input": "{{extraction_results}}",
        "prompt": "Compose a professional HTML email body for an invoice summary. Use the data from extraction_results (array of invoice objects) and the aggregate values (invoice_count, missing_vendor_invoices, missing_number_invoices, missing_total_invoices). Structure the email as follows:\n\n1. HEADER: A short paragraph stating 'Invoice Summary' with the folder link from config and the total number of invoices found (invoice_count).\n\n2. TABLE: An HTML <table> with borders, header row background (#4472C4 white text), and alternating row shading. Columns: File Name, Vendor, Invoice #, Invoice Date, Due Date, Total, Currency, Notes. For each invoice in extraction_results, populate one row. If a field is null/empty, leave the cell blank and add a note in the Notes column (e.g., 'Missing vendor name', 'Missing invoice number', 'Missing total'). Multiple missing fields should be comma-separated in Notes.\n\n3. TOTALS SECTION: Below the table, show: (a) Total invoices processed, (b) Sum of all available total_amount values (skip nulls; note how many had missing totals), (c) A short list of exceptions — file names with missing key fields (vendor, invoice number, or total).\n\nUse inline CSS for styling. Keep the email clean and professional.",
        "description": "Compose an HTML email body with a per-invoice table, roll-up totals, and exceptions list",
        "config": {
          "ai_type": "generate",
          "output_schema": {
            "type": "object",
            "properties": {
              "subject": {
                "type": "string",
                "description": "Email subject line"
              },
              "html_body": {
                "type": "string",
                "description": "Complete HTML email body with styled table and totals"
              }
            },
            "required": [
              "subject",
              "html_body"
            ]
          },
          "type": "generate",
          "instruction": "Compose a professional HTML email body for an invoice summary. Use the data from extraction_results (array of invoice objects) and the aggregate values (invoice_count, missing_vendor_invoices, missing_number_invoices, missing_total_invoices). Structure the email as follows:\n\n1. HEADER: A short paragraph stating 'Invoice Summary' with the folder link from config and the total number of invoices found (invoice_count).\n\n2. TABLE: An HTML <table> with borders, header row background (#4472C4 white text), and alternating row shading. Columns: File Name, Vendor, Invoice #, Invoice Date, Due Date, Total, Currency, Notes. For each invoice in extraction_results, populate one row. If a field is null/empty, leave the cell blank and add a note in the Notes column (e.g., 'Missing vendor name', 'Missing invoice number', 'Missing total'). Multiple missing fields should be comma-separated in Notes.\n\n3. TOTALS SECTION: Below the table, show: (a) Total invoices processed, (b) Sum of all available total_amount values (skip nulls; note how many had missing totals), (c) A short list of exceptions — file names with missing key fields (vendor, invoice number, or total).\n\nUse inline CSS for styling. Keep the email clean and professional.",
          "input": "{{extraction_results}}"
        },
        "output_variable": "email_content",
        "output_schema": {
          "type": "object",
          "properties": {
            "subject": {
              "type": "string",
              "source": "ai_declared",
              "description": "Email subject line"
            },
            "html_body": {
              "type": "string",
              "source": "ai_declared",
              "description": "Complete HTML email body with styled table and totals"
            }
          },
          "source": "ai_declared"
        },
        "input_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "source": "ai_declared",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared"
