[
  {
    "step_id": "step1",
    "type": "action",
    "description": "List all files in the specified Google Drive folder (non-recursive)",
    "plugin": "google-drive",
    "output_variable": "folder_files",
    "output_schema": {
      "type": "object",
      "source": "plugin",
      "properties": {
        "files": {
          "type": "array",
          "source": "plugin",
          "description": "List of files and folders",
          "items": {
            "type": "object",
            "source": "plugin",
            "semantic_type": "file_attachment",
            "properties": {
              "id": {
                "type": "string",
                "source": "plugin",
                "description": "Unique file ID"
              },
              "name": {
                "type": "string",
                "source": "plugin",
                "description": "File or folder name"
              },
              "mimeType": {
                "type": "string",
                "source": "plugin",
                "description": "MIME type of the file"
              },
              "size": {
                "type": "string",
                "source": "plugin",
                "description": "File size in bytes"
              },
              "createdTime": {
                "type": "string",
                "source": "plugin",
                "description": "Creation timestamp (ISO 8601)"
              },
              "modifiedTime": {
                "type": "string",
                "source": "plugin",
                "description": "Last modification timestamp (ISO 8601)"
              },
              "webViewLink": {
                "type": "string",
                "source": "plugin",
                "description": "URL to view the file"
              },
              "shared": {
                "type": "boolean",
                "source": "plugin",
                "description": "Whether file is shared"
              },
              "starred": {
                "type": "boolean",
                "source": "plugin",
                "description": "Whether file is starred"
              }
            }
          }
        },
        "file_count": {
          "type": "number",
          "source": "plugin",
          "description": "Number of files returned"
        },
        "next_page_token": {
          "type": "string",
          "source": "plugin",
          "description": "Token for fetching next page of results"
        },
        "has_more": {
          "type": "boolean",
          "source": "plugin",
          "description": "Whether more files are available"
        },
        "query_used": {
          "type": "string",
          "source": "plugin",
          "description": "The query used to filter results"
        },
        "retrieved_at": {
          "type": "string",
          "source": "plugin",
          "description": "Timestamp when data was retrieved (ISO 8601)"
        }
      }
    },
    "id": "step1",
    "params": {
      "folder_id": "{{input.folder_id}}",
      "max_results": "{{input.max_files}}",
      "order_by": "name"
    },
    "name": "List all files in the specified Google Drive folder (non-recursive)",
    "action": "list_files"
  },
  {
    "step_id": "step2",
    "type": "transform",
    "operation": "filter",
    "input": "{{folder_files.files}}",
    "description": "Filter to only PDF and image files (common invoice formats)",
    "config": {
      "type": "filter",
      "input": "folder_files.files",
      "custom_code": "Keep only files with PDF or image MIME types (application/pdf, image/jpeg, image/png)",
      "condition": {
        "operator": "in",
        "value": [
          "application/pdf",
          "image/jpeg",
          "image/png",
          "image/jpg"
        ],
        "field": "item.mimeType",
        "conditionType": "simple"
      }
    },
    "output_variable": "invoice_files",
    "output_schema": {
      "type": "array",
      "source": "inferred",
      "description": "List of files and folders",
      "items": {
        "type": "object",
        "source": "plugin",
        "semantic_type": "file_attachment",
        "properties": {
          "id": {
            "type": "string",
            "source": "plugin",
            "description": "Unique file ID"
          },
          "name": {
            "type": "string",
            "source": "plugin",
            "description": "File or folder name"
          },
          "mimeType": {
            "type": "string",
            "source": "plugin",
            "description": "MIME type of the file"
          },
          "size": {
            "type": "string",
            "source": "plugin",
            "description": "File size in bytes"
          },
          "createdTime": {
            "type": "string",
            "source": "plugin",
            "description": "Creation timestamp (ISO 8601)"
          },
          "modifiedTime": {
            "type": "string",
            "source": "plugin",
            "description": "Last modification timestamp (ISO 8601)"
          },
          "webViewLink": {
            "type": "string",
            "source": "plugin",
            "description": "URL to view the file"
          },
          "shared": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is shared"
          },
          "starred": {
            "type": "boolean",
            "source": "plugin",
            "description": "Whether file is starred"
          }
        }
      }
    },
    "id": "step2",
    "_on_empty": "warn",
    "name": "Filter to only PDF and image files (common invoice formats)"
  },
  {
    "step_id": "step3",
    "type": "conditional",
    "description": "Conditional: node_2",
    "condition": {
      "conditionType": "simple",
      "field": "invoice_files.length",
      "operator": "greater_than",
      "value": 0
    },
    "steps": [
      {
        "step_id": "step4",
        "type": "scatter_gather",
        "description": "Loop over invoice_files",
        "scatter": {
          "input": "{{invoice_files}}",
          "steps": [
            {
              "step_id": "step5",
              "type": "action",
              "description": "Download the raw binary content of the invoice file from Google Drive",
              "plugin": "google-drive",
              "output_variable": "downloaded_file",
              "output_schema": {
                "type": "object",
                "source": "plugin",
                "semantic_type": "file_attachment",
                "properties": {
                  "file_id": {
                    "type": "string",
                    "source": "plugin",
                    "description": "ID of the downloaded file",
                    "required": true
                  },
                  "filename": {
                    "type": "string",
                    "source": "plugin",
                    "description": "Name of the file"
                  },
                  "mimeType": {
                    "type": "string",
                    "source": "plugin",
                    "description": "MIME type of the file (e.g. application/pdf, image/png)",
                    "required": true
                  },
                  "content": {
                    "type": "string",
                    "source": "plugin",
                    "description": "Base64-encoded raw file bytes — pass directly to document-extractor.file_content (which reads a file object's 'content' field)",
                    "required": true
                  },
                  "file_size": {
                    "type": "string",
                    "source": "plugin",
                    "description": "Human-readable file size (e.g., '1.5 MB')"
                  }
                }
              },
              "id": "step5",
              "params": {
                "file_id": "{{invoice_file.id}}"
              },
              "name": "Download the raw binary content of the invoice file from Google Drive",
              "action": "download_file"
            },
            {
              "step_id": "step6",
              "type": "action",
              "description": "Extract structured invoice fields from the downloaded document (vendor, invoice number, dates, totals, currency, tax)",
              "plugin": "document-extractor",
              "output_variable": "extracted_fields",
              "output_schema": {
                "type": "object",
                "properties": {
                  "vendor_name": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Vendor or supplier name on the invoice",
                    "required": false
                  },
                  "invoice_number": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Invoice number or reference ID",
                    "required": false
                  },
                  "invoice_date": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Date the invoice was issued",
                    "required": false
                  },
                  "due_date": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Payment due date",
                    "required": false
                  },
                  "total_amount": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Total amount on the invoice",
                    "required": false
                  },
                  "currency": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Currency code (e.g., USD, EUR, ILS)",
                    "required": false
                  },
                  "tax_amount": {
                    "type": "string",
                    "source": "ai_declared",
                    "description": "Tax or VAT amount",
                    "required": false
                  }
                },
                "source": "ai_declared"
              },
              "id": "step6",
              "params": {
                "file_content": "{{downloaded_file.content}}",
                "fields": [
                  {
                    "name": "vendor_name",
                    "type": "string",
                    "required": false
                  },
                  {
                    "name": "invoice_number",
                    "type": "string",
                    "required": false
                  },
                  {
                    "name": "invoice_date",
                    "type": "date",
                    "required": false
                  },
                  {
                    "name": "due_date",
                    "type": "date",
                    "required": false
                  },
                  {
                    "name": "total_amount",
                    "type": "currency",
                    "required": false
                  },
                  {
                    "name": "currency",
                    "type": "string",
                    "required": false
                  },
                  {
                    "name": "tax_amount",
                    "type": "currency",
                    "required": false
                  }
                ],
                "deterministic": true
              },
              "name": "Extract structured invoice fields from the downloaded document (vendor, invoice number, dates, totals, currency, tax)",
              "action": "extract_structured_data"
            },
            {
              "step_id": "step7",
              "type": "transform",
              "operation": "with_fields",
              "input": "{{extracted_fields}}",
              "description": "Combine extracted invoice fields with file metadata (file name, modified time) and generate notes for missing fields",
              "config": {
                "type": "with_fields",
                "input": "extracted_fields",
                "output_schema": {
                  "type": "object",
                  "properties": {
                    "vendor_name": {
                      "type": "string"
                    },
                    "invoice_number": {
                      "type": "string"
                    },
                    "invoice_date": {
                      "type": "string"
                    },
                    "due_date": {
                      "type": "string"
                    },
                    "total_amount": {
                      "type": "string"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "tax_amount": {
                      "type": "string"
                    },
                    "file_name": {
                      "type": "string"
                    },
                    "last_modified": {
                      "type": "string"
                    },
                    "has_vendor": {
                      "type": "boolean"
                    },
                    "has_invoice_number": {
                      "type": "boolean"
                    },
                    "has_total": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "file_name",
                    "has_vendor",
                    "has_invoice_number",
                    "has_total"
                  ]
                },
                "fields": [
                  {
                    "name": "file_name",
                    "expression": "{{invoice_file.name}}"
                  },
                  {
                    "name": "last_modified",
                    "expression": "{{invoice_file.modifiedTime}}"
                  },
                  {
                    "name": "has_vendor",
                    "expression": {
                      "kind": "null_check",
                      "invert": true,
                      "value": {
                        "kind": "ref",
                        "ref": "item",
                        "field": "vendor_name"
                      }
                    }
                  },
                  {
                    "name": "has_invoice_number",
                    "expression": {
                      "kind": "null_check",
                      "invert": true,
                      "value": {
                        "kind": "ref",
                        "ref": "item",
                        "field": "invoice_number"
                      }
                    }
                  },
                  {
                    "name": "has_total",
                    "expression": {
                      "kind": "null_check",
                      "invert": true,
                      "value": {
                        "kind": "ref",
                        "ref": "item",
                        "field": "total_amount"
                      }
                    }
                  }
                ]
              },
              "output_variable": "enriched_extraction",
              "output_schema": {
                "type": "object",
                "source": "ai_declared",
                "properties": {
                  "vendor_name": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "invoice_number": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "invoice_date": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "due_date": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "total_amount": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "currency": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "tax_amount": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "file_name": {
                    "type": "string",
                    "source": "ai_declared",
                    "required": true
                  },
                  "last_modified": {
                    "type": "string",
                    "source": "ai_declared"
                  },
                  "has_vendor": {
                    "type": "boolean",
                    "source": "ai_declared",
                    "required": true
                  },
                  "has_invoice_number": {
                    "type": "boolean",
                    "source": "ai_declared",
                    "required": true
                  },
                  "has_total": {
                    "type": "boolean",
                    "source": "ai_declared",
                    "required": true
                  }
                }
              },
              "id": "step7",
              "name": "Combine extracted invoice fields with file metadata (file name, modified time) and generate notes for missing fields"
            }
          ],
          "itemVariable": "invoice_file"
        },
        "gather": {
          "operation": "collect"
        },
        "output_variable": "extraction_results",
        "id": "step4",
        "name": "Loop over invoice_files"
      },
      {
        "step_id": "step8",
        "type": "transform",
        "operation": "reduce",
        "input": "{{extraction_results}}",
        "description": "Count items for invoice_count",
        "config": {
          "type": "reduce",
          "input": "extraction_results",
          "reduce_operation": "count",
          "reducer": "count"
        },
        "output_variable": "invoice_count",
        "output_schema": {
          "type": "number",
          "description": "Count of invoice_count",
          "source": "inferred"
        },
        "id": "step8",
        "name": "Count items for invoice_count"
      },
      {
        "step_id": "step9",
        "type": "transform",
        "operation": "filter",
        "input": "{{extraction_results}}",
        "description": "Filter subset for missing_vendor_invoices",
        "config": {
          "type": "filter",
          "input": "extraction_results",
          "condition": {
            "operator": "eq",
            "value": false,
            "field": "item.has_vendor",
            "conditionType": "simple"
          }
        },
        "output_variable": "missing_vendor_invoices",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "source": "ai_declared",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "due_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "total_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "currency": {
                "type": "string",
                "source": "ai_declared"
              },
              "tax_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "file_name": {
                "type": "string",
                "source": "ai_declared",
                "required": true
              },
              "last_modified": {
                "type": "string",
                "source": "ai_declared"
              },
              "has_vendor": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              },
              "has_invoice_number": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              },
              "has_total": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              }
            }
          },
          "source": "inferred"
        },
        "id": "step9",
        "_on_empty": "warn",
        "name": "Filter subset for missing_vendor_invoices"
      },
      {
        "step_id": "step10",
        "type": "transform",
        "operation": "filter",
        "input": "{{extraction_results}}",
        "description": "Filter subset for missing_number_invoices",
        "config": {
          "type": "filter",
          "input": "extraction_results",
          "condition": {
            "operator": "eq",
            "value": false,
            "field": "item.has_invoice_number",
            "conditionType": "simple"
          }
        },
        "output_variable": "missing_number_invoices",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "source": "ai_declared",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "due_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "total_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "currency": {
                "type": "string",
                "source": "ai_declared"
              },
              "tax_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "file_name": {
                "type": "string",
                "source": "ai_declared",
                "required": true
              },
              "last_modified": {
                "type": "string",
                "source": "ai_declared"
              },
              "has_vendor": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              },
              "has_invoice_number": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              },
              "has_total": {
                "type": "boolean",
                "source": "ai_declared",
                "required": true
              }
            }
          },
          "source": "inferred"
        },
        "id": "step10",
        "_on_empty": "warn",
        "name": "Filter subset for missing_number_invoices"
      },
      {
        "step_id": "step11",
        "type": "transform",
        "operation": "filter",
        "input": "{{extraction_results}}",
        "description": "Filter subset for missing_total_invoices",
        "config": {
          "type": "filter",
          "input": "extraction_results",
          "condition": {
            "operator": "eq",
            "value": false,
            "field": "item.has_total",
            "conditionType": "simple"
          }
        },
        "output_variable": "missing_total_invoices",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "source": "ai_declared",
            "properties": {
              "vendor_name": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_number": {
                "type": "string",
                "source": "ai_declared"
              },
              "invoice_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "due_date": {
                "type": "string",
                "source": "ai_declared"
              },
              "total_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "currency": {
                "type": "string",
                "source": "ai_declared"
              },
              "tax_amount": {
                "type": "string",
                "source": "ai_declared"
              },
              "file_name": {
                "type": "string",
