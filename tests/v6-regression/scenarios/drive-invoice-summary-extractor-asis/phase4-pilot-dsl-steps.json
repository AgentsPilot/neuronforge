        "source": "ai_declared",
        "properties": {
          "currency": {
            "type": "string",
            "source": "ai_declared",
            "required": false,
            "description": "Currency code (e.g., USD, EUR, ILS)"
          },
          "due_date": {
            "type": "string",
            "source": "ai_declared",
            "required": false,
            "description": "Payment due date"
          },
          "file_name": {
            "type": "string",
            "source": "ai_declared",
            "required": false,
            "description": "Original file name from Google Drive"
          },
          "tax_amount": {
            "type": "number",
            "source": "ai_declared",
            "required": false,
            "description": "Tax or VAT amount"
          },
          "vendor_name": {
            "type": "string",
            "source": "ai_declared",
            "required": false,
            "description": "Vendor or supplier name on the invoice"
          },
          "invoice_date": {
            "type": "string",
