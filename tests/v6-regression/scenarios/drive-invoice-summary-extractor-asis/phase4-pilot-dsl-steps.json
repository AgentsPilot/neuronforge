    },
    "output_variable": "email_content"
  },
  {
    "id": "step10",
    "name": "Send the invoice summary email via Gmail to the user",
    "type": "action",
    "action": "send_email",
    "params": {
      "content": {
        "subject": "{{input.email_subject}}",
        "html_body": "{{email_content.body}}"
      },
      "recipients": {
        "to": [
          "{{input.recipient_email}}"
        ]
      }
    },
    "plugin": "google-mail",
    "step_id": "step10",
    "description": "Send the invoice summary email via Gmail to the user"
  }
