{
  "version": "intent.v1",
  "goal": "Scan Gmail for PDF invoice/expense attachments from the last 7 days, extract structured fields, store each PDF in Google Drive under per-vendor subfolders, append qualifying rows (amount > 50) to Google Sheets, and send a single digest email summary.",
  "unit_of_work": {
    "entity": "attachment",
    "parent_entity": "email"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find invoice/expense emails with PDF attachments from the last 7 days",
      "default": "subject:(Invoice OR Expenses OR Bill) has:attachment filename:pdf newer_than:7d"
    },
    {
      "key": "gmail_max_results",
      "type": "number",
      "description": "Maximum number of emails to retrieve",
      "default": 50
    },
    {
      "key": "drive_base_folder_id",
      "type": "string",
      "description": "Google Drive base folder ID for storing vendor subfolders",
      "default": "1BoYgIIQj5QB6F0mWLzD_0-2pMLoxHVp-"
    },
    {
      "key": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID for appending invoice/expense rows",
      "default": "1RHLbBXzrKv24gNgp7a4Lr7RlMIrP9fjacfGWjhPAbOE"
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Sheet tab name to append rows into",
      "default": "Invoices"
    },
    {
      "key": "amount_threshold",
      "type": "number",
      "description": "Minimum amount threshold for appending to Google Sheets (in document currency)",
      "default": 50
    },
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send the digest summary to",
      "default": "meiribarak@gmail.com"
    }
  ],
  "invariants": [
    "Every PDF attachment is stored in Google Drive regardless of extracted amount",
    "Every processed attachment appears in the digest email regardless of extracted amount",
    "Only attachments with extracted amount greater than threshold are appended to Google Sheets",
    "Attachments with missing or unextractable amounts are included in email and Drive but skipped for Sheets",
    "Vendor subfolders are created idempotently under the base folder"
  ],
  "required_outcomes": [
    "All PDF attachments from matching emails are stored in per-vendor Google Drive subfolders",
    "A single digest email is sent with a table of all processed attachments",
    "Qualifying rows (amount > 50) are appended to the specified Google Sheet tab",
    "Each stored attachment has a shareable Drive link included in the digest"
  ],
  "confidence": 0.9,
  "steps": [
    {
      "id": "search_emails",
      "kind": "data_source",
      "summary": "Search Gmail for invoice/expense emails with PDF attachments from the last 7 days",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "matching_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full",
        "include_attachments": true
      }
    },
    {
      "id": "flatten_attachments",
      "kind": "transform",
      "summary": "Extract attachment metadata from emails, preserving parent email fields needed downstream",
      "inputs": [
        "matching_emails"
      ],
      "output": "all_attachments",
      "transform": {
        "op": "flatten",
        "input": "matching_emails",
        "description": "Flatten the attachments array from each email, carrying forward parent email fields (id, from, subject, date) alongside each attachment's fields (filename, mimeType, size, attachment_id, message_id)",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "message_id": {
                "type": "string"
              },
              "attachment_id": {
                "type": "string"
              },
              "filename": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              },
              "size": {
                "type": "integer"
              },
              "email_from": {
                "type": "string"
              },
              "email_subject": {
                "type": "string"
              },
              "email_date": {
                "type": "string"
              }
            },
            "required": [
              "message_id",
              "attachment_id",
              "filename",
              "mimeType",
              "email_from",
              "email_subject",
              "email_date"
            ]
          }
        }
      }
    },
    {
      "id": "filter_pdf_attachments",
      "kind": "transform",
      "summary": "Keep only PDF attachments",
      "inputs": [
        "all_attachments"
      ],
      "output": "pdf_attachments",
      "transform": {
        "op": "filter",
        "input": "all_attachments",
        "description": "Filter to only PDF attachments by MIME type",
        "where": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "all_attachments",
            "field": "mimeType"
          },
          "comparator": "eq",
          "right": {
            "kind": "literal",
            "value": "application/pdf"
          }
        }
      }
    },
    {
      "id": "process_each_attachment",
      "kind": "loop",
      "summary": "Process each PDF attachment: download, extract fields, store in Drive, build digest row",
      "inputs": [
        "pdf_attachments"
      ],
      "output": "processed_attachments",
      "loop": {
        "over": "pdf_attachments",
        "item_ref": "attachment",
        "unit_of_work": {
          "entity": "attachment"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_attachments",
          "from_step_output": "attachment_row"
        },
        "do": [
          {
            "id": "download_attachment",
            "kind": "data_source",
            "summary": "Download the PDF attachment content from Gmail",
            "uses": [
              {
                "capability": "download",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "attachment"
            ],
            "output": "attachment_content",
            "source": {
              "domain": "email",
              "intent": "download"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "attachment",
                "field": "message_id"
              },
              "attachment_id": {
                "kind": "ref",
                "ref": "attachment",
                "field": "attachment_id"
              },
              "filename": {
                "kind": "ref",
                "ref": "attachment",
                "field": "filename"
              }
            }
          },
          {
            "id": "extract_invoice_fields",
            "kind": "extract",
            "summary": "Extract structured invoice/expense fields from the PDF attachment",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "inputs": [
              "attachment_content"
            ],
            "output": "extracted_fields",
            "extract": {
              "input": "attachment_content",
              "fields": [
                {
                  "name": "type",
                  "type": "string",
                  "required": true,
                  "description": "Document type: expense or invoice"
                },
                {
                  "name": "vendor",
                  "type": "string",
                  "required": true,
                  "description": "Vendor or merchant name"
                },
                {
                  "name": "date",
                  "type": "date",
                  "required": false,
                  "description": "Invoice or expense date"
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": false,
                  "description": "Total amount as a numeric value"
                },
                {
                  "name": "invoice_receipt_number",
                  "type": "string",
                  "required": false,
                  "description": "Invoice number or receipt number"
                },
                {
                  "name": "category",
                  "type": "string",
                  "required": false,
                  "description": "Expense category (e.g., Office Supplies, Travel, Software, Utilities)"
                }
              ],
              "deterministic": false,
              "content_hints": {
                "file_types": [
                  "pdf"
                ],
                "language": "en"
              }
            }
          },
          {
            "id": "create_vendor_folder",
            "kind": "artifact",
            "summary": "Get or create a subfolder named after the vendor under the base Drive folder",
            "uses": [
              {
                "capability": "upsert",
                "domain": "storage",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "extracted_fields"
            ],
            "output": "vendor_folder",
            "artifact": {
              "domain": "storage",
              "type": "folder",
              "strategy": "get_or_create",
              "name_hint": "vendor_name",
              "options": {
                "folder_name": {
                  "kind": "ref",
                  "ref": "extracted_fields",
                  "field": "vendor"
                },
                "parent_folder_id": {
                  "kind": "config",
                  "key": "drive_base_folder_id"
                }
              }
            }
          },
          {
            "id": "upload_pdf_to_drive",
            "kind": "deliver",
            "summary": "Upload the PDF attachment to the vendor's Google Drive subfolder",
            "uses": [
              {
                "capability": "upload",
                "domain": "storage",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "attachment_content",
              "vendor_folder",
              "attachment"
            ],
            "output": "uploaded_file",
            "deliver": {
              "domain": "storage",
              "intent": "upload_file",
              "input": "attachment_content",
              "destination": "vendor_folder",
              "mapping": [
                {
                  "from": {
                    "ref": "attachment_content",
                    "field": "data"
                  },
                  "to": "file_content"
                },
                {
                  "from": {
                    "ref": "attachment",
                    "field": "filename"
                  },
                  "to": "file_name"
                },
                {
                  "from": {
                    "ref": "vendor_folder",
                    "field": "folder_id"
                  },
                  "to": "folder_id"
                },
                {
                  "from": {
                    "kind": "literal",
                    "value": "application/pdf"
                  },
                  "to": "mime_type"
                }
              ]
            }
          },
          {
            "id": "build_attachment_row",
            "kind": "generate",
            "summary": "Build a digest table row combining extracted fields, email metadata, and Drive link",
            "uses": [
              {
                "capability": "generate",
                "domain": "internal"
              }
            ],
            "inputs": [
              "extracted_fields",
              "attachment",
              "uploaded_file"
            ],
            "output": "attachment_row",
            "generate": {
              "instruction": "Combine the extracted invoice/expense fields with the uploaded file's Drive link into a single structured row. Fields: type (from extracted_fields.type), vendor (from extracted_fields.vendor), date (from extracted_fields.date), amount (from extracted_fields.amount as numeric or null if missing), invoice_receipt_number (from extracted_fields.invoice_receipt_number), category (from extracted_fields.category), drive_link (from uploaded_file.web_view_link). Also include has_valid_amount as a boolean: true if amount is a valid number, false otherwise.",
              "format": "json",
              "outputs": [
                {
                  "name": "type",
                  "type": "string",
                  "description": "Document type: expense or invoice"
                },
                {
                  "name": "vendor",
                  "type": "string",
                  "description": "Vendor or merchant name"
                },
                {
                  "name": "date",
                  "type": "string",
                  "description": "Invoice or expense date"
                },
                {
                  "name": "amount",
                  "type": "number",
                  "description": "Total amount as numeric value, or null if not extractable"
                },
                {
                  "name": "invoice_receipt_number",
                  "type": "string",
                  "description": "Invoice or receipt number"
                },
                {
                  "name": "category",
                  "type": "string",
                  "description": "Expense category"
                },
                {
                  "name": "drive_link",
                  "type": "string",
                  "description": "Shareable Google Drive link to the stored PDF"
                },
                {
                  "name": "has_valid_amount",
                  "type": "boolean",
                  "description": "Whether the amount was successfully extracted as a valid number"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "ensure_sheet_tab",
      "kind": "artifact",
      "summary": "Get or create the target sheet tab in the Google Sheets spreadsheet",
      "uses": [
        {
          "capability": "upsert",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "sheet_tab",
      "artifact": {
        "domain": "table",
        "type": "sheet_tab",
        "strategy": "get_or_create",
        "name_hint": "Invoices",
        "options": {
          "spreadsheet_id": {
            "kind": "config",
            "key": "spreadsheet_id"
          },
          "tab_name": {
            "kind": "config",
            "key": "sheet_tab_name"
          }
        }
      }
    },
    {
      "id": "split_by_threshold",
      "kind": "aggregate",
      "summary": "Split processed attachments into those qualifying for Sheets (amount > 50 and valid) and all items for the digest",
      "inputs": [
        "processed_attachments"
      ],
      "output": "threshold_split",
      "aggregate": {
        "input": "processed_attachments",
        "outputs": [
          {
            "name": "sheets_qualifying_rows",
            "type": "subset",
            "where": {
              "op": "and",
              "conditions": [
                {
                  "op": "test",
                  "left": {
                    "kind": "ref",
                    "ref": "processed_attachments",
                    "field": "has_valid_amount"
                  },
                  "comparator": "eq",
                  "right": {
                    "kind": "literal",
                    "value": true
                  }
                },
                {
                  "op": "test",
                  "left": {
                    "kind": "ref",
                    "ref": "processed_attachments",
                    "field": "amount"
                  },
                  "comparator": "gt",
                  "right": {
                    "kind": "config",
                    "key": "amount_threshold"
                  }
                }
              ]
            }
          },
          {
            "name": "total_processed",
            "type": "count"
          },
          {
            "name": "qualifying_count",
            "type": "count",
            "of": "sheets_qualifying_rows"
          }
        ]
      }
    },
    {
      "id": "append_to_sheets",
      "kind": "deliver",
      "summary": "Append qualifying rows (amount > 50) to the Google Sheets spreadsheet",
      "uses": [
        {
          "capability": "append",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "inputs": [
        "sheets_qualifying_rows",
        "sheet_tab"
      ],
      "output": "sheets_result",
      "deliver": {
        "domain": "table",
        "intent": "append_rows",
        "input": "sheets_qualifying_rows",
        "destination": "sheet_tab",
        "mapping": [
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "type"
            },
            "to": "Type"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "vendor"
            },
            "to": "Vendor / merchant"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "date"
            },
            "to": "Date"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "amount"
            },
            "to": "Amount"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "invoice_receipt_number"
            },
            "to": "Invoice/receipt #"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "category"
            },
            "to": "Category"
          },
          {
            "from": {
              "ref": "sheets_qualifying_rows",
              "field": "drive_link"
            },
            "to": "Drive link"
          }
        ],
        "options": {
          "spreadsheet_id": {
            "kind": "config",
            "key": "spreadsheet_id"
          },
          "range": {
            "kind": "config",
            "key": "sheet_tab_name"
          }
        }
      }
    },
    {
      "id": "generate_digest_email",
      "kind": "generate",
      "summary": "Generate a single HTML digest email with a table of all processed attachments",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "inputs": [
        "processed_attachments",
        "total_processed",
        "qualifying_count"
      ],
      "output": "digest_email_content",
      "generate": {
        "input": "processed_attachments",
        "format": "html",
        "instruction": "Generate a professional HTML digest email summarizing all processed invoice/expense attachments. If the processed_attachments list is empty, produce a message stating 'No invoices or expenses were found in the last 7 days.' Otherwise, create an HTML table with columns: Type, Vendor / merchant, Date, Amount, Invoice/receipt #, Category, Drive link (as clickable hyperlink). Use professional styling with borders, header row background color (#4472C4 with white text), padding, and alternating row colors. Include a summary header showing total items processed (from total_processed) and how many were added to Google Sheets (from qualifying_count). The Drive link column should render as a clickable 'View' link. If amount is null or missing for a row, display 'N/A'. Add a footer note: 'Items with amount > 50 were automatically added to the tracking spreadsheet.'",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line for the digest"
          },
          {
            "name": "body",
            "type": "string",
            "description": "Full HTML body of the digest email"
          }
        ]
      }
    },
    {
      "id": "send_digest_email",
      "kind": "notify",
      "summary": "Send the digest email to the configured recipient",
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "inputs": [
        "digest_email_content"
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "digest_email_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "digest_email_content",
            "field": "body"
          },
          "format": "html"
        }
      }
    }
  ],
  "questions": [
    {
      "key": "sheet_tab_name",
      "question": "Which Google Sheet tab name should rows be appended to? The available options mentioned are 'Invoices' and 'Expenses'. Please choose one.",
      "default": "Invoices"
    }
  ],
  "meta": {
    "estimated_steps_per_attachment": 5,
    "services_used": [
      "google-mail",
      "google-drive",
      "google-sheets",
      "chatgpt-research"
    ],
    "idempotent_artifacts": [
      "vendor_folder",
      "sheet_tab"
    ]
  }
}