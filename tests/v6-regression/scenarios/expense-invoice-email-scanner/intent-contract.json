{
  "version": "intent.v1",
  "goal": "Scan Gmail for PDF attachments matching invoice/expense/bill subjects from the last 7 days, extract structured fields from each PDF, store each PDF in a per-vendor Google Drive subfolder under a base folder, append rows to Google Sheets only when amount > 50, and send a single digest email summarizing all items.",
  "unit_of_work": {
    "entity": "attachment",
    "parent_entity": "email"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query combining subject filter, attachment filter, and time window",
      "default": "subject:(Invoice OR Expenses OR Bill) has:attachment filename:pdf newer_than:7d"
    },
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send the digest summary to",
      "default": "meiribarak@gmail.com"
    },
    {
      "key": "drive_base_folder_id",
      "type": "string",
      "description": "Google Drive folder ID for the base storage location",
      "default": "1BoYgIIQj5QB6F0mWLzD_0-2pMLoxHVp-"
    },
    {
      "key": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID for appending invoice/expense rows",
      "default": "1RHLbBXzrKv24gNgp7a4Lr7RlMIrP9fjacfGWjhPAbOE"
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Name of the sheet tab to append rows into",
      "default": "Invoices"
    },
    {
      "key": "amount_threshold",
      "type": "number",
      "description": "Minimum amount threshold for appending rows to Google Sheets (in document currency)",
      "default": 50
    }
  ],
  "invariants": [
    "Every PDF attachment must be stored in Google Drive regardless of extracted amount",
    "Every processed item must appear in the digest email regardless of extracted amount",
    "Rows are appended to Google Sheets ONLY when extracted amount is greater than the threshold",
    "Items with missing or undetectable amounts are included in digest email and stored in Drive but NOT appended to Sheets",
    "Vendor subfolders are created idempotently under the base folder"
  ],
  "required_outcomes": [
    "All PDF attachments from matching emails are stored in per-vendor Drive subfolders",
    "A single digest email is sent with a table of all processed items",
    "Rows with amount > 50 are appended to the specified Google Sheet tab",
    "Each digest row includes: Type, Vendor/merchant, Date, Amount, Invoice/receipt #, Category, Drive link"
  ],
  "steps": [
    {
      "id": "search_emails",
      "kind": "data_source",
      "summary": "Search Gmail for emails with PDF attachments matching invoice/expense/bill subjects from the last 7 days",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "matching_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full",
        "include_attachments": true
      }
    },
    {
      "id": "flatten_attachments",
      "kind": "transform",
      "summary": "Extract attachment metadata from emails, preserving parent email context (sender, subject, date, message_id)",
      "inputs": [
        "matching_emails"
      ],
      "output": "all_attachments",
      "transform": {
        "op": "flatten",
        "input": "matching_emails",
        "description": "Flatten emails to individual attachment records, carrying parent email fields (id, from, subject, date) alongside each attachment (filename, mimeType, size, attachment_id, message_id)",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "email_id": {
                "type": "string"
              },
              "from": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "filename": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              },
              "size": {
                "type": "number"
              },
              "attachment_id": {
                "type": "string"
              },
              "message_id": {
                "type": "string"
              }
            },
            "required": [
              "email_id",
              "from",
              "subject",
              "date",
              "filename",
              "attachment_id",
              "message_id"
            ]
          }
        }
      }
    },
    {
      "id": "filter_pdf_attachments",
      "kind": "transform",
      "summary": "Keep only PDF attachments",
      "inputs": [
        "all_attachments"
      ],
      "output": "pdf_attachments",
      "transform": {
        "op": "filter",
        "input": "all_attachments",
        "description": "Filter to only PDF attachments by MIME type",
        "where": {
          "op": "test",
          "left": {
            "kind": "ref",
            "ref": "all_attachments",
            "field": "mimeType"
          },
          "comparator": "eq",
          "right": {
            "kind": "literal",
            "value": "application/pdf"
          }
        }
      }
    },
    {
      "id": "process_each_attachment",
      "kind": "loop",
      "summary": "For each PDF attachment: download content, extract fields, store in Drive per-vendor folder, build digest row, conditionally append to Sheets",
      "inputs": [
        "pdf_attachments"
      ],
      "output": "processed_items",
      "loop": {
        "over": "pdf_attachments",
        "item_ref": "current_attachment",
        "unit_of_work": {
          "entity": "attachment"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_items",
          "from_step_output": "digest_row"
        },
        "do": [
          {
            "id": "download_attachment",
            "kind": "data_source",
            "summary": "Download the PDF attachment content from Gmail",
            "uses": [
              {
                "capability": "download",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "current_attachment"
            ],
            "output": "attachment_content",
            "source": {
              "domain": "email",
              "intent": "download"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "current_attachment",
                "field": "message_id"
              },
              "attachment_id": {
                "kind": "ref",
                "ref": "current_attachment",
                "field": "attachment_id"
              },
              "filename": {
                "kind": "ref",
                "ref": "current_attachment",
                "field": "filename"
              }
            }
          },
          {
            "id": "extract_invoice_fields",
            "kind": "extract",
            "summary": "Extract structured invoice/expense fields from the PDF attachment",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "inputs": [
              "attachment_content"
            ],
            "output": "extracted_fields",
            "extract": {
              "input": "attachment_content",
              "fields": [
                {
                  "name": "type",
                  "type": "string",
                  "required": true,
                  "description": "Document type: 'Invoice' or 'Expense'"
                },
                {
                  "name": "vendor",
                  "type": "string",
                  "required": true,
                  "description": "Vendor or merchant name"
                },
                {
                  "name": "date",
                  "type": "date",
                  "required": false,
                  "description": "Invoice or expense date"
                },
                {
                  "name": "amount",
                  "type": "currency",
                  "required": false,
                  "description": "Total amount in the document's currency"
                },
                {
                  "name": "invoice_receipt_number",
                  "type": "string",
                  "required": false,
                  "description": "Invoice number or receipt number"
                },
                {
                  "name": "category",
                  "type": "string",
                  "required": false,
                  "description": "Expense category (e.g., Office Supplies, Travel, Software)"
                }
              ],
              "deterministic": false,
              "content_hints": {
                "file_types": [
                  "pdf"
                ],
                "language": "en"
              }
            }
          },
          {
            "id": "ensure_vendor_folder",
            "kind": "artifact",
            "summary": "Get or create a subfolder named after the vendor under the base Drive folder",
            "uses": [
              {
                "capability": "upsert",
                "domain": "storage",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "extracted_fields"
            ],
            "output": "vendor_folder",
            "artifact": {
              "domain": "storage",
              "type": "folder",
              "strategy": "get_or_create",
              "name_hint": "vendor_name",
              "options": {
                "folder_name": {
                  "kind": "ref",
                  "ref": "extracted_fields",
                  "field": "vendor"
                },
                "parent_folder_id": {
                  "kind": "config",
                  "key": "drive_base_folder_id"
                }
              }
            }
          },
          {
            "id": "upload_pdf_to_drive",
            "kind": "deliver",
            "summary": "Upload the PDF attachment to the vendor's Drive subfolder",
            "uses": [
              {
                "capability": "upload",
                "domain": "storage",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "attachment_content",
              "vendor_folder"
            ],
            "output": "uploaded_file",
            "deliver": {
              "domain": "storage",
              "intent": "upload_file",
              "input": "attachment_content",
              "destination": "vendor_folder",
              "mapping": [
                {
                  "from": {
                    "ref": "attachment_content",
                    "field": "data"
                  },
                  "to": "file_content"
                },
                {
                  "from": {
                    "ref": "attachment_content",
                    "field": "filename"
                  },
                  "to": "file_name"
                },
                {
                  "from": {
                    "ref": "attachment_content",
                    "field": "mimeType"
                  },
                  "to": "mime_type"
                },
                {
                  "from": {
                    "ref": "vendor_folder",
                    "field": "folder_id"
                  },
                  "to": "folder_id"
                }
              ]
            }
          },
          {
            "id": "build_digest_row",
            "kind": "transform",
            "summary": "Build a digest table row combining extracted fields with the Drive link from the uploaded file",
            "inputs": [
              "extracted_fields",
              "uploaded_file"
            ],
            "output": "digest_row",
            "transform": {
              "op": "with_fields",
              "input": "extracted_fields",
              "fields": [
                {
                  "name": "drive_link",
                  "expression": {
                    "kind": "ref",
                    "ref": "uploaded_file",
                    "field": "web_view_link"
                  }
                }
              ],
              "output_schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string"
                  },
                  "vendor": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string"
                  },
                  "amount": {
                    "type": "string"
                  },
                  "invoice_receipt_number": {
                    "type": "string"
                  },
                  "category": {
                    "type": "string"
                  },
                  "drive_link": {
                    "type": "string"
                  }
                },
                "required": [
                  "type",
                  "vendor",
                  "drive_link"
                ]
              }
            }
          },
          {
            "id": "check_amount_threshold",
            "kind": "decide",
            "summary": "If the extracted amount is greater than the threshold, append a row to Google Sheets",
            "inputs": [
              "digest_row"
            ],
            "decide": {
              "condition": {
                "op": "and",
                "conditions": [
                  {
                    "op": "test",
                    "left": {
                      "kind": "ref",
                      "ref": "digest_row",
                      "field": "amount"
                    },
                    "comparator": "exists"
                  },
                  {
                    "op": "test",
                    "left": {
                      "kind": "ref",
                      "ref": "digest_row",
                      "field": "amount"
                    },
                    "comparator": "gt",
                    "right": {
                      "kind": "config",
                      "key": "amount_threshold"
                    }
                  }
                ]
              },
              "then": [
                {
                  "id": "ensure_sheet_tab",
                  "kind": "artifact",
                  "summary": "Get or create the target sheet tab in the spreadsheet",
                  "uses": [
                    {
                      "capability": "upsert",
                      "domain": "table",
                      "preferences": {
                        "provider_family": "google"
                      }
                    }
                  ],
                  "output": "sheet_tab",
                  "artifact": {
                    "domain": "table",
                    "type": "sheet_tab",
                    "strategy": "get_or_create",
                    "name_hint": "sheet_tab",
                    "options": {
                      "spreadsheet_id": {
                        "kind": "config",
                        "key": "spreadsheet_id"
                      },
                      "tab_name": {
                        "kind": "config",
                        "key": "sheet_tab_name"
                      }
                    }
                  }
                },
                {
                  "id": "append_row_to_sheet",
                  "kind": "deliver",
                  "summary": "Append the digest row to the Google Sheet",
                  "uses": [
                    {
                      "capability": "append",
                      "domain": "table",
                      "preferences": {
                        "provider_family": "google"
                      }
                    }
                  ],
                  "inputs": [
                    "digest_row",
                    "sheet_tab"
                  ],
                  "output": "appended_row",
                  "deliver": {
                    "domain": "table",
                    "intent": "append_record",
                    "input": "digest_row",
                    "mapping": [
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "type"
                        },
                        "to": "0"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "vendor"
                        },
                        "to": "1"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "date"
                        },
                        "to": "2"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "amount"
                        },
                        "to": "3"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "invoice_receipt_number"
                        },
                        "to": "4"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "category"
                        },
                        "to": "5"
                      },
                      {
                        "from": {
                          "ref": "digest_row",
                          "field": "drive_link"
                        },
                        "to": "6"
                      }
                    ],
                    "options": {
                      "spreadsheet_id": {
                        "kind": "config",
                        "key": "spreadsheet_id"
                      },
                      "range": {
                        "kind": "config",
                        "key": "sheet_tab_name"
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "id": "generate_digest_email",
      "kind": "generate",
      "summary": "Generate a single HTML digest email body with a table of all processed items",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "inputs": [
        "processed_items"
      ],
      "output": "digest_email_content",
      "generate": {
        "input": "processed_items",
        "format": "html",
        "instruction": "Generate a professional HTML email body for an expense/invoice digest. If the processed_items array is empty, produce a message stating 'No invoices or expenses were found in the last 7 days.' If items exist, create an HTML table with columns: Type, Vendor / Merchant, Date, Amount, Invoice/Receipt #, Category, Drive Link (as a clickable hyperlink). Style the table with borders, a header row with a background color, and padding for readability. Include a brief introductory sentence summarizing the number of items found. Items with missing amounts should show 'N/A' in the Amount column and include a note that they were not added to the spreadsheet.",
        "reason": "Free-form HTML email body composition with conditional content (empty vs non-empty results) and styled table formatting — requires semantic composition, not rule-based",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line for the digest"
          },
          {
            "name": "body",
            "type": "string",
            "description": "Full HTML body of the digest email"
          }
        ]
      }
    },
    {
      "id": "send_digest_email",
      "kind": "notify",
      "summary": "Send the digest email to the configured recipient",
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "inputs": [
        "digest_email_content"
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "digest_email_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "digest_email_content",
            "field": "body"
          },
          "format": "html"
        }
      }
    }
  ],
  "confidence": 0.9,
  "meta": {
    "questions": [
      {
        "key": "sheet_tab_name",
        "question": "Which Google Sheet tab should rows be appended to? The available options mentioned are 'Invoices' and 'Expenses'. Currently defaulting to 'Invoices'.",
        "default": "Invoices"
      }
    ]
  }
}