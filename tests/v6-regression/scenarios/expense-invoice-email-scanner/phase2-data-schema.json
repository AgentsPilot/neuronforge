          "file_name": {
            "type": "string",
            "source": "plugin",
            "description": "Name of the uploaded file",
            "required": true
          },
          "file_size": {
            "type": "string",
            "source": "plugin",
            "description": "Size of the uploaded file"
          },
          "mime_type": {
            "type": "string",
            "source": "plugin",
