          },
          "uploaded_at": {
            "type": "string",
            "source": "plugin",
            "description": "Timestamp when file was uploaded (ISO 8601)"
          }
        }
      },
      "scope": "loop",
      "produced_by": "upload_pdf_to_drive",
      "consumed_by": [
        "build_digest_row"
      ]
    },
    "digest_row": {
