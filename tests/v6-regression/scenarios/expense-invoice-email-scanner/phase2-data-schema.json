            "source": "plugin",
            "description": "Name of the sheet tab",
            "required": true
          },
          "tab_name": {
            "type": "string",
            "source": "plugin",
            "description": "Name of the sheet tab (alias for sheet_name)",
            "required": true
          },
          "existed": {
            "type": "boolean",
