            "description": "Gmail labels",
            "items": {
              "type": "string",
              "source": "plugin"
            }
          },
          "body": {
            "type": "string",
            "source": "plugin",
            "description": "Email body text (NOTE: Usually empty in search results - use 'snippet' field instead for email content)"
          },
          "attachments": {
            "type": "array",
            "source": "plugin",
            "description": "Attachment metadata (if include_attachments=true). Each item contains: filename, mimeType, size, attachment_id (use with get_email_attachment), message_id (email ID)",
            "items": {
              "type": "object",
              "source": "plugin",
              "semantic_type": "file_attachment",
              "properties": {
                "filename": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Attachment filename"
                },
                "mimeType": {
                  "type": "string",
                  "source": "plugin",
                  "description": "MIME type (application/pdf, image/png, etc.)"
                },
                "size": {
                  "type": "number",
                  "source": "plugin",
                  "description": "File size in bytes"
                },
                "attachment_id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Attachment ID (required for get_email_attachment action)"
                },
                "message_id": {
                  "type": "string",
                  "source": "plugin",
                  "description": "Email message ID (required for get_email_attachment action)"
                }
              }
            }
          }
        }
      }
    },
    "id": "step2",
    "_on_empty": "warn",
    "name": "Filter emails to only those containing delivery update or shipment keywords in subject or body"
  },
  {
    "step_id": "step3",
    "type": "ai_processing",
    "input": "{{delivery_emails}}",
    "prompt": "For each email in the delivery_emails array, analyze the email body and subject to extract: 1) The package/tracking number, 2) A list of product names included in the shipment, 3) The current delivery status (e.g., 'Shipped', 'In Transit', 'Out for Delivery', 'Delivered'), 4) The estimated delivery date if available. Also preserve the email id for downstream processing. If a field cannot be found, use 'N/A'.",
    "description": "Extract package number, list of products, and delivery summary (status and estimated delivery date) from each AliExpress delivery email",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "deliveries": {
            "type": "array",
            "description": "One entry per delivery email with extracted details"
          }
        },
        "required": [
          "deliveries"
        ]
      },
      "type": "generate",
      "instruction": "For each email in the delivery_emails array, analyze the email body and subject to extract: 1) The package/tracking number, 2) A list of product names included in the shipment, 3) The current delivery status (e.g., 'Shipped', 'In Transit', 'Out for Delivery', 'Delivered'), 4) The estimated delivery date if available. Also preserve the email id for downstream processing. If a field cannot be found, use 'N/A'.",
      "input": "{{delivery_emails}}"
    },
    "output_variable": "extracted_deliveries",
    "output_schema": {
      "type": "object",
      "properties": {
        "deliveries": {
          "type": "array",
          "source": "ai_declared",
