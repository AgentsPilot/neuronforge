  {
    "step_id": "step5",
    "type": "action",
    "description": "Send the AliExpress delivery summary email to the user",
    "plugin": "google-mail",
    "id": "step5",
    "params": {
      "recipients": {
        "to": [
          "{{input.recipient_email}}"
        ]
      },
      "content": {
        "subject": "{{input.summary_email_subject}}",
        "html_body": "{{summary_email_content.html_body}}"
      }
    },
    "name": "Send the AliExpress delivery summary email to the user",
    "action": "send_email"
  },
  {
    "step_id": "step6",
    "type": "scatter_gather",
    "description": "Loop over delivery_emails",
    "scatter": {
      "input": "{{delivery_emails}}",
      "steps": [
        {
          "step_id": "step7",
          "type": "action",
          "description": "Mark the email as read and add the shopping label",
          "plugin": "google-mail",
          "output_variable": "label_result",
          "output_schema": {
            "type": "object",
            "source": "plugin",
            "description": "Result of the email modification",
            "properties": {
              "message_id": {
                "type": "string",
                "source": "plugin",
                "description": "The modified message ID",
                "required": true
              },
              "labels_added": {
                "type": "array",
                "source": "plugin",
                "description": "Labels that were added",
                "items": {
                  "type": "string",
                  "source": "plugin"
                },
                "required": true
              },
              "labels_removed": {
                "type": "array",
                "source": "plugin",
                "description": "Labels that were removed",
                "items": {
                  "type": "string",
                  "source": "plugin"
                },
                "required": true
              }
            }
          },
          "id": "step7",
          "params": {
            "message_id": "{{current_email.id}}",
            "add_labels": [
              "{{input.shopping_label}}"
            ],
            "mark_read": true
          },
          "name": "Mark the email as read and add the shopping label",
          "action": "modify_email"
        }
      ],
      "itemVariable": "current_email"
    },
    "gather": {
      "operation": "collect"
    },
    "output_variable": "labeled_emails",
    "id": "step6",
    "name": "Loop over delivery_emails"
  }
]