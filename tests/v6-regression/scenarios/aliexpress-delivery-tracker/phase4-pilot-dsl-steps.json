  {
    "step_id": "step4",
    "type": "ai_processing",
    "input": "{{extracted_deliveries}}",
    "prompt": "Create a professional HTML email body. Start with a brief greeting and introductory sentence like 'Here is a summary of your latest AliExpress delivery updates:'. Then create an HTML table with the following columns: Package Number, Products, Delivery Status, Estimated Delivery Date. Style the table with borders, a colored header row (e.g., light blue background), padding, and clean professional formatting. Populate the table rows from the deliveries array in extracted_deliveries. If there are no deliveries, show a message saying 'No AliExpress delivery updates found.' End with a brief closing line.",
    "description": "Compose an HTML email body with a brief introductory message and an HTML summary table of all AliExpress delivery updates",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "html_body": {
            "type": "string",
            "description": "Complete HTML email body with summary table"
          }
        },
        "required": [
          "html_body"
        ]
      },
      "type": "generate",
      "instruction": "Create a professional HTML email body. Start with a brief greeting and introductory sentence like 'Here is a summary of your latest AliExpress delivery updates:'. Then create an HTML table with the following columns: Package Number, Products, Delivery Status, Estimated Delivery Date. Style the table with borders, a colored header row (e.g., light blue background), padding, and clean professional formatting. Populate the table rows from the deliveries array in extracted_deliveries. If there are no deliveries, show a message saying 'No AliExpress delivery updates found.' End with a brief closing line.",
      "input": "{{extracted_deliveries}}"
    },
    "output_variable": "summary_email_content",
    "output_schema": {
      "type": "object",
      "properties": {
        "html_body": {
          "type": "string",
          "source": "ai_declared",
          "description": "Complete HTML email body with summary table"
        }
      },
      "source": "ai_declared"
