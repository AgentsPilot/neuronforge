{
  "version": "intent.v1",
  "goal": "Search Gmail for AliExpress delivery updates, extract package details, consolidate into HTML summary table, and email to user",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "search_results"
  },
  "config": [
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send the summary to",
      "default": "meiribarak@gmail.com"
    },
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query for AliExpress delivery updates",
      "default": "from:transaction@notice.aliexpress.com (subject:(delivery update) OR subject:(shipment) OR delivery update OR shipment)"
    },
    {
      "key": "max_emails",
      "type": "number",
      "description": "Maximum number of emails to retrieve",
      "default": 50
    }
  ],
  "steps": [
    {
      "id": "search_aliexpress_emails",
      "kind": "data_source",
      "summary": "Search Gmail for AliExpress delivery update emails",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "aliexpress_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full"
      }
    },
    {
      "id": "extract_package_details",
      "kind": "loop",
      "summary": "Extract package number, products, and delivery summary from each email",
      "inputs": [
        "aliexpress_emails"
      ],
      "output": "extracted_packages",
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "unit_of_work": {
          "entity": "email"
        },
        "collect": {
          "enabled": true,
          "collect_as": "extracted_packages",
          "from_step_output": "package_info"
        },
        "do": [
          {
            "id": "extract_fields",
            "kind": "extract",
            "summary": "Extract package number, products list, and delivery summary from email body",
            "inputs": [
              "email"
            ],
            "output": "package_info",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "extract": {
              "input": "email",
              "fields": [
                {
                  "name": "package_number",
                  "type": "string",
                  "required": true,
                  "description": "Tracking or package number"
                },
                {
                  "name": "products",
                  "type": "array",
                  "required": true,
                  "description": "List of product names or descriptions in the shipment"
                },
                {
                  "name": "delivery_status",
                  "type": "string",
                  "required": true,
                  "description": "Current delivery status (e.g., shipped, in transit, out for delivery)"
                },
                {
                  "name": "estimated_delivery_date",
                  "type": "date",
                  "required": false,
                  "description": "Estimated delivery date if available"
                }
              ],
              "deterministic": false
            }
          }
        ]
      }
    },
    {
      "id": "generate_html_summary",
      "kind": "generate",
      "summary": "Create HTML table summarizing all package deliveries",
      "inputs": [
        "extracted_packages"
      ],
      "output": "summary_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "extracted_packages",
        "format": "html",
        "instruction": "Create a professional HTML table with the following structure: columns for Package Number, Products (comma-separated list), Delivery Status, and Estimated Delivery Date. Include proper table styling with borders, header row background color, and padding for readability. Add a brief introductory message above the table: 'Here is your AliExpress delivery updates summary:'",
        "outputs": [
          {
            "name": "html_body",
            "type": "string",
            "description": "Complete HTML content with message and table"
          }
        ]
      }
    },
    {
      "id": "send_summary_email",
      "kind": "notify",
      "summary": "Send summary email to user",
      "inputs": [
        "summary_content"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "literal",
            "value": "AliExpress Delivery Updates Summary"
          },
          "body": {
            "kind": "ref",
            "ref": "summary_content",
            "field": "html_body"
          },
          "format": "html"
        }
      }
    },
    {
      "id": "mark_emails_read",
      "kind": "loop",
      "summary": "Mark all AliExpress delivery emails as read",
      "inputs": [
        "aliexpress_emails"
      ],
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "do": [
          {
            "id": "mark_read",
            "kind": "data_source",
            "summary": "Mark email as read",
            "inputs": [
              "email"
            ],
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "source": {
              "domain": "email",
              "intent": "modify"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "email",
                "field": "id"
              },
              "mark_read": {
                "kind": "literal",
                "value": true
              }
            }
          }
        ]
      }
    },
    {
      "id": "move_to_shopping_label",
      "kind": "loop",
      "summary": "Move all AliExpress delivery emails to shopping label",
      "inputs": [
        "aliexpress_emails"
      ],
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "do": [
          {
            "id": "apply_label",
            "kind": "data_source",
            "summary": "Apply shopping label to email",
            "inputs": [
              "email"
            ],
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "source": {
              "domain": "email",
              "intent": "modify"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "email",
                "field": "id"
              },
              "add_labels": {
                "kind": "literal",
                "value": [
                  "shopping"
                ]
              }
            }
          }
        ]
      }
    }
  ],
  "confidence": 0.95
}