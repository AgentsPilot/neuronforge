{
  "version": "intent.v1",
  "goal": "Search Gmail for AliExpress delivery updates, extract package details, consolidate into HTML summary table, and email to user",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "search_results"
  },
  "config": [
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send the summary to",
      "default": "meiribarak@gmail.com"
    },
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query for AliExpress delivery updates",
      "default": "from:transaction@notice.aliexpress.com (subject:(delivery update) OR subject:(shipment) OR delivery update OR shipment)"
    },
    {
      "key": "max_emails",
      "type": "number",
      "description": "Maximum number of emails to retrieve",
      "default": 50
    },
    {
      "key": "shopping_label",
      "type": "string",
      "description": "Gmail label to apply to processed emails",
      "default": "shopping"
    }
  ],
  "steps": [
    {
      "id": "search_aliexpress_emails",
      "kind": "data_source",
      "summary": "Search Gmail for AliExpress delivery update emails",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "aliexpress_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 50,
        "include_content": "full",
        "include_attachments": false
      }
    },
    {
      "id": "extract_delivery_info",
      "kind": "loop",
      "summary": "Extract package details from each email",
      "inputs": [
        "aliexpress_emails"
      ],
      "output": "extracted_deliveries",
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "unit_of_work": {
          "entity": "email"
        },
        "collect": {
          "enabled": true,
          "collect_as": "extracted_deliveries",
          "from_step_output": "delivery_data"
        },
        "do": [
          {
            "id": "extract_fields",
            "kind": "extract",
            "summary": "Extract package number, products, and delivery summary from email content",
            "inputs": [
              "email"
            ],
            "output": "delivery_data",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "extract": {
              "input": "email",
              "fields": [
                {
                  "name": "package_number",
                  "type": "string",
                  "required": true,
                  "description": "Tracking or package number"
                },
                {
                  "name": "products",
                  "type": "array",
                  "required": true,
                  "description": "List of product names or descriptions"
                },
                {
                  "name": "delivery_status",
                  "type": "string",
                  "required": true,
                  "description": "Current delivery status (e.g., shipped, in transit, delivered)"
                },
                {
                  "name": "estimated_delivery_date",
                  "type": "date",
                  "required": false,
                  "description": "Estimated delivery date if available"
                }
              ],
              "deterministic": false
            }
          }
        ]
      }
    },
    {
      "id": "generate_html_table",
      "kind": "generate",
      "summary": "Generate HTML table with delivery summary",
      "inputs": [
        "extracted_deliveries"
      ],
      "output": "summary_table",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "extracted_deliveries",
        "format": "html",
        "instruction": "Create a professional HTML table with the following structure: columns for Package Number, Products (comma-separated list), Delivery Status, and Estimated Delivery Date. Include proper table styling with borders, header row background color, and cell padding. Format dates in a readable format (e.g., 'Jan 15, 2024'). If estimated delivery date is missing, show 'N/A'.",
        "outputs": [
          {
            "name": "html_content",
            "type": "string",
            "description": "Complete HTML table with delivery information"
          }
        ]
      }
    },
    {
      "id": "compose_email_body",
      "kind": "generate",
      "summary": "Compose email body with message and HTML table",
      "inputs": [
        "summary_table"
      ],
      "output": "email_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "summary_table",
        "format": "html",
        "instruction": "Create an HTML email body that includes: 1) A brief greeting and introductory message explaining this is a summary of AliExpress delivery updates, 2) The HTML table from the input, 3) A closing message. Use professional email formatting with proper spacing and styling.",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line"
          },
          {
            "name": "body",
            "type": "string",
            "description": "Complete HTML email body"
          }
        ]
      }
    },
    {
      "id": "send_summary_email",
      "kind": "notify",
      "summary": "Send delivery summary email to user",
      "inputs": [
        "email_content"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "email_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "email_content",
            "field": "body"
          },
          "format": "html"
        }
      }
    },
    {
      "id": "mark_emails_read",
      "kind": "loop",
      "summary": "Mark all processed emails as read",
      "inputs": [
        "aliexpress_emails"
      ],
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "do": [
          {
            "id": "mark_read",
            "kind": "data_source",
            "summary": "Mark email as read",
            "inputs": [
              "email"
            ],
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "source": {
              "domain": "email",
              "intent": "modify"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "email",
                "field": "message_id"
              },
              "mark_read": {
                "kind": "literal",
                "value": true
              }
            }
          }
        ]
      }
    },
    {
      "id": "apply_shopping_label",
      "kind": "loop",
      "summary": "Apply shopping label to all processed emails",
      "inputs": [
        "aliexpress_emails"
      ],
      "loop": {
        "over": "aliexpress_emails",
        "item_ref": "email",
        "do": [
          {
            "id": "add_label",
            "kind": "data_source",
            "summary": "Add shopping label to email",
            "inputs": [
              "email"
            ],
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "source": {
              "domain": "email",
              "intent": "modify"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "email",
                "field": "message_id"
              },
              "add_labels": {
                "kind": "computed",
                "op": "array",
                "args": [
                  {
                    "kind": "config",
                    "key": "shopping_label"
                  }
                ]
              }
            }
          }
        ]
      }
    }
  ],
  "required_outcomes": [
    "Email summary sent to user with AliExpress delivery updates",
    "All processed emails marked as read",
    "All processed emails labeled with 'shopping' tag"
  ],
  "confidence": 0.95
}