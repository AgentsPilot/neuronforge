    "labeled_emails": {
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "source": "plugin",
          "description": "Result of the email modification",
          "properties": {
            "message_id": {
              "type": "string",
              "source": "plugin",
              "description": "The modified message ID",
              "required": true
            },
            "labels_added": {
