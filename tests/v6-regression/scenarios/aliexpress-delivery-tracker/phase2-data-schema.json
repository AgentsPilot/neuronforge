                  }
                }
              }
            }
          }
        }
      },
      "scope": "global",
      "produced_by": "filter_delivery_keywords",
      "consumed_by": [
        "extract_delivery_details",
        "mark_and_label_emails"
      ]
    },
    "extracted_deliveries": {
      "schema": {
        "type": "object",
        "properties": {
          "deliveries": {
            "type": "array",
            "source": "ai_declared",
            "description": "One entry per delivery email with extracted details",
            "items": {
              "type": "object",
              "source": "ai_declared",
              "properties": {
                "email_id": {
                  "type": "string",
                  "source": "ai_declared",
                  "description": "Gmail message ID for downstream labeling/marking"
                },
                "package_number": {
                  "type": "string",
                  "source": "ai_declared",
                  "description": "Package or tracking number"
                },
                "products": {
                  "type": "string",
                  "source": "ai_declared",
                  "description": "Comma-separated list of product names in the shipment"
                },
                "delivery_status": {
                  "type": "string",
                  "source": "ai_declared",
                  "description": "Current delivery status (Shipped, In Transit, Out for Delivery, Delivered, etc.)"
                },
                "estimated_delivery_date": {
                  "type": "string",
                  "source": "ai_declared",
                  "description": "Estimated delivery date if available, otherwise N/A"
                }
              }
            }
          }
        },
        "source": "ai_declared"
      },
      "scope": "global",
      "produced_by": "extract_delivery_details",
      "consumed_by": [
        "compose_summary_email"
      ]
    },
    "summary_email_content": {
      "schema": {
        "type": "object",
        "properties": {
          "html_body": {
            "type": "string",
            "source": "ai_declared",
            "description": "Complete HTML email body with summary table"
