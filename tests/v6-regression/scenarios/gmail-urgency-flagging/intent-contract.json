{
  "version": "intent.v1",
  "goal": "Scan Gmail Inbox for urgent emails based on keywords, mark them as important, apply tracking label, and send summary email",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "inbox"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find Inbox emails excluding tracking label",
      "default": "in:inbox -label:AgentsPilot"
    },
    {
      "key": "max_emails",
      "type": "number",
      "description": "Maximum number of emails to retrieve per search",
      "default": 100
    },
    {
      "key": "urgency_keywords",
      "type": "json",
      "description": "List of keywords that indicate urgency",
      "default": [
        "today",
        "urgent",
        "immediately",
        "now",
        "sensitive"
      ]
    },
    {
      "key": "tracking_label",
      "type": "string",
      "description": "Gmail label to apply to processed emails",
      "default": "AgentsPilot"
    },
    {
      "key": "recipient_email",
      "type": "string",
      "description": "Email address to send summary to",
      "default": "meiribarak@gmail.com"
    }
  ],
  "steps": [
    {
      "id": "search_inbox_emails",
      "kind": "data_source",
      "summary": "Search Gmail Inbox for emails excluding already-processed ones",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "inbox_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "payload": {
        "query": {
          "kind": "config",
          "key": "gmail_search_query"
        },
        "max_results": {
          "kind": "config",
          "key": "max_emails"
        },
        "content_level": {
          "kind": "literal",
          "value": "full"
        }
      }
    },
    {
      "id": "classify_urgency",
      "kind": "classify",
      "summary": "Classify emails as urgent or not urgent based on keyword presence in subject or body",
      "inputs": [
        "inbox_emails"
      ],
      "output": "classified_emails",
      "classify": {
        "input": "inbox_emails",
        "labels": [
          "urgent",
          "not_urgent"
        ],
        "multi_label": false,
        "output_field": "urgency_classification"
      }
    },
    {
      "id": "split_by_urgency",
      "kind": "aggregate",
      "summary": "Split emails into urgent and non-urgent subsets",
      "inputs": [
        "classified_emails"
      ],
      "output": "urgency_subsets",
      "aggregate": {
        "input": "classified_emails",
        "outputs": [
          {
            "name": "urgent_emails",
            "type": "subset",
            "where": {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "classified_emails",
                "field": "urgency_classification"
              },
              "comparator": "eq",
              "right": {
                "kind": "literal",
                "value": "urgent"
              }
            }
          },
          {
            "name": "urgent_count",
            "type": "count",
            "of": "urgent_emails"
          }
        ]
      }
    },
    {
      "id": "process_urgent_emails",
      "kind": "loop",
      "summary": "Mark each urgent email as important and apply tracking label",
      "inputs": [
        "urgent_emails"
      ],
      "output": "processed_urgent_emails",
      "loop": {
        "over": "urgent_emails",
        "item_ref": "urgent_email",
        "unit_of_work": {
          "entity": "email"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_urgent_emails",
          "from_step_output": "marked_email"
        },
        "do": [
          {
            "id": "mark_important_and_label",
            "kind": "data_source",
            "summary": "Mark email as important and apply tracking label",
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "inputs": [
              "urgent_email"
            ],
            "output": "marked_email",
            "source": {
              "domain": "email",
              "intent": "modify"
            },
            "payload": {
              "message_id": {
                "kind": "ref",
                "ref": "urgent_email",
                "field": "id"
              },
              "mark_important": {
                "kind": "literal",
                "value": true
              },
              "add_labels": {
                "kind": "computed",
                "op": "array",
                "args": [
                  {
                    "kind": "config",
                    "key": "tracking_label"
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "id": "prepare_summary_data",
      "kind": "transform",
      "summary": "Extract relevant fields from processed emails for summary",
      "inputs": [
        "processed_urgent_emails"
      ],
      "output": "summary_data",
      "transform": {
        "op": "map",
        "input": "processed_urgent_emails",
        "mapping": [
          {
            "to": "sender",
            "from": "from"
          },
          {
            "to": "subject",
            "from": "subject"
          },
          {
            "to": "received_date",
            "from": "date"
          },
          {
            "to": "matched_keywords",
            "from": "urgency_classification"
          }
        ],
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              },
              "received_date": {
                "type": "string"
              },
              "matched_keywords": {
                "type": "string"
              }
            },
            "required": [
              "sender",
              "subject",
              "received_date"
            ]
          }
        }
      }
    },
    {
      "id": "generate_summary_email",
      "kind": "generate",
      "summary": "Generate summary email content with list of urgent emails marked",
      "inputs": [
        "summary_data",
        "urgent_count"
      ],
      "output": "summary_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "format": "html",
        "instruction": "Create an email summary of urgent emails that were marked as important. If urgent_count is 0, state 'No urgent emails were found in this scan.' Otherwise, create a formatted list showing: sender, subject, received date/time, and matched urgency keywords for each email in summary_data. Use clear formatting with headers and bullet points.",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line"
          },
          {
            "name": "body",
            "type": "string",
            "description": "HTML-formatted email body with summary"
          }
        ]
      }
    },
    {
      "id": "send_summary_email",
      "kind": "notify",
      "summary": "Send summary email to user",
      "inputs": [
        "summary_content"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "recipient_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "summary_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "summary_content",
            "field": "body"
          },
          "format": "html"
        }
      }
    }
  ],
  "confidence": 0.95
}