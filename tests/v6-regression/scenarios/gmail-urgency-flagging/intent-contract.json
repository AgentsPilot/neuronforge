{
  "version": "intent.v1",
  "goal": "Scan Gmail inbox for emails from the last 30 days, flag urgent emails based on keyword matching in subject/body, mark them as important, apply tracking label, and email a summary of actions taken.",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "inbox"
  },
  "config": [
    {
      "key": "gmail_search_query",
      "type": "string",
      "description": "Gmail search query to find candidate emails excluding already-processed ones",
      "default": "in:inbox -label:AgentsPilot newer_than:30d"
    },
    {
      "key": "urgency_keywords",
      "type": "json",
      "description": "List of keywords/phrases to check for urgency (case-insensitive)",
      "default": [
        "today",
        "urgent",
        "immediately",
        "now",
        "sensitive"
      ]
    },
    {
      "key": "tracking_label_name",
      "type": "string",
      "description": "Gmail label to apply to processed urgent emails to prevent re-processing",
      "default": "AgentsPilot"
    },
    {
      "key": "summary_recipient",
      "type": "string",
      "description": "Email address to send the summary report to",
      "default": "meiribarak@gmail.com"
    }
  ],
  "invariants": [
    {
      "description": "Only emails matching the search query and NOT already labeled with the tracking label are processed"
    },
    {
      "description": "Non-urgent emails are left completely unchanged"
    },
    {
      "description": "Urgent emails are marked important AND labeled with the tracking label"
    },
    {
      "description": "A summary email is always sent, even if no urgent emails were found"
    }
  ],
  "required_outcomes": [
    "All urgent emails in the search results are marked as important",
    "All urgent emails have the tracking label applied",
    "A summary email is sent to the configured recipient listing all flagged emails or stating none were found"
  ],
  "steps": [
    {
      "id": "search_inbox_emails",
      "kind": "data_source",
      "summary": "Search Gmail inbox for emails from the last 30 days that have not yet been processed (excluding tracking label)",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "candidate_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": {
        "kind": "config",
        "key": "gmail_search_query"
      },
      "retrieval": {
        "max_results": 100,
        "include_content": "full",
        "include_attachments": false
      }
    },
    {
      "id": "classify_urgency",
      "kind": "classify",
      "summary": "Classify each email as urgent or not-urgent by checking if subject or body contains any of the configured urgency keywords (case-insensitive)",
      "inputs": [
        "candidate_emails"
      ],
      "output": "classified_emails",
      "classify": {
        "input": "candidate_emails",
        "labels": [
          "urgent",
          "not_urgent"
        ],
        "multi_label": false,
        "output_field": "urgency_classification"
      },
      "payload": {
        "classification_method": {
          "kind": "literal",
          "value": "keyword_match"
        },
        "keywords": {
          "kind": "config",
          "key": "urgency_keywords"
        },
        "fields_to_check": {
          "kind": "literal",
          "value": [
            "subject",
            "body",
            "snippet"
          ]
        },
        "match_rule": {
          "kind": "literal",
          "value": "case_insensitive_contains_any"
        }
      }
    },
    {
      "id": "split_by_urgency",
      "kind": "aggregate",
      "summary": "Split classified emails into urgent and not-urgent subsets",
      "inputs": [
        "classified_emails"
      ],
      "output": "urgency_split",
      "aggregate": {
        "input": "classified_emails",
        "outputs": [
          {
            "name": "urgent_emails",
            "type": "subset",
            "where": {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "classified_emails",
                "field": "urgency_classification"
              },
              "comparator": "eq",
              "right": {
                "kind": "literal",
                "value": "urgent"
              }
            }
          },
          {
            "name": "urgent_count",
            "type": "count",
            "of": "urgent_emails"
          }
        ]
      }
    },
    {
      "id": "process_urgent_emails",
      "kind": "loop",
      "summary": "For each urgent email, mark as important and apply the tracking label",
      "inputs": [
        "urgent_emails"
      ],
      "output": "processed_urgent_emails",
      "loop": {
        "over": "urgent_emails",
        "item_ref": "urgent_email",
        "unit_of_work": {
          "entity": "email"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_urgent_emails",
          "from_step_output": "label_result"
        },
        "do": [
          {
            "id": "mark_important",
            "kind": "deliver",
            "summary": "Mark the urgent email as important in Gmail",
            "inputs": [
              "urgent_email"
            ],
            "output": "importance_result",
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "email",
              "intent": "modify_labels",
              "input": "urgent_email",
              "mapping": [
                {
                  "from": {
                    "ref": "urgent_email",
                    "field": "id"
                  },
                  "to": "message_id"
                }
              ],
              "options": {
                "mark_important": {
                  "kind": "literal",
                  "value": true
                }
              }
            }
          },
          {
            "id": "apply_tracking_label",
            "kind": "deliver",
            "summary": "Apply the AgentsPilot tracking label to the urgent email so it is excluded from future runs",
            "inputs": [
              "urgent_email"
            ],
            "output": "label_result",
            "uses": [
              {
                "capability": "modify",
                "domain": "email",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "email",
              "intent": "modify_labels",
              "input": "urgent_email",
              "mapping": [
                {
                  "from": {
                    "ref": "urgent_email",
                    "field": "id"
                  },
                  "to": "message_id"
                }
              ],
              "options": {
                "add_labels": [
                  {
                    "kind": "config",
                    "key": "tracking_label_name"
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "id": "prepare_summary_rows",
      "kind": "transform",
      "summary": "Map urgent emails to summary rows with sender, subject, date, and matched keyword info",
      "inputs": [
        "urgent_emails"
      ],
      "output": "summary_rows",
      "transform": {
        "op": "map",
        "input": "urgent_emails",
        "mapping": [
          {
            "to": "sender",
            "from": "from"
          },
          {
            "to": "subject",
            "from": "subject"
          },
          {
            "to": "received_date",
            "from": "date"
          },
          {
            "to": "urgency_classification",
            "from": "urgency_classification"
          }
        ],
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": {
                "type": "string"
              },
              "subject": {
                "type": "string"
              },
              "received_date": {
                "type": "string"
              },
              "urgency_classification": {
                "type": "string"
              }
            },
            "required": [
              "sender",
              "subject",
              "received_date"
            ]
          }
        }
      }
    },
    {
      "id": "generate_summary_email",
      "kind": "generate",
      "summary": "Generate an HTML summary email body listing all urgent emails that were flagged, or stating none were found",
      "inputs": [
        "summary_rows",
        "urgent_count"
      ],
      "output": "summary_email_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "input": "summary_rows",
        "format": "html",
        "reason": "Free-form HTML email body composition with conditional content (no-results vs results table) and professional styling — requires semantic composition, not a deterministic template",
        "instruction": "Generate a professional HTML email summarizing the urgent emails that were flagged in this run. Use the urgent_count to determine the content: If urgent_count is 0, write a clear message stating 'No urgent emails were found in this scan.' If urgent_count > 0, create an HTML table with columns: Sender, Subject, Received Date, and Matched Keywords. Use the summary_rows data to populate the table. Each row should show the sender (from field), subject, received_date, and urgency_classification. Style the table with borders, a colored header row (#4a90d9 background, white text), and alternating row colors for readability. Add padding to cells. Include a header line like 'Urgent Email Summary — [count] email(s) flagged as important'. At the bottom, add a note explaining that these emails were marked as Important and labeled AgentsPilot in Gmail.",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line for the summary"
          },
          {
            "name": "body",
            "type": "string",
            "description": "Full HTML body of the summary email"
          }
        ]
      }
    },
    {
      "id": "send_summary_email",
      "kind": "notify",
      "summary": "Send the urgency summary email to the configured recipient",
      "inputs": [
        "summary_email_content"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "summary_recipient"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "summary_email_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "summary_email_content",
            "field": "body"
          },
          "format": "html"
        }
      }
    }
  ],
  "confidence": 0.92,
  "meta": {
    "estimated_steps": 7,
    "uses_loop": true,
    "idempotent_tracking": true,
    "tracking_mechanism": "Gmail label exclusion in search query prevents re-processing"
  }
}