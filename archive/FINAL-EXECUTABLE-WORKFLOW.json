{
  "workflow_name": "High-Quality Lead Checker + Sales Follow-up",
  "workflow_version": "1.0",
  "generated_by": "V6 Pipeline",
  "generation_date": "2026-03-05",
  "status": "✅ 100% EXECUTABLE",

  "runtime_config": {
    "description": "These values will be provided by the user at runtime",
    "required_parameters": {
      "google_sheet_id": {
        "type": "string",
        "description": "Google Sheet ID containing lead data",
        "example": "1LKhXUzV9xh-q1NZJKHDjJWPdwFHXalV6amwLJwX8JkE"
      },
      "sheet_tab_name": {
        "type": "string",
        "description": "Sheet tab name to read leads from",
        "example": "Leads"
      },
      "lead_score_column": {
        "type": "string",
        "description": "Column name containing numeric lead score",
        "example": "stage",
        "note": "This is the actual column name in your spreadsheet"
      },
      "score_threshold": {
        "type": "number",
        "description": "Minimum score for high-quality classification",
        "example": 4
      },
      "salesperson_email_mapping": {
        "type": "json",
        "description": "Optional mapping from sales person names to email addresses",
        "example": {
          "John Doe": "john@example.com",
          "Jane Smith": "jane@example.com"
        },
        "required": false
      },
      "user_email": {
        "type": "string",
        "description": "Email address for unresolved leads notifications",
        "default": "avital.livovsky@gmail.com"
      }
    }
  },

  "execution_flow": {
    "description": "Step-by-step execution flow with data dependencies",
    "steps": [
      {
        "step": 1,
        "id": "step1",
        "action": "Fetch lead rows from Google Sheets",
        "type": "action",
        "plugin": "google-sheets.read_range",
        "inputs": {
          "spreadsheet_id": "{{config.google_sheet_id}}",
          "range": "{{config.sheet_tab_name}}"
        },
        "outputs": ["lead_rows"],
        "executable": "✅ Yes"
      },
      {
        "step": 2,
        "id": "step2",
        "action": "Convert 2D array to objects",
        "type": "transform",
        "operation": "rows_to_objects",
        "inputs": {
          "source": "lead_rows.values"
        },
        "outputs": ["lead_rows_objects"],
        "executable": "✅ Yes"
      },
      {
        "step": 3,
        "id": "step3",
        "action": "Filter high-quality leads by score",
        "type": "transform",
        "operation": "filter",
        "inputs": {
          "source": "lead_rows"
        },
        "filter_condition": {
          "field": "item.{{config.lead_score_column}}",
          "operator": ">=",
          "value": "{{config.score_threshold}}",
          "note": "At runtime with lead_score_column='stage', this resolves to: item.stage >= 4"
        },
        "outputs": ["high_quality_leads"],
        "executable": "✅ Yes - Runtime resolvable"
      },
      {
        "step": 4,
        "id": "step4",
        "action": "Resolve sales person names to emails",
        "type": "ai_processing",
        "ai_type": "generate",
        "inputs": {
          "source": "high_quality_leads",
          "config": "salesperson_email_mapping"
        },
        "outputs": ["leads_with_resolved_emails"],
        "executable": "✅ Yes"
      },
      {
        "step": 5,
        "id": "step5",
        "action": "Filter leads with resolved emails",
        "type": "transform",
        "operation": "filter",
        "inputs": {
          "source": "leads_with_resolved_emails"
        },
        "filter_condition": {
          "field": "item.resolved_email",
          "operator": "exists"
        },
        "outputs": ["leads_with_email"],
        "executable": "✅ Yes"
      },
      {
        "step": 6,
        "id": "step6",
        "action": "Filter leads without resolved emails",
        "type": "transform",
        "operation": "filter",
        "inputs": {
          "source": "leads_with_resolved_emails"
        },
        "filter_condition": {
          "field": "item.resolved_email",
          "operator": "not exists"
        },
        "outputs": ["leads_without_email"],
        "executable": "✅ Yes"
      },
      {
        "step": 7,
        "id": "step7",
        "action": "Group leads by sales person email",
        "type": "transform",
        "operation": "group",
        "inputs": {
          "source": "leads_with_email"
        },
        "group_by": "resolved_email",
        "outputs": ["leads_by_salesperson"],
        "executable": "✅ Yes"
      },
      {
        "step": 8,
        "id": "step8",
        "action": "Loop: Send follow-up email to each sales person",
        "type": "scatter_gather",
        "inputs": {
          "source": "leads_by_salesperson"
        },
        "loop_over": "salesperson_group",
        "substeps": [
          {
            "step": "8a",
            "id": "step9",
            "action": "Generate follow-up email content",
            "type": "ai_processing",
            "outputs": ["followup_email_content"]
          },
          {
            "step": "8b",
            "id": "step10",
            "action": "Send email to sales person",
            "type": "action",
            "plugin": "google-mail.send_email",
            "inputs": {
              "to": "salesperson_group.resolved_email",
              "subject": "followup_email_content.subject",
              "body": "followup_email_content.body"
            }
          }
        ],
        "executable": "✅ Yes"
      },
      {
        "step": 9,
        "id": "step11",
        "action": "Conditional: Handle unresolved leads",
        "type": "conditional",
        "condition": "leads_without_email.length > 0",
        "then": [
          {
            "step": "9a",
            "id": "step12",
            "action": "Generate unresolved leads email",
            "type": "ai_processing",
            "outputs": ["unresolved_email_content"]
          },
          {
            "step": "9b",
            "id": "step13",
            "action": "Send email to user",
            "type": "action",
            "plugin": "google-mail.send_email",
            "inputs": {
              "to": "{{config.user_email}}",
              "subject": "unresolved_email_content.subject",
              "body": "unresolved_email_content.body"
            }
          }
        ],
        "executable": "✅ Yes"
      }
    ]
  },

