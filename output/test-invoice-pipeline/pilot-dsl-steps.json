[
  {
    "id": "step1",
    "step_id": "step1",
    "name": "Fetch Data Using Google-mail",
    "type": "action",
    "output_variable": "emails",
    "description": "Fetch data using google-mail",
    "plugin": "google-mail",
    "action": "search_emails",
    "params": {
      "query": "is:unread",
      "include_attachments": true
    }
  },
  {
    "id": "step2",
    "step_id": "step2",
    "name": "Fetch Data Using Google-drive",
    "type": "action",
    "output_variable": "drive_folder",
    "description": "Fetch data using google-drive",
    "plugin": "google-drive",
    "action": "get_or_create_folder",
    "params": {
      "folder_name": "Email Attachment Expenses"
    }
  },
  {
    "id": "step3",
    "step_id": "step3",
    "name": "Loop Over {{emails}}",
    "type": "scatter_gather",
    "description": "Loop over {{emails}}",
    "scatter": {
      "input": "{{emails}}",
      "itemVariable": "current_email",
      "steps": [
        {
          "id": "step4",
          "step_id": "step4",
          "name": "Transform",
          "type": "transform",
          "output_variable": "email_metadata",
          "description": "Transform: select",
          "operation": "select",
          "input": "{{current_email}}",
          "config": {
            "fields": {
              "sender": "{{current_email.from}}",
              "subject": "{{current_email.subject}}",
              "message_id": "{{current_email.id}}"
            }
          }
        },
        {
          "id": "step5",
          "step_id": "step5",
          "name": "Transform",
          "type": "transform",
          "output_variable": "filtered_attachments",
          "description": "Transform: filter",
          "operation": "filter",
          "input": "{{current_email.attachments}}",
          "config": {
            "filter_expression": {
              "type": "complex_or",
              "conditions": [
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "application/pdf"
                },
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "image/jpeg"
                },
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "image/png"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".pdf"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".jpg"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".png"
                }
              ]
            },
            "condition": {
              "type": "complex_or",
              "conditions": [
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "application/pdf"
                },
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "image/jpeg"
                },
                {
                  "type": "simple",
                  "variable": "item.mimeType",
                  "operator": "eq",
                  "value": "image/png"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".pdf"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".jpg"
                },
                {
                  "type": "simple",
                  "variable": "item.filename",
                  "operator": "ends_with",
                  "value": ".png"
                }
              ]
            }
          }
        },
        {
          "id": "step6",
          "step_id": "step6",
          "name": "Loop Over {{filtered_attachments}}",
          "type": "scatter_gather",
          "output_variable": "all_attachment_results",
          "description": "Loop over {{filtered_attachments}}",
          "scatter": {
            "input": "{{filtered_attachments}}",
            "itemVariable": "current_attachment",
            "steps": [
              {
                "id": "step7",
                "step_id": "step7",
                "name": "Fetch Data Using Google-mail",
                "type": "action",
                "output_variable": "attachment_content",
                "description": "Fetch data using google-mail",
                "plugin": "google-mail",
                "action": "get_email_attachment",
                "params": {
                  "message_id": "{{current_attachment.message_id}}",
                  "attachment_id": "{{current_attachment.attachment_id}}"
                }
              },
              {
                "id": "step8",
                "step_id": "step8",
                "name": "Deliver Using Google-drive",
                "type": "action",
                "output_variable": "uploaded_file",
                "description": "Deliver using google-drive",
                "plugin": "google-drive",
                "action": "upload_file",
                "params": {
                  "file_content": "{{attachment_content.data}}",
                  "file_name": "{{attachment_content.filename}}",
                  "folder_id": "{{drive_folder.folder_id}}",
                  "mime_type": "{{attachment_content.mimeType}}"
                }
              },
              {
                "id": "step9",
                "step_id": "step9",
                "name": "AI",
                "type": "ai_processing",
                "output_variable": "extracted_fields",
                "description": "AI: undefined",
                "input": "{{attachment_content}}",
                "prompt": "Extract transaction/invoice/receipt fields from this attachment. Look for date, vendor/merchant name, total amount, currency, and invoice or receipt number. If any field is not clearly present, return null for that field. For the amount field, only return a value if you are confident it represents the total transaction amount.",
                "config": {
                  "ai_type": "deterministic_extract",
                  "output_schema": {
                    "type": "object",
                    "properties": {
                      "date": {
                        "type": "string",
                        "description": "Transaction or invoice date"
                      },
                      "vendor": {
                        "type": "string",
                        "description": "Vendor or merchant name"
                      },
                      "amount": {
                        "type": "number",
                        "description": "Total transaction amount as a number"
                      },
                      "currency": {
                        "type": "string",
                        "description": "Currency code (e.g., USD, EUR)"
                      },
                      "invoice_or_receipt_number": {
                        "type": "string",
                        "description": "Invoice or receipt number"
                      },
                      "extraction_confidence": {
                        "type": "string",
                        "description": "Confidence level for amount extraction: high, medium, or low"
                      }
                    },
                    "required": [
                      "amount",
                      "extraction_confidence"
                    ]
                  }
                }
              },
              {
                "id": "step10",
                "step_id": "step10",
                "name": "AI",
                "type": "ai_processing",
                "output_variable": "full_record",
                "description": "AI: undefined",
                "input": "{{extracted_fields}}",
                "prompt": "Combine the extracted transaction fields with the file metadata and email metadata into a single structured record. Include all fields: date, vendor, amount, currency, invoice_or_receipt_number, drive_file_link, sender, subject, filename, extraction_confidence. Preserve all values exactly as provided.",
                "config": {
                  "ai_type": "generate",
                  "output_schema": {
                    "type": "object",
                    "properties": {
                      "date": {
                        "type": "string",
                        "description": "Transaction date"
                      },
                      "vendor": {
                        "type": "string",
                        "description": "Vendor name"
                      },
                      "amount": {
                        "type": "number",
                        "description": "Transaction amount"
                      },
                      "currency": {
                        "type": "string",
                        "description": "Currency code"
                      },
                      "invoice_or_receipt_number": {
                        "type": "string",
                        "description": "Invoice/receipt number"
                      },
                      "drive_file_link": {
                        "type": "string",
                        "description": "Google Drive link to the uploaded file"
                      },
                      "sender": {
                        "type": "string",
                        "description": "Email sender"
                      },
                      "subject": {
                        "type": "string",
                        "description": "Email subject"
                      },
                      "filename": {
                        "type": "string",
                        "description": "Attachment filename"
                      },
                      "extraction_confidence": {
                        "type": "string",
                        "description": "Confidence level for amount extraction"
                      }
                    }
                  }
                }
              },
              {
                "id": "step11",
                "step_id": "step11",
                "name": "Conditional",
                "type": "conditional",
                "description": "Conditional: check_amount_confidence",
                "condition": {
                  "conditionType": "simple",
                  "field": "extracted_fields.amount",
                  "operator": "is_empty"
                },
                "then": [
                  {
                    "id": "step12",
                    "step_id": "step12",
                    "name": "AI",
                    "type": "ai_processing",
                    "output_variable": "attachment_result",
                    "description": "AI: undefined",
                    "input": "{{full_record}}",
                    "prompt": "Create a result record marking this attachment as skipped due to missing or unclear amount. Set status to 'skipped', include the sender, subject, filename, and drive_file_link from the full record. Set amount to null and over_50 to false.",
                    "config": {
                      "ai_type": "generate",
                      "output_schema": {
                        "type": "object",
                        "properties": {
                          "status": {
                            "type": "string",
                            "description": "Processing status: skipped"
                          },
                          "date": {
                            "type": "string"
                          },
                          "vendor": {
                            "type": "string"
                          },
                          "amount": {
                            "type": "number"
                          },
                          "currency": {
                            "type": "string"
                          },
                          "invoice_or_receipt_number": {
                            "type": "string"
                          },
                          "drive_file_link": {
                            "type": "string"
                          },
                          "sender": {
                            "type": "string"
                          },
                          "subject": {
                            "type": "string"
                          },
                          "filename": {
                            "type": "string"
                          },
                          "over_50": {
                            "type": "boolean",
                            "description": "Always false for skipped"
                          }
                        }
                      }
                    }
                  }
                ],
                "else": [
                  {
                    "id": "step13",
                    "step_id": "step13",
                    "name": "Conditional",
                    "type": "conditional",
                    "description": "Conditional: check_amount_threshold",
                    "condition": {
                      "conditionType": "simple",
                      "field": "extracted_fields.amount",
                      "operator": "greater_than",
                      "value": 50
                    },
                    "then": [
                      {
                        "id": "step14",
                        "step_id": "step14",
                        "name": "Deliver Using Google-sheets",
                        "type": "action",
                        "output_variable": "sheet_append_result",
                        "description": "Deliver using google-sheets",
                        "plugin": "google-sheets",
                        "action": "append_rows",
                        "params": {
                          "spreadsheet_id": "1pM8WbXtPgaYqokHn_spgQAfR7SBuql3JUtE1ugDtOpc",
                          "range": "Expenses",
                          "values": [
                            [
                              "{{full_record.date}}",
                              "{{full_record.vendor}}",
                              "{{full_record.amount}}",
                              "{{full_record.currency}}",
                              "{{full_record.invoice_or_receipt_number}}",
                              "{{full_record.drive_file_link}}",
                              "{{full_record.sender}}",
                              "{{full_record.subject}}"
                            ]
                          ]
                        }
                      },
                      {
                        "id": "step15",
                        "step_id": "step15",
                        "name": "AI",
                        "type": "ai_processing",
                        "output_variable": "attachment_result",
                        "description": "AI: undefined",
                        "input": "{{full_record}}",
                        "prompt": "Create a result record for this successfully extracted transaction with amount > $50. Set status to 'extracted', over_50 to true. Include all fields from the full record.",
                        "config": {
                          "ai_type": "generate",
                          "output_schema": {
                            "type": "object",
                            "properties": {
                              "status": {
                                "type": "string",
                                "description": "Processing status: extracted"
                              },
                              "date": {
                                "type": "string"
                              },
                              "vendor": {
                                "type": "string"
                              },
                              "amount": {
                                "type": "number"
                              },
                              "currency": {
                                "type": "string"
                              },
                              "invoice_or_receipt_number": {
                                "type": "string"
                              },
                              "drive_file_link": {
                                "type": "string"
                              },
                              "sender": {
                                "type": "string"
                              },
                              "subject": {
                                "type": "string"
                              },
                              "filename": {
                                "type": "string"
                              },
                              "over_50": {
                                "type": "boolean",
                                "description": "true for amount > 50"
                              }
                            }
                          }
                        }
                      }
                    ],
                    "else": [
                      {
                        "id": "step16",
                        "step_id": "step16",
                        "name": "AI",
                        "type": "ai_processing",
                        "output_variable": "attachment_result",
                        "description": "AI: undefined",
                        "input": "{{full_record}}",
                        "prompt": "Create a result record for this successfully extracted transaction with amount <= $50. Set status to 'extracted', over_50 to false. Include all fields from the full record.",
                        "config": {
                          "ai_type": "generate",
                          "output_schema": {
                            "type": "object",
                            "properties": {
                              "status": {
                                "type": "string",
                                "description": "Processing status: extracted"
                              },
                              "date": {
                                "type": "string"
                              },
                              "vendor": {
                                "type": "string"
                              },
                              "amount": {
                                "type": "number"
                              },
                              "currency": {
                                "type": "string"
                              },
                              "invoice_or_receipt_number": {
                                "type": "string"
                              },
                              "drive_file_link": {
                                "type": "string"
                              },
                              "sender": {
                                "type": "string"
                              },
                              "subject": {
                                "type": "string"
                              },
                              "filename": {
                                "type": "string"
                              },
                              "over_50": {
                                "type": "boolean",
                                "description": "false for amount <= 50"
                              }
                            }
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "gather": {
            "operation": "collect",
            "outputKey": "all_attachment_results"
          }
        }
      ]
    },
    "gather": {
      "operation": "collect"
    }
  },
  {
    "id": "step17",
    "step_id": "step17",
    "name": "AI",
    "type": "ai_processing",
    "output_variable": "aggregated_summary",
    "description": "AI: undefined",
    "input": "{{all_attachment_results}}",
    "prompt": "Analyze the collected attachment results and produce a comprehensive summary. Group the results into three categories: 1) All successfully extracted transactions (status='extracted'), 2) Transactions with amount > $50 only (over_50=true), 3) Skipped attachments (status='skipped'). Compute totals: total number of extracted transactions, sum of all extracted amounts, sum of amounts for the >$50 subset. Format the output as structured data with these three groups and the computed totals.",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "all_extracted_transactions": {
            "type": "array",
            "description": "All successfully extracted transactions with date, vendor, amount, currency, invoice_or_receipt_number, drive_file_link, sender, subject"
          },
          "over_50_transactions": {
            "type": "array",
            "description": "Only transactions with amount > $50"
          },
          "skipped_attachments": {
            "type": "array",
            "description": "Attachments skipped due to missing/unclear amounts, with sender, subject, drive_file_link, filename"
          },
          "total_extracted_count": {
            "type": "number",
            "description": "Total number of successfully extracted transactions"
          },
          "total_all_amounts": {
            "type": "number",
            "description": "Sum of all extracted transaction amounts"
          },
          "total_over_50_amounts": {
            "type": "number",
            "description": "Sum of amounts for transactions > $50"
          }
        }
      }
    }
  },
  {
    "id": "step18",
    "step_id": "step18",
    "name": "AI",
    "type": "ai_processing",
    "output_variable": "summary_email_content",
    "description": "AI: undefined",
    "input": "{{aggregated_summary}}",
    "prompt": "Generate a professional HTML email body for a summary report of extracted expense transactions. The email must include:\n\n1. A header: 'Expense Extraction Summary'\n\n2. A table titled 'All Extracted Transactions' with columns: Date, Vendor, Amount, Currency, Invoice/Receipt #, Drive Link (as clickable hyperlink), Sender, Subject. Include ALL extracted transactions from all_extracted_transactions.\n\n3. A separate section titled 'Transactions Over $50' with the same table format but only including transactions from over_50_transactions.\n\n4. A 'Totals Summary' section showing:\n   - Total transactions extracted: {{total_extracted_count}}\n   - Sum of all extracted amounts: {{total_all_amounts}}\n   - Sum of amounts > $50: {{total_over_50_amounts}}\n\n5. A 'Skipped Attachments' note section listing attachments that were skipped due to missing/unclear amounts. For each, show: Sender, Subject, Drive File Link (as clickable hyperlink), Filename.\n\nUse clean HTML tables with borders. Make Drive links clickable. If any section has no items, show 'None' or 'No items'.",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "email_subject": {
            "type": "string",
            "description": "Email subject line"
          },
          "email_html_body": {
            "type": "string",
            "description": "Full HTML email body with all sections"
          }
        }
      }
    }
  },
  {
    "id": "step19",
    "step_id": "step19",
    "name": "Deliver Using Google-mail",
    "type": "action",
    "output_variable": "sent_email_result",
    "description": "Deliver using google-mail",
    "plugin": "google-mail",
    "action": "send_email",
    "params": {
      "recipients": {
        "to": [
          "offir.omer@gmail.com"
        ]
      },
      "content": {
        "subject": "{{summary_email_content.email_subject}}",
        "html_body": "{{summary_email_content.email_html_body}}"
      }
    }
  }
]