{
  "version": "intent.v1",
  "goal": "Scan Gmail Inbox for complaint emails from the last 7 days and append them to Google Sheets tab 'UrgentEmails', skipping duplicates based on Gmail message link/id",
  "unit_of_work": {
    "entity": "email",
    "parent_entity": "inbox"
  },
  "config": [
    {
      "key": "user_email",
      "type": "string",
      "description": "Gmail account email address",
      "default": "offir.omer@gmail.com"
    },
    {
      "key": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID",
      "default": "1pM8WbXtPgaYqokHn_spgQAfR7SBuql3JUtE1ugDtOpc"
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Worksheet tab name for logging complaint emails",
      "default": "UrgentEmails"
    },
    {
      "key": "gmail_scope",
      "type": "string",
      "description": "Gmail folder/label to scan",
      "default": "Inbox"
    },
    {
      "key": "data_time_window",
      "type": "string",
      "description": "Time window for email search",
      "default": "last 7 days"
    },
    {
      "key": "complaint_keywords",
      "type": "string",
      "description": "Comma-separated complaint keywords",
      "default": "complaint, refund, angry, not working"
    }
  ],
  "steps": [
    {
      "id": "fetch_gmail_messages",
      "kind": "data_source",
      "summary": "Search Gmail Inbox for messages from the last 7 days",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "gmail_messages",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "payload": {
        "user_email": {
          "kind": "config",
          "key": "user_email"
        },
        "folder": {
          "kind": "config",
          "key": "gmail_scope"
        },
        "time_window": {
          "kind": "config",
          "key": "data_time_window"
        }
      },
      "retrieval": {
        "include_content": "full",
        "include_metadata": true
      },
      "plugin_key": "google-mail",
      "action": "search_emails",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: email",
        "✅ Capability match: search",
        "✅ Provider preference matched: google"
      ]
    },
    {
      "id": "load_existing_sheet_rows",
      "kind": "data_source",
      "summary": "Load existing rows from UrgentEmails tab to identify duplicates",
      "uses": [
        {
          "capability": "get",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "existing_rows",
      "source": {
        "domain": "table",
        "intent": "get"
      },
      "payload": {
        "spreadsheet_id": {
          "kind": "config",
          "key": "spreadsheet_id"
        },
        "sheet_name": {
          "kind": "config",
          "key": "sheet_tab_name"
        }
      },
      "plugin_key": "google-sheets",
      "action": "read_range",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: table",
        "✅ Capability match: get",
        "✅ Provider preference matched: google"
      ]
    },
    {
      "id": "extract_existing_message_ids",
      "kind": "transform",
      "summary": "Extract Gmail message link/id values from existing sheet rows",
      "inputs": [
        "existing_rows"
      ],
      "output": "existing_message_ids",
      "transform": {
        "op": "map",
        "input": "existing_rows",
        "description": "Extract the Gmail message link/id field from each existing row to build deduplication set",
        "output_schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "message_id": {
                "type": "string"
              }
            },
            "required": [
              "message_id"
            ]
          }
        }
      },
      "binding_method": "unbound"
    },
    {
      "id": "filter_complaint_emails",
      "kind": "transform",
      "summary": "Filter emails containing complaint keywords (complaint, refund, angry, not working)",
      "inputs": [
        "gmail_messages"
      ],
      "output": "complaint_emails",
      "transform": {
        "op": "filter",
        "input": "gmail_messages",
        "description": "Keep only emails where content contains any of the complaint keywords (case-insensitive)",
        "where": {
          "op": "or",
          "conditions": [
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "gmail_messages",
                "field": "body"
              },
              "comparator": "contains",
              "right": {
                "kind": "literal",
                "value": "complaint"
              }
            },
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "gmail_messages",
                "field": "body"
              },
              "comparator": "contains",
              "right": {
                "kind": "literal",
                "value": "refund"
              }
            },
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "gmail_messages",
                "field": "body"
              },
              "comparator": "contains",
              "right": {
                "kind": "literal",
                "value": "angry"
              }
            },
            {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "gmail_messages",
                "field": "body"
              },
              "comparator": "contains",
              "right": {
                "kind": "literal",
                "value": "not working"
              }
            }
          ]
        }
      },
      "binding_method": "unbound"
    },
    {
      "id": "filter_new_complaints",
      "kind": "transform",
      "summary": "Remove complaint emails that already exist in the sheet (deduplication by Gmail message link/id)",
      "inputs": [
        "complaint_emails",
        "existing_message_ids"
      ],
      "output": "new_complaint_emails",
      "transform": {
        "op": "filter",
        "input": "complaint_emails",
        "description": "Keep only complaint emails whose Gmail message link/id is not already present in the existing sheet rows"
      },
      "binding_method": "unbound"
    },
    {
      "id": "process_each_complaint",
      "kind": "loop",
      "summary": "Process each new complaint email and append to Google Sheets",
      "inputs": [
        "new_complaint_emails"
      ],
      "loop": {
        "over": "new_complaint_emails",
        "item_ref": "complaint_email",
        "unit_of_work": {
          "entity": "email"
        },
        "do": [
          {
            "id": "extract_email_fields",
            "kind": "transform",
            "summary": "Extract required fields from complaint email",
            "inputs": [
              "complaint_email"
            ],
            "output": "email_row_data",
            "transform": {
              "op": "map",
              "input": "complaint_email",
              "description": "Extract sender email, subject, date, full email text, and Gmail message link/id",
              "output_schema": {
                "type": "object",
                "properties": {
                  "sender_email": {
                    "type": "string"
                  },
                  "subject": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "message_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "sender_email",
                  "subject",
                  "date",
                  "body",
                  "message_id"
                ]
              }
            },
            "binding_method": "unbound"
          },
          {
            "id": "append_to_sheet",
            "kind": "deliver",
            "summary": "Append complaint email row to UrgentEmails tab",
            "inputs": [
              "email_row_data"
            ],
            "output": "appended_row",
            "uses": [
              {
                "capability": "append",
                "domain": "table",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "table",
              "intent": "append",
              "input": "email_row_data",
              "mapping": [
                {
                  "from": {
                    "kind": "ref",
                    "ref": "email_row_data",
                    "field": "sender_email"
                  },
                  "to": "sender_email"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "email_row_data",
                    "field": "subject"
                  },
                  "to": "subject"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "email_row_data",
                    "field": "date"
                  },
                  "to": "date"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "email_row_data",
                    "field": "body"
                  },
                  "to": "full_email_text"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "email_row_data",
                    "field": "message_id"
                  },
                  "to": "gmail_message_link_id"
                }
              ],
              "options": {
                "spreadsheet_id": {
                  "kind": "config",
                  "key": "spreadsheet_id"
                },
                "sheet_name": {
                  "kind": "config",
                  "key": "sheet_tab_name"
                }
              }
            },
            "plugin_key": "google-sheets",
            "action": "append_rows",
            "binding_confidence": 1,
            "binding_method": "exact_match",
            "binding_reason": [
              "✅ Domain match: table",
              "✅ Capability match: append",
              "✅ Provider preference matched: google"
            ]
          }
        ]
      },
      "binding_method": "unbound"
    }
  ],
  "required_outcomes": [
    "All complaint emails from the last 7 days are identified and logged",
    "No duplicate Gmail message link/id entries exist in the sheet",
    "Each complaint email row contains: sender email, subject, date, full email text, Gmail message link/id"
  ],
  "confidence": 0.95,
  "subset_resolution": {
    "success": true,
    "subsets": {},
    "errors": [],
    "warnings": []
  }
}