[
  {
    "step_id": "step1",
    "type": "action",
    "description": "Search Gmail for unread emails with PDF or image attachments",
    "plugin": "google-mail",
    "action": "search_emails",
    "config": {
      "query": "is:unread has:attachment",
      "include_attachments": true
    },
    "output_variable": "unread_emails",
    "id": "step1"
  },
  {
    "step_id": "step2",
    "type": "transform",
    "operation": "flatten",
    "input": "{{unread_emails}}",
    "description": "Extract attachments array from emails",
    "config": {
      "type": "flatten",
      "input": "unread_emails",
      "custom_code": "Extract attachments from emails, preserving email metadata (sender, subject)",
      "output_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "mimeType": {
              "type": "string"
            },
            "size": {
              "type": "number"
            },
            "email_sender": {
              "type": "string"
            },
            "email_subject": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "filename",
            "mimeType"
          ]
        }
      }
    },
    "output_variable": "all_attachments",
    "id": "step2"
  },
  {
    "step_id": "step3",
    "type": "transform",
    "operation": "filter",
    "input": "{{all_attachments}}",
    "description": "Keep only PDF and image attachments (candidate invoices/receipts)",
    "config": {
      "type": "filter",
      "input": "all_attachments",
      "custom_code": "Filter for PDF and image file types",
      "condition": {
        "operator": "in",
        "value": [
          "application/pdf",
          "image/jpeg",
          "image/jpg",
          "image/png"
        ],
        "field": "item.mimeType",
        "conditionType": "simple"
      },
      "output_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "filename": {
              "type": "string"
            },
            "mimeType": {
              "type": "string"
            },
            "size": {
              "type": "number"
            },
            "email_sender": {
              "type": "string"
            },
            "email_subject": {
              "type": "string"
            },
            "message_id": {
              "type": "string"
            },
            "attachment_id": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "folder_id": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "filename",
            "mimeType",
            "message_id",
            "attachment_id",
            "content"
          ]
        }
      }
    },
    "output_variable": "candidate_attachments",
    "id": "step3"
  },
  {
    "step_id": "step4",
    "type": "action",
    "description": "Get or create Google Drive folder for storing invoice/receipt files",
    "plugin": "google-drive",
    "action": "get_or_create_folder",
    "config": {
      "folder_name": "Invoices_Receipts"
    },
    "output_variable": "drive_folder",
    "id": "step4"
  },
  {
    "step_id": "step5",
    "type": "scatter_gather",
    "description": "Loop over candidate_attachments",
    "scatter": {
      "input": "{{candidate_attachments}}",
      "steps": [
        {
          "step_id": "step6",
          "type": "action",
          "description": "Download attachment content from Gmail",
          "plugin": "google-mail",
          "action": "get_email_attachment",
          "config": {
            "message_id": "{{attachment.message_id}}",
            "attachment_id": "{{attachment.attachment_id}}",
            "filename": "{{attachment.filename}}"
          },
          "output_variable": "attachment_content",
          "id": "step6"
        },
        {
          "step_id": "step7",
          "type": "action",
          "description": "Upload attachment to Google Drive folder",
          "plugin": "google-drive",
          "action": "upload_file",
          "config": {
            "file_content": "{{attachment_content.content}}",
            "file_name": "{{attachment_content.filename}}",
            "folder_id": "{{drive_folder.folder_id}}",
            "name": "{{attachment.filename}}"
          },
          "output_variable": "drive_file",
          "id": "step7"
        },
        {
          "step_id": "step8",
          "type": "action",
          "description": "Extract structured transaction fields from attachment",
          "plugin": "document-extractor",
          "action": "extract_structured_data",
          "config": {
            "file_content": "{{attachment_content}}",
            "fields": [
              {
                "name": "date",
                "type": "date",
                "required": false
              },
              {
                "name": "vendor",
                "type": "string",
                "required": false
              },
              {
                "name": "amount",
                "type": "number",
                "required": true
              },
              {
                "name": "currency",
                "type": "string",
                "required": false
              },
              {
                "name": "invoice_number",
                "type": "string",
                "required": false
              }
            ]
          },
          "output_variable": "extracted_fields",
          "id": "step8"
        },
        {
          "step_id": "step9",
          "type": "transform",
          "operation": "map",
          "input": "{{extracted_fields}}",
          "description": "Merge extracted fields with email metadata and Drive link",
          "config": {
            "type": "map",
            "input": "extracted_fields",
            "custom_code": "Combine transaction fields with email sender, subject, and Drive file link",
            "output_schema": {
              "type": "object",
              "properties": {
                "date": {
                  "type": "string"
                },
                "vendor": {
                  "type": "string"
                },
                "amount": {
                  "type": "number"
                },
                "currency": {
                  "type": "string"
                },
                "invoice_number": {
                  "type": "string"
                },
                "email_sender": {
                  "type": "string"
                },
                "email_subject": {
                  "type": "string"
                },
                "drive_link": {
                  "type": "string"
                },
                "filename": {
                  "type": "string"
                }
              },
              "required": [
                "amount"
              ]
            },
            "attachment": "{{attachment}}",
            "attachment_content": "{{attachment_content}}",
            "drive_file": "{{drive_file}}"
          },
          "output_variable": "transaction_record",
          "id": "step9"
        }
      ],
      "itemVariable": "attachment"
    },
    "gather": {
      "operation": "collect"
    },
    "output_variable": "processed_transactions",
    "id": "step5"
  },
  {
    "step_id": "step10",
    "type": "transform",
    "operation": "filter",
    "input": "{{processed_transactions}}",
    "description": "Keep only transactions with valid amount field",
    "config": {
      "type": "filter",
      "input": "processed_transactions",
      "custom_code": "Filter transactions where amount exists and is not null",
      "condition": {
        "operator": "exists",
        "field": "item.amount",
        "conditionType": "simple"
      },
      "output_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "amount": {
              "type": "string"
            }
          },
          "required": []
        }
      }
    },
    "output_variable": "valid_transactions",
    "id": "step10"
  },
  {
    "step_id": "step11",
    "type": "transform",
    "operation": "filter",
    "input": "{{valid_transactions}}",
    "description": "Filter subset for high_value_transactions",
    "config": {
      "type": "filter",
      "input": "valid_transactions",
      "condition": {
        "operator": "gt",
        "value": "{{config.amount_threshold_usd}}",
        "field": "item.amount",
        "conditionType": "simple"
      }
    },
    "output_variable": "high_value_transactions",
    "id": "step11"
  },
  {
    "step_id": "step12",
    "type": "transform",
    "operation": "filter",
    "input": "{{valid_transactions}}",
    "description": "Filter subset for low_value_transactions",
    "config": {
      "type": "filter",
      "input": "valid_transactions",
      "condition": {
        "operator": "lte",
        "value": "{{config.amount_threshold_usd}}",
        "field": "item.amount",
        "conditionType": "simple"
      }
    },
    "output_variable": "low_value_transactions",
    "id": "step12"
  },
  {
    "step_id": "step13",
    "type": "transform",
    "operation": "reduce",
    "input": "{{valid_transactions}}",
    "description": "Count items for total_count",
    "config": {
      "type": "reduce",
      "input": "valid_transactions",
      "reduce_operation": "count",
      "reducer": "count"
    },
    "output_variable": "total_count",
    "id": "step13"
  },
  {
    "step_id": "step14",
    "type": "transform",
    "operation": "reduce",
    "input": "{{valid_transactions}}",
    "description": "Aggregate sum for total_amount",
    "config": {
      "type": "reduce",
      "input": "valid_transactions",
      "reduce_operation": "sum",
      "reducer": "sum",
      "field": "amount"
    },
    "output_variable": "total_amount",
    "id": "step14"
  },
  {
    "step_id": "step15",
    "type": "scatter_gather",
    "description": "Loop over high_value_transactions",
    "scatter": {
      "input": "{{high_value_transactions}}",
      "steps": [
        {
          "step_id": "step16",
          "type": "action",
          "description": "Append transaction row to Google Sheets tab",
          "plugin": "google-sheets",
          "action": "append_rows",
          "config": {
            "spreadsheet_id": "{{config.google_sheet_id}}",
            "range": "{{config.sheet_tab_name}}",
            "values": [
              [
                "{{transaction.date}}",
                "{{transaction.vendor}}",
                "{{transaction.amount}}",
                "{{transaction.currency}}",
                "{{transaction.invoice_number}}",
                "{{transaction.email_sender}}",
                "{{transaction.email_subject}}",
                "{{transaction.drive_link}}"
              ]
            ]
          },
          "output_variable": "sheet_row",
          "id": "step16"
        }
      ],
      "itemVariable": "transaction"
    },
    "gather": {
      "operation": "collect"
    },
    "id": "step15"
  },
  {
    "step_id": "step17",
    "type": "ai_processing",
    "input": {
      "valid_transactions": "{{valid_transactions}}",
      "high_value_transactions": "{{high_value_transactions}}",
      "total_count": "{{total_count}}",
      "total_amount": "{{total_amount}}"
    },
    "prompt": "Create an HTML email summary with:\n1. Opening paragraph stating total number of transactions extracted and total amount\n2. Table of ALL extracted transactions (valid_transactions) with columns: Date, Vendor, Amount, Currency, Invoice Number, Email Sender, Email Subject, Drive Link\n3. Separate section titled 'High-Value Transactions (>$50)' with table of high_value_transactions using same columns\n4. Use total_count and total_amount for the summary statistics\n5. Format amounts as currency, make Drive Link clickable\n6. Use professional email styling",
    "description": "Generate email summary with transaction tables and totals",
    "config": {
      "ai_type": "generate",
      "output_schema": {
        "type": "object",
        "properties": {
          "subject": {
            "type": "string",
            "description": "Email subject line"
          },
          "body": {
            "type": "string",
            "description": "HTML email body"
          }
        },
        "required": [
          "subject",
          "body"
        ]
      },
      "type": "generate",
      "instruction": "Create an HTML email summary with:\n1. Opening paragraph stating total number of transactions extracted and total amount\n2. Table of ALL extracted transactions (valid_transactions) with columns: Date, Vendor, Amount, Currency, Invoice Number, Email Sender, Email Subject, Drive Link\n3. Separate section titled 'High-Value Transactions (>$50)' with table of high_value_transactions using same columns\n4. Use total_count and total_amount for the summary statistics\n5. Format amounts as currency, make Drive Link clickable\n6. Use professional email styling"
    },
    "output_variable": "email_content",
    "id": "step17"
  },
  {
    "step_id": "step18",
    "type": "action",
    "description": "Send summary email to user",
    "plugin": "google-mail",
    "action": "send_email",
    "config": {
      "recipients": {
        "to": [
          "{{config.user_email}}"
        ]
      },
      "content": {
        "subject": "{{email_content.subject}}",
        "html_body": "{{email_content.body}}"
      }
    },
    "id": "step18"
  }
]