{
  "version": "intent.v1",
  "goal": "Extract invoices and receipts from unread Gmail emails, store files in Google Drive, log transactions over $50 to Google Sheets, and send summary email",
  "unit_of_work": {
    "entity": "attachment",
    "parent_entity": "email"
  },
  "config": [
    {
      "key": "user_email",
      "type": "string",
      "description": "Email address to send summary to",
      "default": "offir.omer@gmail.com"
    },
    {
      "key": "amount_threshold_usd",
      "type": "number",
      "description": "Minimum amount in USD to log to Google Sheets",
      "default": 50
    },
    {
      "key": "sheet_tab_name",
      "type": "string",
      "description": "Google Sheets tab name for expenses",
      "default": "Expenses"
    },
    {
      "key": "google_sheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID",
      "default": "1pM8WbXtPgaYqokHn_spgQAfR7SBuql3JUtE1ugDtOpc"
    }
  ],
  "required_outcomes": [
    "All unread Gmail emails with PDF/image attachments are processed",
    "All attachments are stored in Google Drive folder",
    "Transactions over $50 are logged to Google Sheets",
    "Summary email is sent with all extracted transactions"
  ],
  "steps": [
    {
      "id": "fetch_unread_emails",
      "kind": "data_source",
      "summary": "Fetch unread emails from Gmail",
      "uses": [
        {
          "capability": "search",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "unread_emails",
      "source": {
        "domain": "email",
        "intent": "search"
      },
      "query": "is:unread has:attachment",
      "filters": [
        {
          "field": "read_status",
          "op": "eq",
          "value": {
            "kind": "literal",
            "value": false
          }
        },
        {
          "field": "has_attachments",
          "op": "eq",
          "value": {
            "kind": "literal",
            "value": true
          }
        }
      ],
      "retrieval": {
        "include_content": "full",
        "include_attachments": true,
        "include_metadata": true
      },
      "plugin_key": "google-mail",
      "action": "search_emails",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: email",
        "✅ Capability match: search",
        "✅ Provider preference matched: google"
      ]
    },
    {
      "id": "create_drive_folder",
      "kind": "artifact",
      "summary": "Create Google Drive folder for storing invoice/receipt files",
      "uses": [
        {
          "capability": "create",
          "domain": "storage",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "drive_folder",
      "artifact": {
        "domain": "storage",
        "type": "folder",
        "strategy": "get_or_create",
        "name_hint": "Invoice_Receipt_Extractions",
        "options": {
          "name": {
            "kind": "computed",
            "op": "format",
            "args": [
              {
                "kind": "literal",
                "value": "Invoice_Receipt_Extractions_{date}"
              }
            ]
          }
        }
      },
      "plugin_key": "google-drive",
      "action": "get_or_create_folder",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: storage",
        "✅ Capability match (expanded): upsert (requested: create)",
        "✅ Provider preference matched: google",
        "✅ Output entity matches artifact type (folder ~ folder)",
        "✅ Idempotent action (UNIVERSAL DEFAULT for artifact creation)",
        "✅ Perfect match: idempotent action + get_or_create strategy"
      ]
    },
    {
      "id": "extract_attachments",
      "kind": "transform",
      "summary": "Extract PDF and image attachments from emails with metadata",
      "inputs": [
        "unread_emails"
      ],
      "output": "candidate_attachments",
      "transform": {
        "op": "flatten",
        "input": "unread_emails",
        "description": "Flatten email attachments into individual items, filtering for PDF and image types, and enriching with email metadata (sender, subject)"
      },
      "binding_method": "unbound"
    },
    {
      "id": "process_each_attachment",
      "kind": "loop",
      "summary": "Process each attachment: upload to Drive and extract transaction data",
      "inputs": [
        "candidate_attachments",
        "drive_folder"
      ],
      "output": "processed_transactions",
      "loop": {
        "over": "candidate_attachments",
        "item_ref": "attachment",
        "unit_of_work": {
          "entity": "attachment"
        },
        "collect": {
          "enabled": true,
          "collect_as": "processed_transactions",
          "from_step_output": "transaction_record"
        },
        "do": [
          {
            "id": "upload_attachment_to_drive",
            "kind": "deliver",
            "summary": "Upload attachment file to Google Drive folder",
            "inputs": [
              "attachment",
              "drive_folder"
            ],
            "output": "uploaded_file",
            "uses": [
              {
                "capability": "upload",
                "domain": "storage",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "storage",
              "intent": "upload",
              "input": "attachment",
              "destination": "drive_folder",
              "options": {
                "file_name": {
                  "kind": "ref",
                  "ref": "attachment",
                  "field": "filename"
                }
              }
            },
            "plugin_key": "google-drive",
            "action": "upload_file",
            "binding_confidence": 1,
            "binding_method": "exact_match",
            "binding_reason": [
              "✅ Domain match: storage",
              "✅ Capability match: upload",
              "✅ Provider preference matched: google"
            ]
          },
          {
            "id": "extract_transaction_fields",
            "kind": "extract",
            "summary": "Extract structured transaction fields from attachment",
            "inputs": [
              "uploaded_file"
            ],
            "output": "extracted_fields",
            "uses": [
              {
                "capability": "extract_structured_data",
                "domain": "document"
              }
            ],
            "extract": {
              "input": "uploaded_file",
              "fields": [
                {
                  "name": "date",
                  "type": "date",
                  "required": false,
                  "description": "Transaction or invoice date"
                },
                {
                  "name": "vendor",
                  "type": "string",
                  "required": false,
                  "description": "Vendor or merchant name"
                },
                {
                  "name": "amount",
                  "type": "number",
                  "required": true,
                  "description": "Transaction amount"
                },
                {
                  "name": "currency",
                  "type": "string",
                  "required": false,
                  "description": "Currency code (e.g., USD, EUR)"
                },
                {
                  "name": "invoice_number",
                  "type": "string",
                  "required": false,
                  "description": "Invoice or receipt number"
                }
              ],
              "deterministic": false,
              "content_hints": {
                "file_types": [
                  "pdf",
                  "jpg",
                  "png"
                ]
              }
            },
            "plugin_key": "document-extractor",
            "action": "extract_structured_data",
            "binding_confidence": 1,
            "binding_method": "exact_match",
            "binding_reason": [
              "✅ Domain match: document",
              "✅ Capability match: extract_structured_data"
            ]
          },
          {
            "id": "check_amount_extracted",
            "kind": "decide",
            "summary": "Check if amount was successfully extracted",
            "inputs": [
              "extracted_fields"
            ],
            "decide": {
              "condition": {
                "op": "test",
                "left": {
                  "kind": "ref",
                  "ref": "extracted_fields",
                  "field": "amount"
                },
                "comparator": "exists"
              },
              "then": [
                {
                  "id": "build_transaction_record",
                  "kind": "transform",
                  "summary": "Build complete transaction record with all metadata",
                  "inputs": [
                    "extracted_fields",
                    "uploaded_file",
                    "attachment"
                  ],
                  "output": "transaction_record",
                  "transform": {
                    "op": "map",
                    "input": "extracted_fields",
                    "description": "Combine extracted fields with file metadata and email source info"
                  },
                  "binding_method": "unbound"
                }
              ],
              "else": [
                {
                  "id": "skip_transaction",
                  "kind": "transform",
                  "summary": "Skip transaction record creation (no amount found)",
                  "inputs": [],
                  "output": "transaction_record",
                  "transform": {
                    "op": "custom",
                    "input": "extracted_fields",
                    "description": "Return null/empty record"
                  },
                  "binding_method": "unbound"
                }
              ]
            },
            "binding_method": "unbound"
          }
        ]
      },
      "binding_method": "unbound"
    },
    {
      "id": "filter_valid_transactions",
      "kind": "transform",
      "summary": "Filter out transactions without valid amounts",
      "inputs": [
        "processed_transactions"
      ],
      "output": "valid_transactions",
      "transform": {
        "op": "filter",
        "input": "processed_transactions",
        "description": "Remove null/empty transaction records where amount extraction failed"
      },
      "binding_method": "unbound"
    },
    {
      "id": "split_by_amount_threshold",
      "kind": "aggregate",
      "summary": "Split transactions into high-value (>$50) and low-value (≤$50) groups",
      "inputs": [
        "valid_transactions"
      ],
      "output": "transaction_metrics",
      "aggregate": {
        "input": "valid_transactions",
        "outputs": [
          {
            "name": "high_value_transactions",
            "type": "subset",
            "where": {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "valid_transactions",
                "field": "amount"
              },
              "comparator": "gt",
              "right": {
                "kind": "config",
                "key": "amount_threshold_usd"
              }
            }
          },
          {
            "name": "low_value_transactions",
            "type": "subset",
            "where": {
              "op": "test",
              "left": {
                "kind": "ref",
                "ref": "valid_transactions",
                "field": "amount"
              },
              "comparator": "lte",
              "right": {
                "kind": "config",
                "key": "amount_threshold_usd"
              }
            }
          },
          {
            "name": "total_count",
            "type": "count"
          },
          {
            "name": "total_amount",
            "type": "sum",
            "field": "amount"
          }
        ]
      },
      "binding_method": "unbound"
    },
    {
      "id": "get_google_sheet",
      "kind": "artifact",
      "summary": "Reference existing Google Sheets spreadsheet",
      "uses": [
        {
          "capability": "get",
          "domain": "table",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "output": "expense_sheet",
      "artifact": {
        "domain": "table",
        "type": "spreadsheet",
        "strategy": "use_existing",
        "options": {
          "spreadsheet_id": {
            "kind": "config",
            "key": "google_sheet_id"
          },
          "tab_name": {
            "kind": "config",
            "key": "sheet_tab_name"
          }
        }
      },
      "plugin_key": "google-sheets",
      "action": "read_range",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: table",
        "✅ Capability match: get",
        "✅ Provider preference matched: google",
        "✅ Idempotent action (UNIVERSAL DEFAULT for artifact creation)",
        "✅ Read-only action matches strategy: use_existing"
      ]
    },
    {
      "id": "append_high_value_to_sheet",
      "kind": "loop",
      "summary": "Append each high-value transaction to Google Sheets",
      "inputs": [
        "high_value_transactions",
        "expense_sheet"
      ],
      "loop": {
        "over": "high_value_transactions",
        "item_ref": "transaction",
        "unit_of_work": {
          "entity": "transaction"
        },
        "do": [
          {
            "id": "append_transaction_row",
            "kind": "deliver",
            "summary": "Append transaction row to Google Sheets",
            "inputs": [
              "transaction",
              "expense_sheet"
            ],
            "uses": [
              {
                "capability": "append",
                "domain": "table",
                "preferences": {
                  "provider_family": "google"
                }
              }
            ],
            "deliver": {
              "domain": "table",
              "intent": "append",
              "input": "transaction",
              "destination": "expense_sheet",
              "mapping": [
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "date"
                  },
                  "to": "Date"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "vendor"
                  },
                  "to": "Vendor"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "amount"
                  },
                  "to": "Amount"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "currency"
                  },
                  "to": "Currency"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "invoice_number"
                  },
                  "to": "Invoice Number"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "drive_link"
                  },
                  "to": "Drive Link"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "email_sender"
                  },
                  "to": "Email Sender"
                },
                {
                  "from": {
                    "kind": "ref",
                    "ref": "transaction",
                    "field": "email_subject"
                  },
                  "to": "Email Subject"
                }
              ]
            },
            "plugin_key": "google-sheets",
            "action": "append_rows",
            "binding_confidence": 1,
            "binding_method": "exact_match",
            "binding_reason": [
              "✅ Domain match: table",
              "✅ Capability match: append",
              "✅ Provider preference matched: google"
            ]
          }
        ]
      },
      "binding_method": "unbound"
    },
    {
      "id": "generate_summary_content",
      "kind": "generate",
      "summary": "Generate email summary with transaction tables and totals",
      "inputs": [
        "valid_transactions",
        "high_value_transactions",
        "low_value_transactions",
        "transaction_metrics"
      ],
      "output": "summary_email_content",
      "uses": [
        {
          "capability": "generate",
          "domain": "internal"
        }
      ],
      "generate": {
        "format": "html",
        "instruction": "Create an email-friendly HTML summary with: 1) A table of ALL extracted transactions with columns for date, vendor, amount, currency, invoice number, Drive link, email sender, and email subject. 2) A separate section listing only transactions with amount > $50. 3) A totals summary showing total number of transactions and sum of all amounts. Include proper HTML formatting with tables.",
        "outputs": [
          {
            "name": "subject",
            "type": "string",
            "description": "Email subject line"
          },
          {
            "name": "body",
            "type": "string",
            "description": "HTML email body with tables and summary"
          }
        ]
      },
      "plugin_key": "chatgpt-research",
      "action": "answer_question",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: internal",
        "✅ Capability match: generate"
      ]
    },
    {
      "id": "send_summary_email",
      "kind": "notify",
      "summary": "Send summary email to user",
      "inputs": [
        "summary_email_content"
      ],
      "uses": [
        {
          "capability": "send_message",
          "domain": "email",
          "preferences": {
            "provider_family": "google"
          }
        }
      ],
      "notify": {
        "channel": "email",
        "recipients": {
          "to": [
            {
              "kind": "config",
              "key": "user_email"
            }
          ]
        },
        "content": {
          "subject": {
            "kind": "ref",
            "ref": "summary_email_content",
            "field": "subject"
          },
          "body": {
            "kind": "ref",
            "ref": "summary_email_content",
            "field": "body"
          },
          "format": "html"
        }
      },
      "plugin_key": "google-mail",
      "action": "send_email",
      "binding_confidence": 1,
      "binding_method": "exact_match",
      "binding_reason": [
        "✅ Domain match: email",
        "✅ Capability match: send_message",
        "✅ Provider preference matched: google"
      ]
    }
  ],
  "confidence": 0.95,
  "subset_resolution": {
    "success": true,
    "subsets": {},
    "errors": [],
    "warnings": []
  }
}